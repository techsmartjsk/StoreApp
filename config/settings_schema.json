[
  {
    "name": "theme_info",
    "theme_name": "Precious Carats",
    "theme_version": "1.0.0",
    "theme_author": "StoreApp",
    "theme_documentation_url": "",
    "theme_support_url": ""
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "header",
        "content": "Primary Colors"
      },
      {
        "type": "color",
        "id": "color_primary",
        "label": "Primary color",
        "default": "#1a1a1a"
      },
      {
        "type": "color",
        "id": "color_secondary",
        "label": "Secondary / Gold accent",
        "default": "#c9a96e"
      },
      {
        "type": "color",
        "id": "color_background",
        "label": "Background color",
        "default": "#faf7f2"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Text color",
        "default": "#1a1a1a"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "heading_font",
        "label": "Heading font",
        "default": "cormorant_garamond_n6"
      },
      {
        "type": "font_picker",
        "id": "body_font",
        "label": "Body font",
        "default": "inter_n4"
      },
      {
        "type": "range",
        "id": "heading_font_scale",
        "min": 80,
        "max": 150,
        "step": 5,
        "default": 100,
        "label": "Heading font scale (%)"
      },
      {
        "type": "range",
        "id": "body_font_scale",
        "min": 80,
        "max": 130,
        "step": 5,
        "default": 100,
        "label": "Body font scale (%)"
      }
    ]
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon image",
        "info": "32 x 32px recommended."
      }
    ]
  },
  {
    "name": "Social Media",
    "settings": [
      {
        "type": "header",
        "content": "Social accounts"
      },
      {
        "type": "text",
        "id": "social_instagram_link",
        "label": "Instagram",
        "info": "https://instagram.com/yourshop"
      },
      {
        "type": "text",
        "id": "social_facebook_link",
        "label": "Facebook",
        "info": "https://facebook.com/yourshop"
      },
      {
        "type": "text",
        "id": "social_twitter_link",
        "label": "Twitter",
        "info": "https://twitter.com/yourshop"
      },
      {
        "type": "text",
        "id": "social_youtube_link",
        "label": "YouTube",
        "info": "https://youtube.com/yourshop"
      },
      {
        "type": "text",
        "id": "social_pinterest_link",
        "label": "Pinterest",
        "info": "https://pinterest.com/yourshop"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart type",
        "options": [
          { "value": "page", "label": "Page" },
          { "value": "drawer", "label": "Drawer" }
        ],
        "default": "page"
      },
      {
        "type": "checkbox",
        "id": "show_cart_note",
        "label": "Show cart note",
        "default": true
      }
    ]
  },
  {
    "name": "Currency",
    "settings": [
      {
        "type": "header",
        "content": "Currency format"
      },
      {
        "type": "checkbox",
        "id": "currency_code_enabled",
        "label": "Show currency codes",
        "default": false
      }
    ]
  }
]
