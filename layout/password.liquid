<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>{{ shop.name }} - Coming Soon</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">
    {{ content_for_header }}
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: 'Inter', sans-serif;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #1a1a1a 0%, #2c1810 30%, #4a3728 60%, #c9a96e 100%);
        color: #fff;
        padding: 2rem;
      }
      .password-page {
        text-align: center;
        max-width: 500px;
      }
      .password-page h1 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 3rem;
        margin-bottom: 1rem;
        font-weight: 600;
      }
      .password-page p {
        font-size: 0.95rem;
        color: rgba(255,255,255,0.7);
        margin-bottom: 2rem;
        line-height: 1.6;
      }
      .password-form { display: flex; gap: 0.5rem; max-width: 400px; margin: 0 auto; }
      .password-form input {
        flex: 1;
        padding: 12px 16px;
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 4px;
        background: rgba(255,255,255,0.1);
        color: #fff;
        font-family: inherit;
        font-size: 0.9rem;
        outline: none;
      }
      .password-form input:focus { border-color: #c9a96e; }
      .password-form button {
        padding: 12px 24px;
        background: #c9a96e;
        color: #fff;
        border: none;
        border-radius: 4px;
        font-family: inherit;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.3s;
      }
      .password-form button:hover { background: #a07d4f; }
    </style>
  </head>
  <body>
    {{ content_for_layout }}
    <div class="password-page">
      <h1>{{ shop.name }}</h1>
      <p>{{ shop.password_message | default: 'We are launching soon. Enter the store password to continue.' }}</p>
      {% form 'storefront_password' %}
        <div class="password-form">
          <input type="password" name="password" placeholder="Enter password" aria-label="Password">
          <button type="submit">Enter</button>
        </div>
        {%- if form.errors -%}
          <p style="color:#e74c3c;margin-top:1rem;font-size:0.85rem;">{{ form.errors | default_errors }}</p>
        {%- endif -%}
      {% endform %}
    </div>
  </body>
</html>
