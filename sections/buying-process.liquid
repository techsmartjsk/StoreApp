</section>

<style>
  .buying-process {
    text-align: center;
  }

  .buying-process .section-heading {
    text-transform: none;
    font-size: var(--font-size-2xl);
    letter-spacing: 0;
    margin-bottom: var(--space-4xl);
    font-family: var(--font-heading);
    font-weight: 400;
  }

  .buying-process__grid {
    display: flex;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
    position: relative;
  }

  .buying-process__item {
    flex: 1;
    min-width: 150px;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .process-icon-wrapper {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background-color: var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-lg);
    position: relative;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
  }

  .process-icon {
    width: 40px;
    height: 40px;
  }

  .process-icon svg {
    width: 100%;
    height: 100%;
  }

  .process-number {
    position: absolute;
    top: -5px;
    right: -5px;
    width: 24px;
    height: 24px;
    background-color: #3e6d5b; /* deep green */
    color: var(--color-white);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 600;
    border: 2px solid var(--color-bg-warm); /* Match section bg */
  }

  .process-title {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: var(--space-sm);
    font-weight: 600;
  }

  .process-desc {
    font-size: 12px;
    color: var(--color-text-light);
    line-height: 1.5;
    max-width: 200px;
  }

  @media screen and (max-width: 768px) {
    .buying-process__grid {
      flex-direction: column;
      align-items: center;
      gap: var(--space-2xl);
    }
    .buying-process .section-heading {
      margin-bottom: var(--space-3xl);
    }
  }
</style>

{% schema %}
{
  "name": "Buying Process",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Easy Buying Process"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#d8c3ad"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Process Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "STEP TITLE"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Description of this step in the process."
        },
        {
          "type": "html",
          "id": "svg_code",
          "label": "SVG Icon Code"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Buying Process",
      "blocks": [
