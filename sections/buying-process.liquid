                  <img src="{{ 'feature-shipping.svg' | asset_url }}" alt="Receive Gemstone" style="width:100%;height:100%;object-fit:contain;">
              {%- endcase -%}
            </div>
            <div class="process-number">{{ forloop.index }}</div>
          </div>
          <h3 class="process-title">{{ block.settings.title }}</h3>
