{%- comment -%}
  Certification Bar Section
  Dark bar showcasing lab certifications
{%- endcomment -%}

<section class="cert-bar reveal" id="cert-bar">
  <div class="page-width">
    <div class="cert-bar__wrapper">
      <h2 class="cert-bar__text">{{ section.settings.heading }}</h2>

      <div class="cert-bar__logos">
        {%- for block in section.blocks -%}
          {%- if block.type == 'logo' -%}
            <div class="cert-bar__logo" {{ block.shopify_attributes }}>
              {%- if block.settings.logo -%}
                <img
                  src="{{ block.settings.logo | image_url: width: 120 }}"
                  alt="{{ block.settings.name | escape }}"
                  loading="lazy"
                >
              {%- else -%}
                <span style="font-weight:700;font-size:12px;color:var(--color-primary);letter-spacing:0.05em;">{{ block.settings.name }}</span>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if section.settings.button_text != blank -%}
        <div class="cert-bar__btn">
          <a href="{{ section.settings.button_url | default: '#' }}" class="btn btn--white btn--sm">
            {{ section.settings.button_text }}
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Certification Bar",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our gems are certified by 12 world-class labs"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "VIEW ALL"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Lab Logo",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Lab name",
          "default": "GIA"
        },
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Lab logo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Certification Bar",
      "blocks": [
        { "type": "logo", "settings": { "name": "GIA" } },
        { "type": "logo", "settings": { "name": "IGI" } },
        { "type": "logo", "settings": { "name": "GRS" } },
        { "type": "logo", "settings": { "name": "AIGS" } }
      ]
    }
  ]
}
{% endschema %}
