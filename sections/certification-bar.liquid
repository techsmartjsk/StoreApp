{%- comment -%}
  Certification Bar Section
  Dark bar showcasing lab certifications
{%- endcomment -%}

<section class="cert-bar reveal" id="cert-bar">
  <div class="page-width">
    <div class="cert-bar__wrapper">
      <h2 class="cert-bar__text">{{ section.settings.heading }}</h2>

      <div class="cert-bar__logos">
        <div class="cert-bar__logo">
          <img src="{{ 'brand-igi.jpeg' | asset_url }}" alt="IGI" loading="lazy">
        </div>
        <div class="cert-bar__logo">
          <img src="{{ 'brand-gci.jpeg' | asset_url }}" alt="GCI" loading="lazy">
        </div>
        <div class="cert-bar__logo">
          <img src="{{ 'brand-grs.jpeg' | asset_url }}" alt="GRS" loading="lazy">
        </div>
        <div class="cert-bar__logo">
          <img src="{{ 'brand-gci.jpeg' | asset_url }}" alt="GCI" loading="lazy">
        </div>
      </div>

      {%- if section.settings.button_text != blank -%}
        <div class="cert-bar__btn">
          <a href="{{ section.settings.button_url }}" class="btn btn--outline-dark btn--sm">
            {{ section.settings.button_text }}
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Certification Bar",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our gems are certified by 12 world-class labs"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "VIEW ALL"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "/collections/certified-by-12-world-class-labs"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Lab Logo",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Lab name",
          "default": "GIA"
        },
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Lab logo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Certification Bar",
      "blocks": [
        { "type": "logo", "settings": { "name": "GIA" } },
        { "type": "logo", "settings": { "name": "IGI" } },
        { "type": "logo", "settings": { "name": "GRS" } },
        { "type": "logo", "settings": { "name": "AIGS" } }
      ]
    }
  ]
}
{% endschema %}
