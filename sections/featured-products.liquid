{%- comment -%}
  Featured Products Section
  Product carousel with optional side promo banner
{%- endcomment -%}

<section class="featured-products section-{{ section.id }} reveal" id="featured-products-{{ section.id }}">
  <div class="featured-products__split">
    {%- if section.settings.show_promo -%}
      <div class="featured-products__promo">
        <div class="featured-products__promo-image">
          {%- if section.settings.asset_name != blank -%}
            <img src="{{ section.settings.asset_name | asset_url }}" alt="" loading="lazy">
          {%- elsif section.settings.promo_image -%}
            <img src="{{ section.settings.promo_image | image_url: width: 800 }}" alt="" loading="lazy">
          {%- else -%}
            <div class="promo-placeholder"></div>
          {%- endif -%}
        </div>
        <div class="featured-products__promo-content">
          <h3 class="promo-title">{{ section.settings.promo_title }}</h3>
          <p class="promo-subtitle">{{ section.settings.promo_subtitle }}</p>
        </div>
      </div>
    {%- endif -%}

    <div class="featured-products__main">
      <div class="featured-products__header">
        <h2 class="featured-products__title">{{ section.settings.heading }}</h2>
        {%- if section.settings.view_all_url != blank -%}
          <a href="{{ section.settings.view_all_url }}" class="view-all-link">
            {{ section.settings.view_all_text | default: 'VIEW ALL' }}
          </a>
        {%- endif -%}
      </div>

      <div class="featured-products__carousel-container">
        <div class="featured-products__grid scroll-container" id="featured-grid-{{ section.id }}">
          {%- if section.settings.collection != blank -%}
            {%- for product in collections[section.settings.collection].products limit: section.settings.products_count -%}
              <div class="carousel-item">
                {% render 'product-card', product: product %}
              </div>
            {%- endfor -%}
          {%- else -%}
            {%- for i in (1..section.settings.products_count) -%}
              <div class="carousel-item">
                {% render 'product-card', product: nil %}
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>

        <button class="carousel-nav-btn next-btn" aria-label="Next products" onclick="const container = document.getElementById('featured-grid-{{ section.id }}'); container.scrollBy({left: container.offsetWidth * 0.8, behavior: 'smooth'})">
          {% render 'icon', name: 'play' %}
        </button>
      </div>

      <div class="featured-products__dots">
        <div class="dot active"></div>
        <div class="dot"></div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "CRUSH-WORTHY DELIGHTS"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_count",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "Number of products"
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View all text",
      "default": "VIEW ALL"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "View all URL"
    },
    {
      "type": "header",
      "content": "Promo Banner"
    },
    {
      "type": "checkbox",
      "id": "show_promo",
      "label": "Show promo banner",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "promo_image",
      "label": "Promo image"
    },
    {
      "type": "text",
      "id": "asset_name",
      "label": "Promo Asset Name (e.g. strand-1.jpg)"
    },
    {
      "type": "text",
      "id": "promo_title",
      "label": "Promo title",
      "default": "Elegance within reach"
    },
    {
      "type": "text",
      "id": "promo_subtitle",
      "label": "Promo subtitle",
      "default": "GEMSTONES UNDER ₹50,000"
    }
  ],
  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}
