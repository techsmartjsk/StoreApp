{%- comment -%}
  Featured Products Section
  Product carousel with optional side promo banner
{%- endcomment -%}

<section class="featured-products section-padding reveal" id="featured-products-{{ section.id }}">
  <div class="page-width">
    <div class="featured-products__header">
      <div>
        <h2 class="section-heading" style="font-size:var(--font-size-2xl);">{{ section.settings.heading }}</h2>
      </div>
      {%- if section.settings.view_all_url != blank -%}
        <a href="{{ section.settings.view_all_url }}" class="btn btn--secondary btn--sm">
          {{ section.settings.view_all_text | default: 'VIEW ALL' }}
        </a>
      {%- endif -%}
    </div>

    <div class="featured-products__layout">
      {%- if section.settings.show_promo -%}
        <!-- Promo Side Banner -->
        <div class="promo-banner">
          {%- if section.settings.asset_name != blank -%}
            <div class="promo-banner__media">
              <img
                src="{{ section.settings.asset_name | asset_url }}"
                alt="{{ section.settings.promo_title | escape }}"
                loading="lazy"
              >
            </div>
          {%- elsif section.settings.promo_image -%}
            <div class="promo-banner__media">
              <img
                src="{{ section.settings.promo_image | image_url: width: 600 }}"
                alt="{{ section.settings.promo_title | escape }}"
                loading="lazy"
              >
            </div>
          {%- else -%}
            <div class="promo-banner__media">
              <div style="width:100%;height:100%;background:linear-gradient(135deg, #2c1810 0%, #c9a96e 100%);"></div>
            </div>
          {%- endif -%}
          <div class="promo-banner__content">
            <h3 class="promo-banner__title">{{ section.settings.promo_title }}</h3>
            <p class="promo-banner__subtitle">{{ section.settings.promo_subtitle }}</p>
            {%- if section.settings.promo_button_text != blank -%}
              <a href="{{ section.settings.promo_button_url | default: '#' }}" class="btn btn--white btn--sm">
                {{ section.settings.promo_button_text }}
              </a>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}

      <!-- Product Grid -->
      <div class="featured-products__grid">
        {%- if section.settings.collection != blank -%}
          {%- for product in collections[section.settings.collection].products limit: section.settings.products_count -%}
            {% render 'product-card', product: product %}
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..4) -%}
            <div class="product-card">
              <div class="product-card__image" style="background:#fff; padding:20px; text-align:center;">
                  <img src="{{ 'crush-' | append: i | append: '.jpg' | asset_url }}" alt="Crystal Gem" loading="lazy" style="width:100%;height:auto;aspect-ratio:1;object-fit:contain;">
              </div>
              <div class="product-card__info" style="padding:15px; background:#fff; border-top:1px solid #eee;">
                <h3 class="product-card__title" style="font-size:11px; margin-bottom:4px;">Product Name</h3>
                <div class="product-card__price" style="font-size:10px; color:#666; margin-bottom:12px;">Price: ₹50,000</div>
                <div style="display:flex; gap:8px;">
                  <button style="border:1px solid #ccc; background:none; width:30px; height:30px; display:flex; align-items:center; justify-content:center; cursor:pointer;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg></button>
                  <button style="border:1px solid #ccc; background:none; flex:1; font-size:10px; letter-spacing:1px; cursor:pointer;">VIEW DETAILS</button>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "CRUSH-WORTHY DELIGHTS"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_count",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "Number of products"
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View all text",
      "default": "VIEW ALL"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "View all URL"
    },
    {
      "type": "header",
      "content": "Promo Banner"
    },
    {
      "type": "checkbox",
      "id": "show_promo",
      "label": "Show promo banner",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "promo_image",
      "label": "Promo image"
    },
    {
      "type": "text",
      "id": "asset_name",
      "label": "Promo Asset Name (e.g. strand-1.jpg)"
    },
    {
      "type": "text",
      "id": "promo_title",
      "label": "Promo title",
      "default": "Elegance within reach"
    },
    {
      "type": "text",
      "id": "promo_subtitle",
      "label": "Promo subtitle",
      "default": "GEMSTONES UNDER ₹50,000"
    },
    {
      "type": "text",
      "id": "promo_button_text",
      "label": "Promo button text",
      "default": "VIEW DETAILS"
    },
    {
      "type": "url",
      "id": "promo_button_url",
      "label": "Promo button URL"
    }
  ],
  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}
