        },
        {
          "type": "text",
          "id": "link_3_text",
          "label": "Link 3 text"
        },
        {
          "type": "url",
          "id": "link_3_url",
          "label": "Link 3 URL"
        },
        {
          "type": "text",
          "id": "link_4_text",
          "label": "Link 4 text"
        },
        {
          "type": "url",
          "id": "link_4_url",
          "label": "Link 4 URL"
        },
        {
          "type": "text",
          "id": "link_5_text",
          "label": "Link 5 text"
        },
        {
          "type": "url",
          "id": "link_5_url",
          "label": "Link 5 URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        {
          "type": "link_column",
          "settings": {
            "heading": "Assistance",
