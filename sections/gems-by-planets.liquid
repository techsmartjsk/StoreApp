        { "type": "planet", "settings": { "title": "GURU", "icon_image": "guru.png"} },
        { "type": "planet", "settings": { "title": "RAHU", "icon_image": "rahu.png"} },
        { "type": "planet", "settings": { "title": "SHANI", "icon_image": "shani.png"} },
        { "type": "planet", "settings": { "title": "MANGAL", "icon_image": "mangal.png"} },
        { "type": "planet", "settings": { "title": "KETU", "icon_image": "ketu.png"} },
        { "type": "planet", "settings": { "title": "BUDH", "icon_image": "budh.png"} }
      ]
    }
  ]
}
{% endschema %}
