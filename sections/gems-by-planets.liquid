{%- comment -%}
  Gems By Planets Section — Swiper.js powered
{%- endcomment -%}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

<section class="gems-planets section-padding reveal" id="section-{{ section.id }}">
  <div class="page-width">
    <div class="gems-planets__header">
      <div class="header-center">
        {%- if section.settings.heading != blank -%}
          <h2 class="section-heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="section-subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>

      {%- if section.settings.view_all_text != blank -%}
        <div class="header-right">
          <a href="{{ section.settings.view_all_link | default: '#' }}" class="view-all-link">
            {{ section.settings.view_all_text }}
          </a>
        </div>
      {%- endif -%}
    </div>

    <div class="gems-planets__carousel-container">
      <div class="swiper gems-planets__swiper" id="gems-swiper-{{ section.id }}">
        <div class="swiper-wrapper">
          {%- for block in section.blocks -%}
            <div class="swiper-slide">
              <a href="{{ block.settings.url | default: '#' }}" class="gems-planets__item" {{ block.shopify_attributes }}>
                <div class="planet-icon-wrapper">
                  <div class="planet-icon">
                    <img
                      src="{{ block.settings.title | downcase | append: '.png' | asset_url }}"
                      alt="{{ block.settings.title }}"
                      loading="lazy"
                    >
                  </div>
                </div>
                <h3 class="planet-title">{{ block.settings.title }}</h3>
                <p class="planet-subtitle">{{ block.settings.subtitle }}</p>
                <div class="planet-separator"></div>
                <p class="planet-desc">{{ block.settings.description }}</p>
              </a>
            </div>
          {%- endfor -%}
        </div>
      </div>

      <button class="carousel-nav-btn prev-btn" aria-label="Previous" id="gems-prev-{{ section.id }}">
        {% render 'icon', name: 'chevron-left' %}
      </button>
      <button class="carousel-nav-btn next-btn" aria-label="Next" id="gems-next-{{ section.id }}">
        {% render 'icon', name: 'chevron-right' %}
      </button>
    </div>

    <div class="gems-planets__dots" id="gems-pagination-{{ section.id }}"></div>
  </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const swiperEl = document.getElementById('gems-swiper-{{ section.id }}');
    if (!swiperEl) return;

    new Swiper(swiperEl, {
      slidesPerView: 'auto',
      spaceBetween: 16,
      grabCursor: true,
      freeMode: {
        enabled: true,
        momentum: true,
        momentumRatio: 0.8,
        momentumBounceRatio: 0.6
      },
      speed: 600,
      loop: true,
      autoplay: {
        delay: 4000,
        disableOnInteraction: false,
        pauseOnMouseEnter: true
      },
      navigation: {
        prevEl: '#gems-prev-{{ section.id }}',
        nextEl: '#gems-next-{{ section.id }}'
      },
      pagination: {
        el: '#gems-pagination-{{ section.id }}',
        clickable: true,
        renderBullet: function(index, className) {
          return '<span class="dot ' + className + '"></span>';
        }
      },
      breakpoints: {
        0: {
          slidesPerView: 1,
          spaceBetween: 0,
          freeMode: false,
          centeredSlides: true
        },
        769: {
          slidesPerView: 'auto',
          spaceBetween: 16,
          freeMode: {
            enabled: true,
            momentum: true,
            momentumRatio: 0.8,
            momentumBounceRatio: 0.6
          },
          centeredSlides: false
        }
      }
    });
  });
</script>

{% schema %}
{
  "name": "Gems By Planets",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "GEMS BY PLANETS"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Sacred nine gemstones for harmony, prosperity, and balance in life."
    }
  ],
  "blocks": [
    {
      "type": "planet",
      "name": "Planet Gem",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Planet/Title",
          "default": "SURYA"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Yellow Sapphire, Blue Sapphire and Hessonite"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Growth, Health, Finance"
        },
        {
          "type": "text",
          "id": "icon_image",
          "label": "Planet Icon Image"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gems By Planets",
      "blocks": [
        { "type": "planet", "settings": { "title": "SURYA", "icon_image": "surya.png"} },
        { "type": "planet", "settings": { "title": "CHANDRA", "icon_image": "chandra.png"} },
        { "type": "planet", "settings": { "title": "SHUKRA", "icon_image": "shukra.png"} },
        { "type": "planet", "settings": { "title": "GURU", "icon_image": "guru.png"} },
        { "type": "planet", "settings": { "title": "RAHU", "icon_image": "rahu.png"} },
        { "type": "planet", "settings": { "title": "SHANI", "icon_image": "shani.png"} },
        { "type": "planet", "settings": { "title": "MANGAL", "icon_image": "mangal.png"} },
        { "type": "planet", "settings": { "title": "KETU", "icon_image": "ketu.png"} },
        { "type": "planet", "settings": { "title": "BUDH", "icon_image": "budh.png"} }
      ]
    }
  ]
}
{% endschema %}
