{%- comment -%}
  Gems By Planets Section
{%- endcomment -%}

<section class="gems-planets section-padding reveal" id="section-{{ section.id }}">
  <div class="page-width">
    <div class="gems-planets__header">
      <div class="header-center">
        {%- if section.settings.heading != blank -%}
          <h2 class="section-heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="section-subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
      
      {%- if section.settings.view_all_text != blank -%}
        <div class="header-right">
          <a href="{{ section.settings.view_all_link | default: '#' }}" class="view-all-link">
            {{ section.settings.view_all_text }}
          </a>
        </div>
      {%- endif -%}
    </div>

    <div class="gems-planets__carousel-container">
      <button class="carousel-nav-btn prev-btn" aria-label="Previous">
        {% render 'icon', name: 'chevron-left' %}
      </button>

      <div class="gems-planets__carousel scroll-container">
        {%- for block in section.blocks -%}
          <a href="{{ block.settings.url | default: '#' }}" class="gems-planets__item" {{ block.shopify_attributes }}>
            <div class="planet-icon-wrapper">
              <div class="planet-icon">
                <img
                  src="{{ block.settings.title | downcase | append: '.png' | asset_url }}"
                  alt="{{ block.settings.title }}"
                  loading="lazy"
                >
              </div>
            </div>
            <h3 class="planet-title">{{ block.settings.title }}</h3>
            <p class="planet-subtitle">{{ block.settings.subtitle }}</p>
            <div class="planet-separator"></div>
            <p class="planet-desc">{{ block.settings.description }}</p>
          </a>
        {%- endfor -%}
      </div>

      <button class="carousel-nav-btn next-btn" aria-label="Next">
        {% render 'icon', name: 'chevron-right' %}
      </button>
    </div>

    <div class="gems-planets__dots">
      {%- for block in section.blocks limit: 3 -%}
        <span class="dot {% if forloop.first %}active{% endif %}"></span>
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const parent = document.getElementById('section-{{ section.id }}');
    if (!parent) return;

    const carousel = parent.querySelector('.gems-planets__carousel');
    const scrollContainer = parent.querySelector('.scroll-container');
    const prevBtn = parent.querySelector('.prev-btn');
    const nextBtn = parent.querySelector('.next-btn');
    const dots = parent.querySelectorAll('.dot');
    
    if(carousel && prevBtn && nextBtn) {
      const getScrollAmount = () => {
        const itemWidth = carousel.querySelector('.gems-planets__item')?.offsetWidth || 200;
        const gap = 16;
        return itemWidth + gap;
      };

      const scrollNext = () => {
        const maxScroll = carousel.scrollWidth - carousel.clientWidth;
        if (carousel.scrollLeft >= maxScroll - 10) {
          carousel.scrollTo({ left: 0, behavior: 'smooth' });
        } else {
          carousel.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
        }
      };

      prevBtn.addEventListener('click', () => {
        carousel.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
      });

      nextBtn.addEventListener('click', () => {
        scrollNext();
      });
      
      carousel.addEventListener('scroll', () => {
        const scrollPercentage = carousel.scrollLeft / (carousel.scrollWidth - carousel.clientWidth);
        const index = Math.min(Math.round(scrollPercentage * (dots.length - 1)), dots.length - 1);
        
        dots.forEach((dot, i) => {
          dot.classList.toggle('active', i === index);
        });
      });

      // Auto-scroll
      let autoScrollInterval = setInterval(scrollNext, 4000);

      parent.addEventListener('mouseenter', () => {
        clearInterval(autoScrollInterval);
      });

      parent.addEventListener('mouseleave', () => {
        autoScrollInterval = setInterval(scrollNext, 4000);
      });

      // Simple mouse drag to scroll
      let isDown = false;
      let startIndex;
      let scrollLeft;

      carousel.addEventListener('mousedown', (e) => {
        isDown = true;
        carousel.classList.add('active');
        startIndex = e.pageX - carousel.offsetLeft;
        scrollLeft = carousel.scrollLeft;
        clearInterval(autoScrollInterval);
      });

      carousel.addEventListener('mouseup', () => {
        isDown = false;
        // Don't restart here, leave it to mouseleave or just let it resume
      });

      carousel.addEventListener('mouseleave', () => {
        isDown = false;
      });

      carousel.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - carousel.offsetLeft;
        const walk = (x - startIndex) * 2;
        carousel.scrollLeft = scrollLeft - walk;
      });
    }
  });
</script>

{% schema %}
{
  "name": "Gems By Planets",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "GEMS BY PLANETS"
