{%- comment -%}
  Gemstone Collection Section
  Used for both Navratnas and Upratnas sections
{%- endcomment -%}

<section class="gem-collection{% if section.settings.alternate_bg %} gem-collection--alt{% endif %} reveal" id="gem-collection-{{ section.id }}">
  <div class="page-width">
    <h2 class="section-heading">{{ section.settings.heading }}</h2>
    <p class="section-subheading">{{ section.settings.subheading }}</p>

    <div class="gem-grid-wrapper">
      {%- if section.settings.show_arrows -%}
        <button class="gem-scroll-btn gem-scroll-btn--left" aria-label="Previous" data-grid="gem-grid-{{ section.id }}">
          <svg viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
      {%- endif -%}

      <div class="gem-grid" id="gem-grid-{{ section.id }}">
        {%- assign mobile_limit = section.settings.mobile_items_limit | default: 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'gemstone' -%}
            {%- assign is_hidden_mobile = false -%}
            {%- if mobile_limit > 0 and forloop.index > mobile_limit -%}
              {%- assign is_hidden_mobile = true -%}
            {%- endif -%}
            <a href="{{ block.settings.url | default: '#' }}" 
               class="gem-item{% if is_hidden_mobile %} hidden-mobile{% endif %}" 
               {{ block.shopify_attributes }}>
              <div class="gem-item__image">
                {%- if block.settings.asset_name != blank -%}
                  <img
                    src="{{ block.settings.asset_name | asset_url }}"
                    alt="{{ block.settings.name | escape }}"
                    width="80"
                    height="80"
                    loading="lazy"
                  >
                {%- elsif block.settings.image -%}
                  <img
                    src="{{ block.settings.image | image_url: width: 200 }}"
                    alt="{{ block.settings.name | escape }}"
                    width="80"
                    height="80"
                    loading="lazy"
                  >
                {%- else -%}
                  <div style="width:100%;height:100%;background:{{ block.settings.placeholder_color | default: '#ddd' }};"></div>
                {%- endif -%}
              </div>
              <span class="gem-item__name">{{ block.settings.name }}</span>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if section.settings.show_arrows -%}
        <button class="gem-scroll-btn gem-scroll-btn--right" aria-label="Next" data-grid="gem-grid-{{ section.id }}">
          <svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      {%- endif -%}
    </div>

    {%- if section.settings.button_text != blank -%}
      {%- assign default_url = '/collections/all' -%}
      {%- assign heading_up = section.settings.heading | upcase -%}
      {%- if heading_up contains 'NAVRATNA' -%}
        {%- assign default_url = '/collections/navratna' -%}
      {%- elsif heading_up contains 'UPRATNA' -%}
        {%- assign default_url = '/collections/upratnas' -%}
      {%- endif -%}

      <div style="text-align: center;">
        <a href="{{ section.settings.button_url | default: default_url }}" class="btn btn--secondary">
          {{ section.settings.button_text }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .gem-grid-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-2xl);
  }
  .gem-grid-wrapper .gem-grid {
    margin-bottom: 0;
  }
  
  @media screen and (max-width: 768px) {
    .gem-item.hidden-mobile {
      display: none !important;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Manual arrow buttons
    document.querySelectorAll('.gem-scroll-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const grid = document.getElementById(btn.dataset.grid);
        if (!grid) return;
        const dir = btn.classList.contains('gem-scroll-btn--left') ? -220 : 220;
        grid.scrollBy({ left: dir, behavior: 'smooth' });
      });
    });

    // Auto-scroll for sections that have arrows (Upratnas)
    document.querySelectorAll('.gem-collection--alt .gem-grid').forEach(grid => {
      let paused = false;
      let interval;

      function startAutoScroll() {
        interval = setInterval(() => {
          if (paused) return;
          const maxScroll = grid.scrollWidth - grid.clientWidth;
          if (grid.scrollLeft >= maxScroll - 2) {
            // Loop back to start
            grid.scrollTo({ left: 0, behavior: 'smooth' });
          } else {
            grid.scrollBy({ left: 220, behavior: 'smooth' });
          }
        }, 2800);
      }

      // Pause on hover / touch
      grid.addEventListener('mouseenter', () => { paused = true; });
      grid.addEventListener('mouseleave', () => { paused = false; });
      grid.addEventListener('touchstart', () => { paused = true; }, { passive: true });
      grid.addEventListener('touchend',   () => { setTimeout(() => { paused = false; }, 2000); }, { passive: true });

      startAutoScroll();
    });
  });
</script>

{% schema %}
{
  "name": "Gemstone Collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "NAVRATNAS"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Sacred nine gemstones for harmony, prosperity, and balance in life."
    },
    {
      "type": "checkbox",
      "id": "alternate_bg",
      "label": "Use alternate background",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show scroll arrows",
      "default": false
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "VIEW ALL"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "range",
      "id": "mobile_items_limit",
      "min": 0,
      "max": 30,
      "step": 1,
      "default": 0,
      "label": "Mobile items limit (0 for all)"
    }
  ],
  "blocks": [
    {
      "type": "gemstone",
      "name": "Gemstone",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Gemstone name",
          "default": "Gemstone"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Gemstone image"
        },
        {
          "type": "text",
          "id": "asset_name",
          "label": "Asset Name (e.g. nav-ruby.png)"
        },
        {
          "type": "color",
          "id": "placeholder_color",
          "label": "Placeholder color (if no image)",
          "default": "#c9a96e"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gemstone Collection",
      "blocks": [
        { "type": "gemstone", "settings": { "name": "Ruby", "placeholder_color": "#e74c3c" } },
        { "type": "gemstone", "settings": { "name": "Pearl", "placeholder_color": "#f5f0e8" } },
        { "type": "gemstone", "settings": { "name": "Emerald", "placeholder_color": "#27ae60" } },
        { "type": "gemstone", "settings": { "name": "Cateye", "placeholder_color": "#c9a96e" } },
        { "type": "gemstone", "settings": { "name": "Red Coral", "placeholder_color": "#e74c3c" } },
        { "type": "gemstone", "settings": { "name": "Blue Sapphire", "placeholder_color": "#2980b9" } },
        { "type": "gemstone", "settings": { "name": "Yellow Sapphire", "placeholder_color": "#f1c40f" } },
        { "type": "gemstone", "settings": { "name": "Hessonite", "placeholder_color": "#d35400" } },
        { "type": "gemstone", "settings": { "name": "Name", "placeholder_color": "#8e44ad" } }
      ]
    }
  ]
}
{% endschema %}
