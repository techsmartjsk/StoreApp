{%- comment -%}
  Gemstone Collection Section
  Used for both Navratnas and Upratnas sections
{%- endcomment -%}

<section class="gem-collection{% if section.settings.alternate_bg %} gem-collection--alt{% endif %} reveal" id="gem-collection-{{ section.id }}">
  <div class="page-width">
    <h2 class="section-heading">{{ section.settings.heading }}</h2>
    <p class="section-subheading">{{ section.settings.subheading }}</p>

    <div class="gem-grid" id="gem-grid-{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'gemstone' -%}
          <a href="{{ block.settings.url | default: '#' }}" class="gem-item" {{ block.shopify_attributes }}>
            <div class="gem-item__image">
              {%- if block.settings.image -%}
                <img
                  src="{{ block.settings.image | image_url: width: 200 }}"
                  alt="{{ block.settings.name | escape }}"
                  width="80"
                  height="80"
                  loading="lazy"
                >
              {%- else -%}
                <div style="width:100%;height:100%;background:{{ block.settings.placeholder_color | default: '#ddd' }};"></div>
              {%- endif -%}
            </div>
            <span class="gem-item__name">{{ block.settings.name }}</span>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.button_text != blank -%}
      <div style="text-align: center;">
        <a href="{{ section.settings.button_url | default: '/collections/all' }}" class="btn btn--secondary">
          {{ section.settings.button_text }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Gemstone Collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "NAVRATNAS"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Sacred nine gemstones for harmony, prosperity, and balance in life."
    },
    {
      "type": "checkbox",
      "id": "alternate_bg",
      "label": "Use alternate background",
      "default": false
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "VIEW ALL"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    }
  ],
  "blocks": [
    {
      "type": "gemstone",
      "name": "Gemstone",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Gemstone name",
          "default": "Gemstone"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Gemstone image"
        },
        {
          "type": "color",
          "id": "placeholder_color",
          "label": "Placeholder color (if no image)",
          "default": "#c9a96e"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gemstone Collection",
      "blocks": [
        { "type": "gemstone", "settings": { "name": "Ruby", "placeholder_color": "#e74c3c" } },
        { "type": "gemstone", "settings": { "name": "Pearl", "placeholder_color": "#f5f0e8" } },
        { "type": "gemstone", "settings": { "name": "Emerald", "placeholder_color": "#27ae60" } },
        { "type": "gemstone", "settings": { "name": "Cateye", "placeholder_color": "#c9a96e" } },
        { "type": "gemstone", "settings": { "name": "Red Coral", "placeholder_color": "#e74c3c" } },
        { "type": "gemstone", "settings": { "name": "Blue Sapphire", "placeholder_color": "#2980b9" } },
        { "type": "gemstone", "settings": { "name": "Yellow Sapphire", "placeholder_color": "#f1c40f" } },
        { "type": "gemstone", "settings": { "name": "Hessonite", "placeholder_color": "#d35400" } },
        { "type": "gemstone", "settings": { "name": "Name", "placeholder_color": "#8e44ad" } }
      ]
    }
  ]
}
{% endschema %}
