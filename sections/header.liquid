{%- comment -%}
  Header Section — with mega-menu dropdown support
{%- endcomment -%}

<header class="site-header" id="site-header">
  <div class="header__wrapper page-width">
    <!-- Mobile Menu Toggle -->
    <button class="header__menu-toggle" id="mobile-menu-toggle" aria-label="Menu">
      {% render 'icon', name: 'menu' %}
    </button>

    <!-- Logo -->
    <div class="header__logo">
      <a href="/" class="header__logo-link" aria-label="{{ shop.name }}">
        {% if section.settings.logo != blank %}
          <img
            src="{{ section.settings.logo | image_url: width: section.settings.logo_width }}"
            alt="{{ shop.name }}"
            width="{{ section.settings.logo_width }}"
            height="auto"
            loading="eager"
            class="header__logo-image"
          >
        {% else %}
          <img
            src="{{ 'brand-logo.svg' | asset_url }}"
            alt="{{ shop.name }}"
            width="{{ section.settings.logo_width }}"
            height="auto"
            loading="eager"
            class="header__logo-image"
          >
        {% endif %}
      </a>
    </div>

    <!-- Search -->
    <div class="header__search">
      <form class="header__search-form" action="/search" method="get" role="search">
        <span class="header__search-icon">
          {% render 'icon', name: 'search' %}
        </span>
        <input
          type="search"
          name="q"
          id="header-search"
          class="header__search-input"
          placeholder="{{ section.settings.search_placeholder | default: 'Search for...' }}"
          autocomplete="off"
        >
      </form>
    </div>

    <!-- Header Icons -->
    <div class="header__icons">
      <a href="/pages/policies" class="header__icon-btn hide-mobile" aria-label="Policies">
        <img src="{{ 'balance.svg' | asset_url }}">
      </a>
      <a href="/account" class="header__icon-btn hide-mobile" aria-label="Account">
        {% render 'icon', name: 'user' %}
      </a>
      <a href="/pages/wishlist" class="header__icon-btn hide-mobile" aria-label="Wishlist">
        {% render 'icon', name: 'heart' %}
        <span class="header__wishlist-count" id="header-wishlist-count" style="display:none;">0</span>
      </a>
      <a href="/cart" class="header__icon-btn" aria-label="Cart">
        {% render 'icon', name: 'cart' %}
        {% if cart.item_count > 0 %}
          <span class="header__cart-count">{{ cart.item_count }}</span>
        {% endif %}
      </a>
    </div>
  </div>

  <!-- Navigation Bar -->
  <nav class="nav-bar" id="nav-bar" aria-label="Main navigation">
    <div class="nav-bar__wrapper page-width">

      {% for block in section.blocks %}
        {% if block.type == 'nav_link' %}
          {%- assign nav_url = '#' -%}
          {%- if block.settings.collection != blank -%}
            {%- assign nav_url = block.settings.collection.url -%}
          {%- elsif block.settings.custom_url != blank -%}
            {%- assign nav_url = block.settings.custom_url -%}
          {%- else -%}
            {%- assign handle = block.settings.label | handle -%}
            {%- assign nav_url = '/collections/' | append: handle -%}
          {%- endif -%}

          {%- assign is_active = false -%}
          {%- if request.path == nav_url -%}
            {%- assign is_active = true -%}
          {%- elsif request.path contains nav_url and nav_url != '/' and nav_url != '#' -%}
            {%- assign is_active = true -%}
          {%- endif -%}

          {%- assign has_dropdown = block.settings.has_dropdown -%}
          {%- assign nav_label = block.settings.label -%}

          {%- comment -%} Check if there are schema-driven dropdown items for this nav {%- endcomment -%}
          {%- assign schema_items_count = 0 -%}
          {%- for item_block in section.blocks -%}
            {%- if item_block.type == 'dropdown_item' -%}
              {%- assign parent_label = item_block.settings.parent_label | strip -%}
              {%- if parent_label == nav_label -%}
                {%- assign schema_items_count = schema_items_count | plus: 1 -%}
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}

          {%- assign show_dropdown = false -%}
          {%- if has_dropdown or schema_items_count > 0 -%}
            {%- assign show_dropdown = true -%}
          {%- endif -%}

          {% if show_dropdown %}
            <div class="nav-item nav-item--has-dropdown" {{ block.shopify_attributes }}>
              <a href="{{ nav_url }}" class="nav-bar__link{% if is_active or block.settings.is_active %} nav-bar__link--active{% endif %}">
                {{ nav_label }}
                <svg class="nav-bar__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
              </a>

              <div class="mega-menu" role="region" aria-label="{{ nav_label }} submenu">
                <div class="page-width">

                  {% if schema_items_count > 0 %}
                    {%- comment -%} Schema-driven items (configured via theme editor) {%- endcomment -%}
                    {%- assign col_list = '' -%}
                    {%- for item_block in section.blocks -%}
                      {%- if item_block.type == 'dropdown_item' -%}
                        {%- assign parent_label = item_block.settings.parent_label | strip -%}
                        {%- if parent_label == nav_label -%}
                          {%- assign col_name = item_block.settings.column_heading | default: 'Items' -%}
                          {%- unless col_list contains col_name -%}
                            {%- assign col_list = col_list | append: col_name | append: '|||' -%}
                          {%- endunless -%}
                        {%- endif -%}
                      {%- endif -%}
                    {%- endfor -%}

                    {%- assign col_array = col_list | split: '|||' -%}
                    <div class="mega-menu__columns">
                      {%- for col in col_array -%}
                        {%- if col != '' -%}
                          <div class="mega-menu__column">
                            {%- if col != 'Items' and col_array.size > 1 -%}
                              <h4 class="mega-menu__col-heading">{{ col }}</h4>
                            {%- endif -%}
                            <div class="mega-menu__grid" data-count="{{ schema_items_count }}">
                              {%- for item_block in section.blocks -%}
                                {%- if item_block.type == 'dropdown_item' -%}
                                  {%- assign parent_label = item_block.settings.parent_label | strip -%}
                                  {%- if parent_label == nav_label and item_block.settings.column_heading == col -%}
                                    <a href="{{ item_block.settings.url | default: '#' }}" class="mega-menu__item">
                                      {%- if item_block.settings.asset_name != blank -%}
                                        <img src="{{ item_block.settings.asset_name | asset_url }}" alt="{{ item_block.settings.label }}" loading="lazy">
                                      {%- elsif item_block.settings.image != blank -%}
                                        {{ item_block.settings.image | image_url: width: 200 | image_tag: loading: 'lazy' }}
                                      {%- endif -%}
                                      <span>{{ item_block.settings.label }}</span>
                                    </a>
                                  {%- endif -%}
                                {%- endif -%}
                              {%- endfor -%}
                            </div>
                          </div>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>

                  {% endif %}

                </div>
              </div>
            </div>

          {% else %}
            <a
              href="{{ nav_url }}"
              class="nav-bar__link{% if is_active or block.settings.is_active %} nav-bar__link--active{% endif %}"
              {{ block.shopify_attributes }}
            >
              {{ nav_label }}
            </a>
          {% endif %}

        {% endif %}
      {% endfor %}

      <!-- Mobile Utility Links -->
      <div class="mobile-utils">
        <a href="/pages/policies" class="nav-bar__link">
          <img src="{{ 'balance.svg' | asset_url }}">
          <span>Product Comparison</span>
        </a>
        <a href="/account" class="nav-bar__link">
          {% render 'icon', name: 'user' %}
          <span>Account</span>
        </a>
        <a href="/collections" class="nav-bar__link">
          {% render 'icon', name: 'gem' %}
          <span>Collections</span>
        </a>
        <a href="/pages/wishlist" class="nav-bar__link">
          {% render 'icon', name: 'heart' %}
          <span>Wishlist</span>
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Mobile menu toggle
    const toggle = document.getElementById('mobile-menu-toggle');
    const navBar = document.getElementById('nav-bar');
    if (toggle && navBar) {
      toggle.addEventListener('click', () => {
        navBar.classList.toggle('is-open');
        toggle.setAttribute('aria-expanded', navBar.classList.contains('is-open'));
      });
    }

    // Mobile: tap on dropdown nav items toggles sub-menu
    document.querySelectorAll('.nav-item--has-dropdown .nav-bar__link').forEach(link => {
      link.addEventListener('click', function(e) {
        if (window.innerWidth <= 992) {
          e.preventDefault();
          const navItem = this.closest('.nav-item--has-dropdown');
          navItem.classList.toggle('is-open');
        }
      });
    });

    // Close mega menu on outside click
    document.addEventListener('click', (e) => {
      if (!e.target.closest('.nav-item--has-dropdown')) {
        document.querySelectorAll('.nav-item--has-dropdown.is-open').forEach(el => el.classList.remove('is-open'));
      }
    });
  });
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 300,
      "step": 10,
      "default": 150,
      "label": "Logo width (px)"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder text",
      "default": "Search for..."
    }
  ],
  "blocks": [
    {
      "type": "nav_link",
      "name": "Navigation Link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Navigation Label",
          "default": "Link"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        },
        {
          "type": "url",
          "id": "custom_url",
          "label": "Or Custom URL"
        },
        {
          "type": "checkbox",
          "id": "has_dropdown",
          "label": "Show dropdown mega menu",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "is_active",
          "label": "Mark as active",
          "default": false
        }
      ]
    },
    {
      "type": "dropdown_item",
      "name": "Dropdown Item",
      "settings": [
        {
          "type": "text",
          "id": "parent_label",
          "label": "Parent Nav Label (must match exactly)",
          "info": "e.g. NAVRATNA"
        },
        {
          "type": "text",
          "id": "column_heading",
          "label": "Column Heading (optional grouping)",
          "default": "Items"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Item Label",
          "default": "Gemstone"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Item URL"
        },
        {
          "type": "text",
          "id": "asset_name",
          "label": "Icon image asset name (e.g. nav-ruby.png)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Header",
      "blocks": [
        { "type": "nav_link", "settings": { "label": "NAVRATNA", "has_dropdown": true, "is_active": true } },
        { "type": "nav_link", "settings": { "label": "UPRATNAS", "has_dropdown": true } },
        { "type": "nav_link", "settings": { "label": "SACRED ESSENTIALS", "custom_url": "/collections/sacred-essentials" } },
        { "type": "nav_link", "settings": { "label": "SANCTUM", "custom_url": "/collections/sanctum" } },
        { "type": "nav_link", "settings": { "label": "CURATED COLLECTIONS", "custom_url": "/collections/all" } }
      ]
    }
  ]
}
{% endschema %}
