{%- comment -%}
  Header Section
  Includes: Logo, Search, Navigation, Utility Icons
  Because apparently Shopify thought URLs in presets should behave like a lottery ticket.
{%- endcomment -%}

<header class="site-header" id="site-header">
  <div class="header__wrapper page-width">
    <!-- Mobile Menu Toggle -->
    <button class="header__menu-toggle" id="mobile-menu-toggle" aria-label="Menu">
      {% render 'icon', name: 'menu' %}
    </button>

    <!-- Logo -->
    <div class="header__logo">
      <a href="/" class="header__logo-link" aria-label="{{ shop.name }}">
        {% if section.settings.logo != blank %}
          <img
            src="{{ section.settings.logo | image_url: width: section.settings.logo_width }}"
            alt="{{ shop.name }}"
            width="{{ section.settings.logo_width }}"
            height="auto"
            loading="eager"
            class="header__logo-image"
          >
        {% else %}
          <img
            src="{{ 'brand-logo.svg' | asset_url }}"
            alt="{{ shop.name }}"
            width="{{ section.settings.logo_width }}"
            height="auto"
            loading="eager"
            class="header__logo-image"
          >
        {% endif %}
      </a>
    </div>

    <!-- Search -->
    <div class="header__search">
      <form class="header__search-form" action="/search" method="get" role="search">
        <span class="header__search-icon">
          {% render 'icon', name: 'search' %}
        </span>

        <input
          type="search"
          name="q"
          id="header-search"
          class="header__search-input"
          placeholder="{{ section.settings.search_placeholder | default: 'Search for...' }}"
          autocomplete="off"
        >
      </form>
    </div>

    <!-- Header Icons -->
    <div class="header__icons">
      <a href="/pages/policies" class="header__icon-btn hide-mobile" aria-label="Policies">
        <img src="{{ 'balance.svg' | asset_url }}">
      </a>

      <a href="/account" class="header__icon-btn hide-mobile" aria-label="Account">
        {% render 'icon', name: 'user' %}
      </a>

      <a href="/collections" class="header__icon-btn hide-mobile" aria-label="Collections">
        {% render 'icon', name: 'gem' %}
      </a>

      <a href="/pages/wishlist" class="header__icon-btn hide-mobile" aria-label="Wishlist">
        {% render 'icon', name: 'heart' %}
        <span
          class="header__wishlist-count"
          id="header-wishlist-count"
          style="display:none;"
        >
          0
        </span>
      </a>

      <a href="/cart" class="header__icon-btn" aria-label="Cart">
        {% render 'icon', name: 'cart' %}

        {% if cart.item_count > 0 %}
          <span class="header__cart-count">
            {{ cart.item_count }}
          </span>
        {% endif %}
      </a>
    </div>
  </div>

  <!-- Navigation Bar -->
  <nav class="nav-bar" id="nav-bar" aria-label="Main navigation">
    <div class="nav-bar__wrapper page-width">
      {% for block in section.blocks %}
        {% if block.type == 'nav_link' %}
          {% assign nav_url = '#' %}

            {% if block.settings.collection != blank %}
              {% assign nav_url = block.settings.collection.url %}
            {% elsif block.settings.custom_url != blank %}
              {% assign nav_url = block.settings.custom_url %}
            {% else %}
              {% assign handle = block.settings.label | handle %}
              {% assign nav_url = '/collections/' | append: handle %}
            {% endif %}

          {%- assign is_active = false -%}
          {%- if request.path == nav_url -%}
            {%- assign is_active = true -%}
          {%- elsif request.path contains nav_url and nav_url != '/' and nav_url != '#' -%}
            {%- assign is_active = true -%}
          {%- endif -%}

          <a
            href="{{ nav_url }}"
            class="nav-bar__link{% if is_active or block.settings.is_active %} nav-bar__link--active{% endif %}"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.label }}
          </a>
        {% endif %}
      {% endfor %}

      <!-- Mobile Utility Links -->
      <div class="mobile-utils">
        <a href="/pages/policies" class="nav-bar__link">
          <img src="{{ 'balance.svg' | asset_url }}">
          <span>Product Comparison</span>
        </a>

        <a href="/account" class="nav-bar__link">
          {% render 'icon', name: 'user' %}
          <span>Account</span>
        </a>

        <a href="/collections" class="nav-bar__link">
          {% render 'icon', name: 'gem' %}
          <span>Collections</span>
        </a>

        <a href="/pages/wishlist" class="nav-bar__link">
          {% render 'icon', name: 'heart' %}
          <span>Wishlist</span>
        </a>
      </div>
    </div>
  </nav>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 300,
      "step": 10,
      "default": 150,
      "label": "Logo width (px)"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder text",
      "default": "Search for..."
    }
  ],
  "blocks": [
    {
      "type": "nav_link",
      "name": "Navigation Link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Navigation Label",
          "default": "Link"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        },
        {
          "type": "url",
          "id": "custom_url",
          "label": "Or Custom URL"
        },
        {
          "type": "checkbox",
          "id": "is_active",
          "label": "Mark as active",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Header",
      "blocks": [
        {
          "type": "nav_link",
          "settings": {
            "label": "NAVRATNA",
            "is_active": true
          }
        },
        {
          "type": "nav_link",
          "settings": {
            "label": "UPRATNA"
          }
        },
        {
          "type": "nav_link",
          "settings": {
            "label": "SACRED ESSENTIALS"
          }
        },
        {
          "type": "nav_link",
          "settings": {
            "label": "SANCTUM"
          }
        },
        {
          "type": "nav_link",
          "settings": {
            "label": "CURATED COLLECTIONS"
          }
        }
      ]
    }
  ]
}
{% endschema %}