{%- comment -%}
  Hero Banner Section
  Full-width hero with image/video background, overlay text, and CTA
{%- endcomment -%}

<section class="hero-banner" id="hero-banner">
  <div class="hero-banner__media">
    {%- if section.settings.asset_name != blank -%}
      <img
        src="{{ section.settings.asset_name | asset_url }}"
        alt="{{ section.settings.heading | escape }}"
        width="2000"
        height="800"
        loading="eager"
        fetchpriority="high"
      >
    {%- elsif section.settings.hero_image -%}
      <img
        src="{{ section.settings.hero_image | image_url: width: 2000 }}"
        alt="{{ section.settings.hero_image.alt | default: section.settings.heading | escape }}"
        width="2000"
        height="800"
        loading="eager"
        fetchpriority="high"
      >
    {%- else -%}
      {%- comment -%} Placeholder gradient when no image is set {%- endcomment -%}
      <div style="width:100%;height:100%;background:linear-gradient(135deg, #2c1810 0%, #4a3728 30%, #6b5a4e 60%, #8b7355 80%, #c9a96e 100%);"></div>
    {%- endif -%}
  </div>
  <div class="hero-banner__overlay"></div>
  <div class="hero-banner__content">
    {%- if section.settings.subtitle != blank -%}
      <p class="hero-banner__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
    <h1 class="hero-banner__title">{{ section.settings.heading }}</h1>
    {%- if section.settings.button_text != blank -%}
      <div class="hero-banner__btn">
        <a href="{{ section.settings.button_url | default: '/collections/all' }}" class="btn btn--white btn--md">
          {{ section.settings.button_text }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "asset_name",
      "label": "Asset Name (e.g. banner-navratna.jpg)"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "PRECIOUS CARATS"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "In a market full of claims, our gemstones stand certified by leading gemological labs."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
