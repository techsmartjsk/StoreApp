{%- comment -%}
  Cart Page Section
{%- endcomment -%}

<section class="cart-page section-padding" id="cart-page">
  <div class="page-width">
    <h1 class="section-heading">Your Cart</h1>

    {%- if cart.item_count > 0 -%}
      <div class="cart-page__wrapper">
        <div class="cart-page__items">
          {%- for item in cart.items -%}
            <div class="cart-item" id="cart-item-{{ item.key }}">
              <div class="cart-item__image">
                {%- if item.image -%}
                  <a href="{{ item.url }}">
                    <img
                      src="{{ item.image | image_url: width: 200 }}"
                      alt="{{ item.title | escape }}"
                      width="100"
                      height="100"
                      loading="lazy"
                    >
                  </a>
                {%- endif -%}
              </div>
              <div class="cart-item__info">
                <h3 class="cart-item__title">
                  <a href="{{ item.url }}">{{ item.product.title }}</a>
                </h3>
                {%- if item.variant.title != 'Default Title' -%}
                  <p class="cart-item__variant">{{ item.variant.title }}</p>
                {%- endif -%}
                <p class="cart-item__price">{{ item.price | money }}</p>
              </div>
              <div class="cart-item__quantity">
                <form action="/cart/change" method="post">
                  <input type="hidden" name="id" value="{{ item.key }}">
                  <div class="cart-item__qty-controls">
                    <button type="submit" name="quantity" value="{{ item.quantity | minus: 1 }}" class="product-page__qty-btn" aria-label="Decrease quantity">−</button>
                    <span class="cart-item__qty-display">{{ item.quantity }}</span>
                    <button type="submit" name="quantity" value="{{ item.quantity | plus: 1 }}" class="product-page__qty-btn" aria-label="Increase quantity">+</button>
                  </div>
                </form>
              </div>
              <div class="cart-item__total">
                {{ item.line_price | money }}
              </div>
              <a href="/cart/change?id={{ item.key }}&quantity=0" class="cart-item__remove" aria-label="Remove {{ item.title }}">
                {% render 'icon', name: 'close' %}
              </a>
            </div>
          {%- endfor -%}
        </div>

        <div class="cart-page__summary">
          <div class="cart-summary">
            <h3 class="cart-summary__title">Order Summary</h3>
            <div class="cart-summary__row">
              <span>Subtotal</span>
              <span>{{ cart.total_price | money }}</span>
            </div>
            <div class="cart-summary__row">
              <span>Shipping</span>
              <span>Calculated at checkout</span>
            </div>
            <div class="cart-summary__row cart-summary__row--total">
              <span>Total</span>
              <span>{{ cart.total_price | money }}</span>
            </div>
            <form action="/cart" method="post">
              <button type="submit" name="checkout" class="btn btn--primary btn--lg" style="width:100%;">
                CHECKOUT
              </button>
            </form>
            <a href="/collections/all" class="cart-summary__continue">
              ← Continue Shopping
            </a>
          </div>
        </div>
      </div>
    {%- else -%}
      <div class="cart-page__empty">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1" style="margin-bottom: var(--space-lg);">
          <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
        </svg>
        <h2>Your cart is empty</h2>
        <p class="cart-page__empty-text">Looks like you haven't added any gems yet.</p>
        <a href="/collections/all" class="btn btn--primary">
          START SHOPPING
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .cart-page__wrapper {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: var(--space-3xl);
    align-items: flex-start;
  }

  .cart-item {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-lg) 0;
    border-bottom: 1px solid var(--color-border-light);
    position: relative;
  }

  .cart-item__image {
    width: 100px;
    height: 100px;
    border-radius: var(--radius-md);
    overflow: hidden;
    flex-shrink: 0;
    background: var(--color-cream);
  }

  .cart-item__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cart-item__info { flex: 1; }

  .cart-item__title {
    font-family: var(--font-body);
    font-size: var(--font-size-base);
    font-weight: 500;
    margin-bottom: var(--space-xs);
  }

  .cart-item__title a { color: var(--color-text); }
  .cart-item__title a:hover { color: var(--color-gold); }

  .cart-item__variant {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .cart-item__price {
    font-weight: 600;
    margin-top: var(--space-xs);
  }

  .cart-item__qty-controls {
    display: flex;
    align-items: center;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .cart-item__qty-display {
    width: 40px;
    text-align: center;
    font-weight: 600;
    font-size: var(--font-size-sm);
    border-left: 1px solid var(--color-border);
    border-right: 1px solid var(--color-border);
    padding: 8px 0;
  }

  .cart-item__total {
    font-family: var(--font-accent);
    font-weight: 700;
    font-size: var(--font-size-md);
    min-width: 100px;
    text-align: right;
  }

  .cart-item__remove {
    position: absolute;
    top: var(--space-md);
    right: 0;
    color: var(--color-text-muted);
    transition: color var(--transition-base);
  }

  .cart-item__remove:hover { color: #e74c3c; }

  .cart-item__remove svg {
    width: 18px;
    height: 18px;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.5;
  }

  .cart-summary {
    background: var(--color-cream);
    border-radius: var(--radius-lg);
    padding: var(--space-2xl);
    position: sticky;
    top: calc(var(--header-height) + var(--nav-height) + var(--space-xl));
  }

  .cart-summary__title {
    font-family: var(--font-heading);
    font-size: var(--font-size-xl);
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-border);
  }

  .cart-summary__row {
    display: flex;
    justify-content: space-between;
    margin-bottom: var(--space-md);
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
  }

  .cart-summary__row--total {
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-md);
    margin-bottom: var(--space-xl);
    font-size: var(--font-size-md);
    font-weight: 700;
    color: var(--color-primary);
  }

  .cart-summary__continue {
    display: block;
    text-align: center;
    margin-top: var(--space-lg);
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
  }

  .cart-summary__continue:hover { color: var(--color-gold); }

  .cart-page__empty {
    text-align: center;
    padding: var(--space-5xl) 0;
  }

  .cart-page__empty h2 {
    margin-bottom: var(--space-sm);
  }

  .cart-page__empty-text {
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
  }

  @media (max-width: 992px) {
    .cart-page__wrapper { grid-template-columns: 1fr; }
  }

  @media (max-width: 768px) {
    .cart-item {
      flex-wrap: wrap;
      gap: var(--space-md);
    }
    .cart-item__total {
      min-width: auto;
      text-align: left;
    }
  }
</style>

{% schema %}
{
  "name": "Cart Page",
  "settings": []
}
{% endschema %}
