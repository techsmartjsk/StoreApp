{%- comment -%}
  Collection Page Section - Myntra-style compact layout
{%- endcomment -%}

<section class="collection-page" id="collection-{{ collection.handle }}">
  <div class="page-width">
    <!-- Breadcrumb -->
    <nav class="collection-breadcrumb" aria-label="Breadcrumb">
      <ol class="collection-breadcrumb__list">
        <li class="collection-breadcrumb__item">
          <a href="/" class="collection-breadcrumb__link">Home</a>
        </li>
        {%- if collection.metafields.custom.parent_collection -%}
          <li class="collection-breadcrumb__item">
            <span class="collection-breadcrumb__sep">/</span>
            <a href="{{ collection.metafields.custom.parent_collection }}" class="collection-breadcrumb__link">{{ collection.metafields.custom.parent_collection_title | default: 'Shop' }}</a>
          </li>
        {%- endif -%}
        <li class="collection-breadcrumb__item">
          <span class="collection-breadcrumb__sep">/</span>
          <span class="collection-breadcrumb__current">{{ collection.title }}</span>
        </li>
      </ol>
    </nav>

    <!-- Collection Title + Count -->
    <div class="collection-page__header">
      <h1 class="collection-page__title">{{ collection.title }}</h1>
      <span class="collection-page__item-count">- {{ collection.products_count }} items</span>
    </div>

    <!-- Top Toolbar: Filter pills + Sort -->
    <div class="collection-page__top-toolbar">
      <div class="collection-page__toolbar-left">
        <div class="collection-page__filter-pills">
          <span class="collection-page__filters-label">FILTERS</span>
        </div>
      </div>

      <div class="collection-page__toolbar-right">
        {%- assign price_filter = collection.filters | where: 'type', 'price_range' | first -%}
        {%- if price_filter -%}
          <div class="collection-page__price-presets">
            {%- assign min_val = price_filter.min_value.value | money_without_currency | replace: ',', '' | plus: 0 -%}
            {%- assign max_val = price_filter.max_value.value | money_without_currency | replace: ',', '' | plus: 0 -%}
            
            <button type="button" 
              class="toolbar-price-preset{% if min_val == 0 and max_val == 30000 %} is-active{% endif %}"
              data-min="0" data-max="30000"
            >
              Below ₹30K
            </button>
            <button type="button" 
              class="toolbar-price-preset{% if min_val == 30000 and max_val == 50000 %} is-active{% endif %}"
              data-min="30000" data-max="50000"
            >
              ₹30K-₹50K
            </button>
            <button type="button" 
              class="toolbar-price-preset{% if min_val == 50000 and max_val == 0 %} is-active{% endif %}"
              data-min="50000" data-max=""
            >
              Above ₹50K
            </button>
          </div>
        {%- endif -%}

        <div class="collection-page__sort">
          <label for="sort-select" class="collection-page__sort-label">Sort by :</label>
          <select id="sort-select" class="collection-page__sort-select" onchange="const searchParams = new URLSearchParams(window.location.search); searchParams.set('sort_by', this.value); window.location.search = searchParams.toString();">
            {%- for option in collection.sort_options -%}
              <option value="{{ option.value }}" {% if option.value == collection.sort_by %}selected{% endif %}>
                {{ option.name }}
              </option>
            {%- endfor -%}
          </select>
        </div>
      </div>
    </div>

    <div class="collection-page__layout">
      <!-- Collection Sidebar (Filters) -->
      <aside class="collection-page__sidebar" id="main-collection-filters" data-id="{{ section.id }}">
        {% render 'facets', results: collection, enable_filtering: true %}
      </aside>

      <!-- Collection Content -->
      <div class="collection-page__content">
        <!-- Product Grid -->
        <div class="collection-page__grid" id="ProductGridContainer">
          {%- paginate collection.products by section.settings.products_per_page -%}
            {%- if collection.products.size == 0 -%}
              <div class="collection-page__empty">
                <h2 class="title" style="margin-bottom: 2rem;">No products found in this collection.</h2>
                <a href="{{ routes.all_products_collection_url }}" class="btn btn--secondary">
                  Clear All Filters
                </a>
              </div>
            {%- else -%}
              {%- for product in collection.products -%}
                {% render 'product-card', product: product %}
              {%- endfor -%}
            {%- endif -%}

            <!-- Pagination -->
            {%- if paginate.pages > 1 -%}
              <div class="collection-page__pagination">
                {{ paginate | default_pagination }}
              </div>
            {%- endif -%}
          {%- endpaginate -%}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Breadcrumb */
  .collection-breadcrumb {
    padding: 4px 0 12px;
    border-bottom: 1px solid #f0f0f0;
  }
  .collection-breadcrumb__list {
    display: flex;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 13px;
    font-family: var(--font-body);
  }
  .collection-breadcrumb__link {
    color: #696b79;
    text-decoration: none;
  }
  .collection-breadcrumb__link:hover {
    color: var(--color-primary);
    text-decoration: underline;
  }
  .collection-breadcrumb__sep {
    margin: 0 8px;
    color: #d4d5d9;
  }
  .collection-breadcrumb__current {
    color: #282c3f;
    font-weight: 600;
  }

  /* Header */
  .collection-page {
    padding: 0;
  }
  .collection-page__header {
    display: flex;
    align-items: baseline;
    gap: 8px;
    padding: 16px 0 4px;
  }
  .collection-page__title {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 700;
    color: #282c3f;
    margin: 0;
    text-transform: none;
    letter-spacing: 0;
  }
  .collection-page__item-count {
    font-size: 14px;
    color: #94969f;
    font-family: var(--font-body);
    font-weight: 400;
  }

  /* Top Toolbar */
  .collection-page__top-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 0;
    border-bottom: 1px solid #e9e9ed;
    margin-bottom: 0;
  }
  .collection-page__toolbar-left {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .collection-page__toolbar-right {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .collection-page__filters-label {
    font-size: 13px;
    font-weight: 700;
    color: #282c3f;
    letter-spacing: 0.05em;
    font-family: var(--font-body);
  }
  .collection-page__sort {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .collection-page__sort-label {
    font-size: 13px;
    color: #282c3f;
    font-family: var(--font-body);
    font-weight: 400;
  }
  .collection-page__sort-select {
    padding: 4px 8px;
    border: none;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    color: #282c3f;
    background: transparent;
    cursor: pointer;
    outline: none;
    -webkit-appearance: none;
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L5 5L9 1' stroke='%23282c3f' stroke-width='1.5'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 4px center;
    padding-right: 20px;
  }

  /* Price Presets in Toolbar */
  .collection-page__price-presets {
    display: flex;
    gap: 8px;
    align-items: center;
  }
  .toolbar-price-preset {
    font-size: 11px;
    font-weight: 600;
    color: #696b79;
    padding: 6px 12px;
    border: 1px solid #e9e9ed;
    border-radius: 20px;
    background: #fff;
    cursor: pointer;
    transition: all 0.2s;
    font-family: var(--font-body);
  }
  .toolbar-price-preset:hover {
    border-color: #282c3f;
    color: #282c3f;
  }
  .toolbar-price-preset.is-active {
    background: #f5f5f6;
    border-color: #282c3f;
    color: #282c3f;
    font-weight: 700;
  }

  /* Layout */
  .collection-page__layout {
    display: flex;
    flex-wrap: nowrap;
    gap: 0;
  }
  .collection-page__sidebar {
    width: 240px;
    flex-shrink: 0;
    padding-top: 16px;
    padding-right: 16px;
    border-right: 1px solid #e9e9ed;
  }
  .collection-page__content {
    flex-grow: 1;
    min-width: 0;
  }

  /* Product Grid - 4 columns like Myntra */
  .collection-page__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
    padding: 16px 0 16px 16px;
  }

  .collection-page__empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: var(--space-4xl);
    color: var(--color-text-muted);
  }

  .collection-page__pagination {
    grid-column: 1 / -1;
    margin-top: 40px;
    text-align: center;
    border-top: 1px solid #e9e9ed;
    padding-top: 30px;
  }
  .collection-page__pagination .pagination {
    display: inline-flex;
    gap: 8px;
    align-items: center;
  }
  /* Target the actual interactive/indicator elements */
  .collection-page__pagination a,
  .collection-page__pagination .current,
  .collection-page__pagination .deco {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    height: 40px;
    padding: 0 14px;
    border: 1px solid #e9e9ed;
    border-radius: 4px;
    font-size: 14px;
    transition: all 0.2s ease;
    color: #282c3f;
    text-decoration: none;
    background: #fff;
  }
  
  /* Reset the wrapping spans that Shopify's default_pagination adds */
  .collection-page__pagination .page,
  .collection-page__pagination .next,
  .collection-page__pagination .prev {
    display: inline-flex;
    border: none;
    padding: 0;
    margin: 0;
  }

  .collection-page__pagination a:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
    background: #fff;
  }
  .collection-page__pagination .current {
    background: var(--color-gold);
    border-color: var(--color-gold);
    color: #fff;
    font-weight: 700;
  }
  .collection-page__pagination .deco {
    border: none;
    min-width: 20px;
    background: transparent;
  }

  @media (max-width: 1200px) {
    .collection-page__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 992px) {
    .collection-page__layout {
      flex-direction: column;
      gap: 0;
    }
    .collection-page__sidebar {
      width: 100%;
      border-right: none;
      border-bottom: 1px solid #e9e9ed;
      padding-right: 0;
      padding-bottom: 12px;
    }
    .collection-page__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      padding-left: 0;
      gap: 10px;
    }
    .collection-page__top-toolbar {
      flex-wrap: wrap;
      gap: 8px;
    }
    .collection-page__price-presets {
      flex-wrap: wrap;
    }
  }

  @media (max-width: 640px) {
    .collection-page__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
    }
    .collection-page__header {
      flex-wrap: wrap;
    }
    .collection-page__top-toolbar {
      flex-direction: column;
      align-items: flex-start;
    }
    .collection-page__toolbar-right {
      width: 100%;
      flex-wrap: wrap;
    }
    .collection-page__sort {
      width: 100%;
    }
  }

  @media (max-width: 380px) {
    .collection-page__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 6px;
    }
  }
</style>

<script>
  // Toolbar Price Preset Logic
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.toolbar-price-preset').forEach(btn => {
      btn.addEventListener('click', () => {
        const min = btn.dataset.min;
        const max = btn.dataset.max;
        const searchParams = new URLSearchParams(window.location.search);
        
        // Use the param names from Shopify Filters (usually filter.v.price.gte / lte)
        searchParams.set('filter.v.price.gte', min);
        if (max) {
          searchParams.set('filter.v.price.lte', max);
        } else {
          searchParams.delete('filter.v.price.lte');
        }
        
        window.location.search = searchParams.toString();
      });
    });
  });
</script>

{% schema %}
{
  "name": "Collection Page Grid",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 20,
      "label": "Products per page"
    }
  ]
}
{% endschema %}
