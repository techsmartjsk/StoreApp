{%- comment -%}Product Compare Page — Card Layout{%- endcomment -%}

<!-- Breadcrumb -->
<div class="compare-breadcrumb">
  <div class="page-width">
    <nav class="breadcrumb" aria-label="breadcrumb">
      <a href="/">Home</a>
      <span class="breadcrumb__sep">|</span>
      <span>Compare Gemstones</span>
    </nav>
    <button class="compare-share-btn" id="compare-share-btn" style="display:none;" onclick="CompareApp.shareCompare()">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
      Share With Friend
    </button>
  </div>
</div>

<section class="compare-page" id="compare-page">
  <div class="page-width">

    <!-- Empty state -->
    <div class="compare-page__empty" id="compare-empty">
      <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1" style="margin-bottom:20px;">
        <path d="M12 2L2 7l10 5 10-5-10-5z"/>
        <path d="M2 17l10 5 10-5"/>
        <path d="M2 12l10 5 10-5"/>
      </svg>
      <h2>No gemstones to compare</h2>
      <p class="compare-page__empty-text">Add gemstones to compare by clicking the <img src="{{ 'balance.svg' | asset_url }}" width="16" height="16" style="vertical-align:middle;opacity:0.5;"> icon on any product.</p>
      <a href="/collections/all" class="compare-page__shop-btn">BROWSE GEMSTONES</a>
    </div>

    <!-- Compare cards (populated by JS) -->
    <div class="compare-page__cards" id="compare-cards" style="display:none;"></div>

    <!-- Clear all -->
    <div class="compare-page__actions" id="compare-actions" style="display:none;">
      <button class="compare-page__clear-btn" onclick="CompareApp.clearAll()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2"/></svg>
        CLEAR ALL
      </button>
    </div>

  </div>
</section>

<!-- Compare List Popup / Drawer -->
<div class="compare-popup-overlay" id="compare-popup-overlay" style="display:none;" onclick="CompareApp.closePopup()"></div>
<div class="compare-popup" id="compare-popup" style="display:none;">
  <div class="compare-popup__header">
    <h3 class="compare-popup__title">Your Compare List</h3>
    <button class="compare-popup__close" onclick="CompareApp.closePopup()" aria-label="Close">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
  <div class="compare-popup__grid" id="compare-popup-grid"></div>
</div>

<style>
  /* ========== Breadcrumb ========== */
  .compare-breadcrumb {
    background: var(--color-bg, #faf8f4);
    padding: 12px 0;
    border-bottom: 1px solid var(--color-border-light, #eee);
  }
  .compare-breadcrumb .page-width {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .compare-breadcrumb .breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-family: var(--font-body, 'Inter', sans-serif);
    color: #888;
  }
  .compare-breadcrumb .breadcrumb a { color: #555; text-decoration: none; }
  .compare-breadcrumb .breadcrumb a:hover { color: var(--color-primary, #1a2a3a); text-decoration: underline; }
  .compare-breadcrumb .breadcrumb__sep { color: #bbb; }

  .compare-share-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 13px;
    color: #555;
    cursor: pointer;
    transition: color 0.2s;
  }
  .compare-share-btn:hover { color: var(--color-primary, #1a2a3a); }

  /* ========== Page ========== */
  .compare-page {
    padding: var(--space-2xl, 40px) 0 var(--space-5xl, 100px);
    min-height: 50vh;
  }

  /* ========== Empty state ========== */
  .compare-page__empty {
    text-align: center;
    padding: var(--space-5xl, 100px) 0;
  }
  .compare-page__empty h2 {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: 24px;
    font-weight: 400;
    margin: 0 0 8px;
    color: var(--color-primary, #1a2a3a);
  }
  .compare-page__empty-text {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 14px;
    color: #aaa;
    margin: 0 0 var(--space-xl, 24px);
  }
  .compare-page__shop-btn {
    display: inline-block;
    padding: 14px 32px;
    background: var(--color-primary, #1a2a3a);
    color: #fff;
    border-radius: 6px;
    font-size: 12px;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-decoration: none;
    transition: background 0.2s;
  }
  .compare-page__shop-btn:hover { background: #2c4a3e; }

  /* ========== Compare Cards ========== */
  .compare-page__cards {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .compare-card {
    background: #fff;
    border: 1px solid var(--color-border-light, #eee);
    border-radius: 8px;
    overflow: hidden;
  }

  .compare-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 24px;
    background: #faf8f4;
    border-bottom: 1px solid var(--color-border-light, #eee);
  }

  .compare-card__label {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 14px;
    color: #999;
    font-weight: 400;
  }

  .compare-card__change-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 18px;
    border: 1px solid var(--color-border, #ddd);
    border-radius: 6px;
    background: #fff;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-primary, #1a2a3a);
    letter-spacing: 0.03em;
    cursor: pointer;
    transition: all 0.2s;
  }
  .compare-card__change-btn:hover {
    background: var(--color-primary, #1a2a3a);
    color: #fff;
    border-color: var(--color-primary, #1a2a3a);
  }
  .compare-card__change-btn svg {
    width: 14px;
    height: 14px;
  }

  .compare-card__body {
    display: flex;
    gap: 0;
    padding: 24px;
    align-items: flex-start;
  }

  .compare-card__image-wrap {
    flex-shrink: 0;
    width: 160px;
    height: 160px;
    border-radius: 8px;
    overflow: hidden;
    background: #faf8f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    margin-right: 24px;
  }

  .compare-card__image {
    max-width: 130px;
    max-height: 130px;
    object-fit: contain;
  }

  .compare-card__details {
    flex: 1;
    display: flex;
    gap: 40px;
    flex-wrap: wrap;
  }

  .compare-card__details-col {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .compare-card__product-name {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: 18px;
    font-weight: 600;
    color: var(--color-primary, #1a2a3a);
    margin: 0 0 4px;
    text-decoration: none;
    display: block;
  }
  .compare-card__product-name:hover { color: var(--color-gold, #c9a96e); }

  .compare-card__attr {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 13px;
    color: #666;
    line-height: 1.6;
  }
  .compare-card__attr strong {
    color: #444;
    font-weight: 600;
  }

  /* ========== Actions bar ========== */
  .compare-page__actions {
    margin-top: var(--space-xl, 24px);
    padding-top: 16px;
    border-top: 1px solid var(--color-border-light, #eee);
    display: flex;
    justify-content: flex-end;
  }

  .compare-page__clear-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 20px;
    border: 1px solid #ddd;
    border-radius: 6px;
    font-size: 11px;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-weight: 600;
    letter-spacing: 0.04em;
    color: #888;
    background: #fff;
    cursor: pointer;
    transition: all 0.2s;
  }
  .compare-page__clear-btn:hover { color: #e74c3c; border-color: #e74c3c; }

  /* ========== Compare Popup / Drawer ========== */
  .compare-popup-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    z-index: 9998;
  }

  .compare-popup {
    position: fixed;
    top: 0;
    right: 0;
    width: 480px;
    max-width: 92vw;
    height: 100vh;
    background: #fff;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    box-shadow: -4px 0 24px rgba(0,0,0,0.12);
    transform: translateX(100%);
    transition: transform 0.3s ease;
  }

  .compare-popup.is-open {
    transform: translateX(0);
  }

  .compare-popup__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px;
    border-bottom: 1px solid #eee;
    flex-shrink: 0;
  }

  .compare-popup__title {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: 22px;
    font-weight: 500;
    margin: 0;
    color: var(--color-primary, #1a2a3a);
  }

  .compare-popup__close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: #888;
    transition: color 0.2s;
  }
  .compare-popup__close:hover { color: #333; }

  .compare-popup__grid {
    flex: 1;
    overflow-y: auto;
    padding: 20px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    align-content: start;
  }

  .compare-popup-card {
    border: 1px solid #eee;
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    background: #fff;
    transition: box-shadow 0.2s;
  }
  .compare-popup-card:hover {
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
  }

  .compare-popup-card__img-wrap {
    position: relative;
    background: #faf8f4;
    padding: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 140px;
  }

  .compare-popup-card__delete {
    position: absolute;
    top: 8px;
    right: 8px;
    background: rgba(255,255,255,0.8);
    border: none;
    cursor: pointer;
    padding: 4px;
    border-radius: 4px;
    color: #999;
    transition: color 0.2s;
  }
  .compare-popup-card__delete:hover { color: #e74c3c; }

  .compare-popup-card__img {
    max-width: 90px;
    max-height: 90px;
    object-fit: contain;
  }

  .compare-popup-card__info {
    padding: 12px 14px;
  }

  .compare-popup-card__name {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 13px;
    font-weight: 600;
    color: var(--color-primary, #1a2a3a);
    margin: 0 0 4px;
    text-decoration: none;
    display: block;
  }

  .compare-popup-card__price {
    font-size: 13px;
    color: #666;
    margin: 0 0 10px;
  }

  .compare-popup-card__add-btn {
    display: block;
    width: 100%;
    padding: 10px;
    border: 1px solid var(--color-primary, #1a2a3a);
    background: #fff;
    color: var(--color-primary, #1a2a3a);
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    border-radius: 4px;
    text-decoration: none;
  }
  .compare-popup-card__add-btn:hover {
    background: var(--color-primary, #1a2a3a);
    color: #fff;
  }
  .compare-popup-card__view-btn {
    display: block;
    width: 100%;
    padding: 10px;
    border: none;
    background: var(--color-primary, #1a2a3a);
    color: #fff;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    border-radius: 4px;
    text-decoration: none;
    margin-top: 6px;
  }
  .compare-popup-card__view-btn:hover {
    background: var(--color-gold, #c9a96e);
  }

  /* ========== Responsive ========== */
  @media (max-width: 768px) {
    .compare-card__body {
      flex-direction: column;
      gap: 16px;
    }
    .compare-card__image-wrap {
      width: 120px;
      height: 120px;
      margin-right: 0;
    }
    .compare-card__details {
      gap: 16px;
    }
    .compare-popup__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
      padding: 16px;
    }
  }

  @media (max-width: 480px) {
    .compare-card__header {
      padding: 12px 16px;
    }
    .compare-card__body {
      padding: 16px;
    }
    .compare-card__details {
      gap: 10px;
    }
    .compare-popup {
      width: 100vw;
      max-width: 100vw;
    }
  }
</style>

{% schema %}
{
  "name": "Compare Products",
  "settings": []
}
{% endschema %}
