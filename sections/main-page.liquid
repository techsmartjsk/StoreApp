{%- comment -%}
  Main Page Section
{%- endcomment -%}

<section class="page-section section-padding">
  <div class="page-width page-width--narrow">
    <h1 class="section-heading">{{ page.title }}</h1>
    <div class="page-section__content">
      {{ page.content }}
    </div>
  </div>
</section>

<style>
  .page-section__content {
    font-size: var(--font-size-base);
    line-height: 1.8;
    color: var(--color-text-light);
  }

  .page-section__content h2,
  .page-section__content h3,
  .page-section__content h4 {
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
  }

  .page-section__content p {
    margin-bottom: var(--space-lg);
  }

  .page-section__content ul,
  .page-section__content ol {
    margin-bottom: var(--space-lg);
    padding-left: var(--space-xl);
    list-style: disc;
  }

  .page-section__content img {
    border-radius: var(--radius-lg);
    margin: var(--space-xl) 0;
  }

  .page-section__content a {
    color: var(--color-gold);
    text-decoration: underline;
  }
</style>

{% schema %}
{
  "name": "Page Content",
  "settings": []
}
{% endschema %}
