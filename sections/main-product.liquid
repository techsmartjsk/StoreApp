<style>
  /* Breadcrumb */
  .product-breadcrumb {
    background: var(--color-bg, #faf8f4);
    padding: 10px 0;
    border-bottom: 1px solid var(--color-border-light, #eee);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 4px;
    font-size: 11px;
    font-family: var(--font-body, 'Inter', sans-serif);
    color: #888;
  }

  .breadcrumb a {
    color: #888;
    text-decoration: none;
  }

  .breadcrumb a:hover { color: var(--color-primary, #1a2a3a); }
  .breadcrumb__sep { color: #bbb; }

  .breadcrumb--pdp {
    margin-bottom: 20px;
  }

  /* Page wrapper */
  .product-page { padding: var(--space-2xl, 40px) 0 var(--space-4xl, 80px); }

  @media (max-width: 768px) {
    .product-page { padding: var(--space-xl, 24px) 16px var(--space-3xl, 60px); }
  }

  .product-page__wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    align-items: flex-start;
    width: 100%;
  }

  /* Gallery */
  .product-page__gallery {
    display: grid;
    grid-template-columns: 70px 36px 1fr;
    gap: 12px;
    padding-right: 32px;
    width: 100%;
  }

  /* Thumbnail strip */
  .product-page__thumbstrip {
    display: flex;
    flex-direction: column;
    gap: 8px;
    max-height: 580px;
    overflow-y: auto;
    scrollbar-width: none;
  }
  .product-page__thumbstrip::-webkit-scrollbar { display: none; }

  .product-page__thumb {
    width: 65px;
    height: 65px;
    border-radius: 6px;
    border: 2px solid transparent;
    overflow: hidden;
    cursor: pointer;
    padding: 0;
    background: var(--color-cream, #f5f0e8);
    flex-shrink: 0;
    transition: border-color 0.2s;
  }
  .product-page__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .product-page__thumb--active,
  .product-page__thumb:hover {
    border-color: var(--color-gold, #b8963e);
  }

  /* Main image */
  .product-page__main-img-wrap {
    position: relative;
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid #eee;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .product-page__main-img-wrap {
      max-height: 65vh;
      max-width: 100%;
    }
  }

  .product-page__main-img {
    width: 100%;
    max-height: 100%;
    display: block;
    object-fit: contain;
  }

  /* Amazon-style zoom preview (desktop only) */
  .product-page__media-item {
    position: relative;
  }

  .product-page__zoom-lens {
    display: none;
    position: absolute;
    width: 200px;
    height: 200px;
    border: 2px solid var(--color-gold, #c9a96e);
    background: rgba(201, 169, 110, 0.15);
    pointer-events: none;
    z-index: 10;
  }

  .product-page__wrapper {
    position: relative;
  }

  .product-page__zoom-result {
    display: none;
    position: absolute;
    top: 0;
    right: 0;
    width: 50%;
    height: 600px;
    border: 1px solid #eee;
    background-color: #fff;
    background-repeat: no-repeat;
    z-index: 100;
    box-shadow: 0 8px 30px rgba(0,0,0,0.15);
    border-radius: 8px;
    overflow: hidden;
  }

  .product-page__main-img-wrap:hover .product-page__main-img {
    cursor: crosshair;
  }

  @media (max-width: 992px) {
    .product-page__zoom-lens,
    .product-page__zoom-result {
      display: none !important;
    }
  }

  .product-page__img-placeholder {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-cream, #f5f0e8);
  }

  /* Cert logos overlay */
  .product-page__cert-logos {
    position: absolute;
    top: 16px;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    padding: 0 20px;
    z-index: 2;
    pointer-events: none;
  }

  .product-page__cert-logo {
    max-height: 52px;
    width: auto;
    object-fit: contain;
  }

  @media (max-width: 768px) {
    .product-page__cert-logo { max-height: 36px; }
  }

  /* Image action icons */
  .product-page__img-actions {
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-items: center;
    padding-top: 8px;
  }

  .product-page__img-action-btn {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(255,255,255,0.9);
    border: 1px solid #e0e0e0;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #444;
    transition: background 0.2s;
  }
  .product-page__img-action-btn:hover { background: #fff; }

  /* Info panel */
  .product-page__info {
    padding-top: 4px;
    padding-left: 32px;
    width: 100%;
  }

  .product-page__vendor {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gold, #b8963e);
    margin-bottom: 6px;
  }

  .product-page__title-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 10px;
  }

  .product-page__title {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: 28px;
    font-weight: 400;
    line-height: 1.2;
    margin: 0;
    color: var(--color-primary, #1a2a3a);
  }

  /* Badges */
  .product-page__badge-row {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    flex-shrink: 0;
  }

  .product-page__shipping-badge {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    color: #555;
  }

  .product-page__avail-badge {
    font-size: 11px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 4px;
  }
  .product-page__avail-badge--in {
    background: #e6f4ea;
    color: #2e7d32;
  }
  .product-page__avail-badge--out {
    background: #fde8e8;
    color: #c62828;
  }

  /* Meta row */
  .product-page__meta-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
    font-size: 12px;
    font-family: var(--font-body, 'Inter', sans-serif);
    color: #555;
    margin-bottom: 14px;
  }
  .product-page__meta-sep { color: #bbb; }
  .product-page__reviews-inline { display: flex; align-items: center; gap: 4px; }
  .product-page__stars { color: #f1c40f; letter-spacing: 1px; font-size: 13px; }

  /* Divider */
  .product-page__divider {
    height: 1px;
    background: var(--color-border-light, #eee);
    margin: 14px 0;
  }

  /* Price */
  .product-page__price-row {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 4px;
  }

  .product-page__price {
    font-size: 24px;
    font-weight: 700;
    color: var(--color-primary, #1a2a3a);
    font-family: var(--font-accent);
  }

  .product-page__compare-price {
    font-size: 15px;
    color: #aaa;
    text-decoration: line-through;
  }

  .product-page__price-note {
    font-size: 11px;
    color: #888;
  }

  .product-page__price-update-badge {
    font-size: 10px;
    font-weight: 700;
    color: #fff;
    background: var(--color-gold, #b8963e);
    padding: 3px 10px;
    border-radius: 20px;
    letter-spacing: 0.05em;
  }

  /* Tabs */
  .product-page__tabs { margin-bottom: 18px; }

  .product-page__tab-nav {
    display: flex;
    border-bottom: 1px solid #e0e0e0;
    margin-bottom: 14px;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }
  .product-page__tab-nav::-webkit-scrollbar { display: none; }

  .product-page__tab-btn {
    flex: 0 0 auto;
    min-width: 155px;
    white-space: nowrap;
    padding: 10px 14px;
    font-size: 12px;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-weight: 500;
    color: #777;
    background: none;
    border: 1px solid #e0e0e0;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.2s;
    margin-bottom: -1px;
    text-align: center;
  }
  .product-page__tab-btn:hover { color: var(--color-primary, #1a2a3a); }
  .product-page__tab-btn--active {
    color: var(--color-primary, #1a2a3a);
    border-bottom-color: var(--color-primary, #1a2a3a);
    font-weight: 600;
  }

  .product-page__tab-pane {
    display: none;
    font-size: 13px;
    font-family: var(--font-body, 'Inter', sans-serif);
    color: #555;
    line-height: 1.7;
    padding: 16px 0;
  }
  .product-page__tab-pane--active { display: block; }

  .product-page__tab-heading {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: 18px;
    font-weight: 600;
    color: var(--color-primary, #1a2a3a);
    margin: 0 0 10px;
  }

  .product-page__tab-list {
    margin: 6px 0 0 16px;
    padding: 0;
    list-style: disc;
  }
  .product-page__tab-list li {
    margin-bottom: 3px;
    font-size: 13px;
  }

  .product-page__read-more {
    display: inline-block;
    margin-top: 8px;
    font-size: 12px;
    font-weight: 700;
    color: var(--color-primary, #1a2a3a);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .product-page__read-more:hover { color: var(--color-gold, #b8963e); }

  /* Customization panel */
  .product-page__customize-panel {
    background: var(--color-cream, #f5f0e8);
    border-radius: 8px;
    padding: 14px 16px;
    margin-bottom: 16px;
  }

  .product-page__customize-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  .product-page__customize-label {
    font-size: 12px;
    font-weight: 600;
    color: var(--color-primary, #1a2a3a);
    letter-spacing: 0.02em;
  }

  .product-page__reset-btn {
    font-size: 11px;
    font-weight: 600;
    color: var(--color-gold, #b8963e);
    background: none;
    border: none;
    cursor: pointer;
    letter-spacing: 0.05em;
  }

  .product-page__customize-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .product-page__customize-cell {
    background: #fff;
    border-radius: 6px;
    padding: 8px 12px;
    border: 1px solid #e0e0e0;
  }
  .product-page__customize-cell--wide { grid-column: 1 / -1; }

  .product-page__customize-cell label {
    display: block;
    font-size: 10px;
    color: #888;
    margin-bottom: 4px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .product-page__customize-val {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 500;
    color: var(--color-primary, #1a2a3a);
  }

  .product-page__metal-swatch {
    width: 20px;
    height: 14px;
    border-radius: 3px;
    flex-shrink: 0;
  }
  .product-page__metal-swatch--rose {
    background: linear-gradient(135deg, #e8c4a0, #c9956c);
  }

  .product-page__style-swatch {
    width: 20px;
    height: 20px;
    background: #f0f0f0;
    border-radius: 3px;
    border: 1px solid #ddd;
    flex-shrink: 0;
  }

  /* CTA buttons */
  .product-page__dual-cta {
    display: flex;
    gap: 10px;
    margin-bottom: 10px;
  }
  .product-page__dual-cta form {
    flex: 1;
  }

  .product-page__btn-outline {
    width: 100%;
    padding: 14px 20px;
    border: 1.5px solid var(--color-primary, #1a2a3a);
    border-radius: 6px;
    font-size: 12px;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: #fff;
    color: var(--color-primary, #1a2a3a);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: all 0.2s;
  }
  .product-page__btn-outline:hover {
    background: var(--color-primary, #1a2a3a);
    color: #fff;
  }

  .product-page__btn-dark {
    flex: 1;
    width: 100%;
    padding: 14px 20px;
    border: none;
    border-radius: 6px;
    font-size: 12px;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: var(--color-primary, #1a2a3a);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: background 0.2s;
  }
  .product-page__btn-dark:hover { background: #2c4a3e; }
  .product-page__btn-dark--full { margin-top: 0; }

  /* Dispatch */
  .product-page__dispatch {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 11px;
    color: #555;
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px solid var(--color-border-light, #eee);
  }
  .product-page__dispatch strong { color: var(--color-primary, #1a2a3a); }
  .product-page__dispatch-sep { color: #bbb; }
  .product-page__pincode-link {
    color: var(--color-gold, #b8963e);
    text-decoration: none;
    font-weight: 500;
  }
  .product-page__pincode-link:hover { text-decoration: underline; }

  /* ====================== */
  /* You May Also Like       */
  /* ====================== */
  .product-recs {
    background: var(--color-bg, #faf8f4);
    padding: var(--space-3xl, 60px) 0 var(--space-4xl, 80px);
    position: relative;
  }

  .product-recs__title {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: 32px;
    font-weight: 600;
    font-style: italic;
    text-align: center;
    color: var(--color-primary, #1a2a3a);
    margin-bottom: 8px;
  }

  .product-recs__header-row {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    margin-bottom: 24px;
  }

  .product-recs__view-all {
    font-size: 13px;
    font-family: var(--font-body, 'Inter', sans-serif);
    color: var(--color-primary, #1a2a3a);
    text-decoration: underline;
    text-underline-offset: 3px;
    font-weight: 500;
  }
  .product-recs__view-all:hover { color: var(--color-gold, #b8963e); }

  .product-recs__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
  }

  @media (max-width: 1024px) {
    .product-recs__grid { grid-template-columns: repeat(4, 1fr); }
  }

  @media (max-width: 768px) {
    .product-recs__grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
  }

  @media (max-width: 480px) {
    .product-recs__grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  }

  .product-recs__card {
    min-width: 0;
  }

  .product-recs__card-img {
    display: block;
    background: #fff;
    border-radius: 10px;
    border: 1px solid #eee;
    overflow: hidden;
    aspect-ratio: 1;
    width: 100%;
  }

  .product-recs__card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product-recs__card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f5f0e8;
  }

  .product-recs__card-info {
    padding: 10px 4px 6px;
  }

  .product-recs__card-name {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 13px;
    font-weight: 500;
    color: var(--color-primary, #1a2a3a);
    margin: 0 0 3px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .product-recs__card-price {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 12px;
    font-weight: 700;
    color: var(--color-primary, #1a2a3a);
    margin: 0;
  }

  .product-recs__details-btn {
    display: block;
    width: 100%;
    text-align: center;
    padding: 9px 12px;
    border: 1px solid #ddd;
    border-radius: 6px;
    font-size: 11px;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-primary, #1a2a3a);
    text-decoration: none;
    background: #fff;
    transition: all 0.2s;
    box-sizing: border-box;
  }
  .product-recs__details-btn:hover {
    background: var(--color-primary, #1a2a3a);
    color: #fff;
    border-color: var(--color-primary, #1a2a3a);
  }

  /* ======================== */
  /* Buying Process (PDP)     */
  /* ======================== */
  .pdp-buying-process {
    background: #d8c3ad;
    text-align: center;
    padding: var(--space-3xl, 60px) 0 var(--space-4xl, 80px);
  }

  .pdp-bp__heading {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: 36px;
    font-weight: 400;
    font-style: italic;
    color: var(--color-primary, #1a2a3a);
    margin: 0 0 8px;
  }

  .pdp-bp__subheading {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 14px;
    color: #555;
    margin: 0 0 var(--space-3xl, 48px);
  }

  .pdp-bp__grid {
    display: flex;
    justify-content: space-between;
    gap: var(--space-md, 16px);
    flex-wrap: wrap;
  }

  .pdp-bp__item {
    flex: 1;
    min-width: 150px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .pdp-bp__icon-wrap {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-lg, 20px);
    position: relative;
    box-shadow: 0 4px 15px rgba(0,0,0,0.06);
  }

  .pdp-bp__icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pdp-bp__icon svg {
    width: 100%;
    height: 100%;
  }

  .pdp-bp__number {
    position: absolute;
    top: -4px;
    right: -4px;
    width: 24px;
    height: 24px;
    background: #2d4a3e;
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 600;
    font-family: var(--font-body, 'Inter', sans-serif);
    border: 2px solid #d8c3ad;
  }

  .pdp-bp__step-title {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 600;
    margin: 0 0 var(--space-sm, 8px);
    color: var(--color-primary, #1a2a3a);
  }

  .pdp-bp__step-desc {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 12px;
    color: #555;
    line-height: 1.5;
    max-width: 200px;
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 992px) {
    .product-page__wrapper { grid-template-columns: 1fr; gap: var(--space-2xl, 40px); }
    .product-page__gallery, .product-page__info { padding-left: 0; padding-right: 0; }
  }

  @media (max-width: 768px) {
    .product-page__wrapper {
      overflow: hidden;
    }

    .product-page__gallery {
      display: flex;
      flex-direction: column;
      gap: 16px;
      max-width: 100%;
      overflow: hidden;
    }

    .product-page__main-img-wrap {
      order: 1;
    }

    .product-page__img-actions {
      display: none;
    }

    .product-page__thumbstrip {
      order: 3;
      flex-direction: row;
      overflow-x: auto;
      max-height: none;
      padding: 0 0 10px;
      justify-content: flex-start;
      gap: 10px;
      scrollbar-width: none;
    }
    .product-page__thumbstrip::-webkit-scrollbar { display: none; }

    .product-page__thumb {
      width: 75px;
      height: 75px;
      flex-shrink: 0;
    }

    .product-page__title-row {
      flex-direction: column;
      gap: 8px;
    }

    .product-page__title {
      font-size: 22px;
    }

    .product-page__badge-row {
      flex-shrink: 1;
    }

    .product-page__meta-row {
      flex-wrap: wrap;
      font-size: 11px;
    }

    .product-page__price {
      font-size: 22px;
    }

    .product-page__dual-cta {
      flex-direction: column;
      gap: 12px;
    }
    .product-page__dual-cta form {
      width: 100%;
      flex: none;
    }
  }

  @media (max-width: 768px) {
    .pdp-bp__grid {
      flex-direction: column;
      align-items: center;
      gap: var(--space-2xl, 32px);
    }
    .pdp-bp__heading { font-size: 28px; }
  }

  .product-page__description {
    font-size: 14px;
    line-height: 1.6;
    color: #555;
    margin-bottom: 20px;
  }

  /* Specs Grid in About Tab */
  .product-page__specs-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-top: 20px;
  }

  .product-page__spec-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 12px 16px;
    background: #f9f9f9;
    border-radius: 8px;
    border: 1px solid #eee;
  }

  .product-page__spec-item--full {
    grid-column: 1 / -1;
  }

  .product-page__spec-label {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #999;
  }

  .product-page__spec-value {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-primary, #1a2a3a);
  }

  /* Taglines in About Tab */
  .product-page__taglines {
    margin-bottom: 24px;
    padding-bottom: 20px;
    border-bottom: 1px dashed #ddd;
  }
  .product-page__tagline-en {
    font-size: 18px;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 1.4;
    margin-bottom: 8px;
  }
  .product-page__tagline-hi {
    font-size: 18px;
    color: #444;
    line-height: 1.5;
  }

  /* Know Your Gem Specs Table */
  .product-page__specs-table {
    margin-top: 16px;
    border-top: 1px solid #eee;
  }
  .product-page__specs-row {
    display: grid;
    grid-template-columns: 200px 1fr;
    padding: 14px 0;
    border-bottom: 1px solid #eee;
    align-items: center;
  }
  .product-page__specs-label {
    font-weight: 600;
    color: #1a1a1a;
    font-size: 13px;
  }
  .product-page__specs-val {
    color: #444;
    font-size: 13px;
    line-height: 1.5;
  }

  /* Treatment Table */
  .product-page__treatment-table {
    margin-top: 16px;
    border: 1px solid #eee;
    border-radius: 4px;
    overflow: hidden;
  }
  .product-page__treatment-row {
    display: flex;
    justify-content: space-between;
    padding: 12px 16px;
    border-bottom: 1px solid #eee;
    align-items: center;
  }
  .product-page__treatment-row:last-child { border-bottom: none; }
  .product-page__treatment-label {
    font-size: 13px;
    color: #444;
  }
  .product-page__treatment-status {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    color: #1a1a1a;
    font-size: 13px;
  }
  .product-page__treatment-icon {
    display: inline-flex;
    width: 14px;
    height: 14px;
    background: #cc0000;
    color: #fff;
    border-radius: 50%;
    align-items: center;
    justify-content: center;
    font-size: 8px;
    font-weight: bold;
    transform: scale(1.1);
