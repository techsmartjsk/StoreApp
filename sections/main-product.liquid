{%- comment -%}Main Product Section{%- endcomment -%}

{%- assign current_variant = product.selected_or_first_available_variant -%}

{%- comment -%} Removed the top breadcrumb to move it closer to the image {%- endcomment -%}

<section class="product-page" id="product-{{ product.id }}">
  <div class="page-width">
    <!-- Breadcrumb moved here -->
    <nav class="breadcrumb breadcrumb--pdp" aria-label="breadcrumb">
      <a href="/">Home</a>
      <span class="breadcrumb__sep">›</span>
      {%- if product.collections.first -%}
        <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a>
        <span class="breadcrumb__sep">›</span>
      {%- endif -%}
      <a href="{{ product.url }}">{{ product.title }}</a>
    </nav>

    <div class="product-page__wrapper">

      <!-- Gallery -->
      <div class="product-page__gallery">

        <!-- Vertical thumbnail strip -->
        <div class="product-page__thumbstrip">
          {%- for media in product.media -%}
            <button
              class="product-page__thumb{% if forloop.first %} product-page__thumb--active{% endif %}"
              onclick="setMainMedia('{{ media.id }}', this)"
              aria-label="View {{ media.media_type | replace: '_', ' ' }} {{ forloop.index }}"
              data-media-id="{{ media.id }}"
            >
              {%- if media.media_type contains 'video' -%}
                <div class="product-page__thumb-video-icon">
                  {% render 'icon', name: 'play' %}
                </div>
              {%- endif -%}
              <img
                src="{{ media.preview_image | image_url: width: 120 }}"
                alt="{{ media.alt | default: product.title | escape }}"
                loading="lazy"
              >
            </button>
          {%- endfor -%}
        </div>

        <!-- Action icons (between thumbs and image) -->
        <div class="product-page__img-actions">
          <button class="product-page__img-action-btn" aria-label="Share" onclick="copyToClipboard(window.location.href, this)">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          </button>
          <button 
            class="product-page__img-action-btn" 
            aria-label="Wishlist"
            data-wishlist-toggle
            data-product-id="{{ product.id }}"
            data-product-title="{{ product.title | escape }}"
            data-product-url="{{ product.url }}"
            data-product-price="{{ product.price | money }}"
            data-product-image="{{ product.featured_image | image_url: width: 600 }}"
            data-variant-id="{{ product.selected_or_first_available_variant.id }}"
            onclick="event.preventDefault(); WishlistApp.toggle(this)"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </button>
          <button class="product-page__img-action-btn" aria-label="Zoom" onclick="zoomActiveImage()">
            <img src="{{ 'zoom-in.svg' | asset_url }}" alt="Zoom" style="width: 16px; height: 16px; object-fit: contain;">
          </button>
        </div>

        <!-- Main image -->
        <div class="product-page__main-img-wrap">
          <!-- Certification logos overlaid on image -->
          {% comment %} <div class="product-page__cert-logos">
            {%- if section.settings.cert_logo != blank -%}
              <img src="{{ section.settings.cert_logo | image_url: width: 160 }}" alt="Certification" class="product-page__cert-logo product-page__cert-logo--left">
            {%- endif -%}
          </div> {% endcomment %}

          <!-- Zoom highlight lens -->
          <div class="product-page__zoom-lens" id="zoom-lens"></div>

          <div id="product-page-media-container">
            {%- if product.featured_media -%}
              {%- for media in product.media -%}
                <div class="product-page__media-item {% if media.id == product.featured_media.id %}is-active{% endif %}" data-media-id="{{ media.id }}" style="display: {% if media.id == product.featured_media.id %}block{% else %}none{% endif %};">
                  {%- case media.media_type -%}
                    {%- when 'image' -%}
                      <img
                        src="{{ media | image_url: width: 1000 }}"
                        data-zoom-src="{{ media | image_url: width: 2000 }}"
                        alt="{{ media.alt | default: product.title | escape }}"
                        class="product-page__main-img"
                        id="main-product-image-{{ media.id }}"
                      >
                    {%- when 'external_video' -%}
                      <div class="product-page__video-preview" data-video-type="external" data-media-id="{{ media.id }}"
                        {%- if media.host == 'youtube' %} data-video-url="https://www.youtube.com/embed/{{ media.external_id }}?autoplay=1"{% endif -%}
                        {%- if media.host == 'vimeo' %} data-video-url="https://player.vimeo.com/video/{{ media.external_id }}?autoplay=1"{% endif -%}
                        onclick="openVideoPopup(this)">
                        <img src="{{ media.preview_image | image_url: width: 1000 }}" alt="{{ media.alt | default: product.title | escape }}" class="product-page__main-img">
                        <div class="product-page__video-play-btn">
                          <svg width="48" height="48" viewBox="0 0 24 24" fill="white"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                        </div>
                      </div>
                    {%- when 'video' -%}
                      <div class="product-page__video-preview" data-video-type="native" data-media-id="{{ media.id }}" onclick="openVideoPopup(this)">
                        <img src="{{ media.preview_image | image_url: width: 1000 }}" alt="{{ media.alt | default: product.title | escape }}" class="product-page__main-img">
                        <div class="product-page__video-play-btn">
                          <svg width="48" height="48" viewBox="0 0 24 24" fill="white"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                        </div>
                        <video class="product-page__video-source" style="display:none;" preload="metadata">
                          {%- for source in media.sources -%}
                            <source src="{{ source.url }}" type="{{ source.mime_type }}">
                          {%- endfor -%}
                        </video>
                      </div>
                  {%- endcase -%}
                </div>
              {%- endfor -%}
            {%- else -%}
              <div class="product-page__img-placeholder">
                <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>

      <!-- Zoom result panel (Amazon-style, positioned over info area) -->
      <div class="product-page__zoom-result" id="zoom-result"></div>

      <!-- Product Info -->
      <div class="product-page__info">

        <!-- Vendor -->
        {%- if product.vendor -%}
          <p class="product-page__vendor">{{ product.vendor }}</p>
        {%- endif -%}

        <!-- Title + badges row -->
        <div class="product-page__title-row">
          <h1 class="product-page__title">{{ product.title }}</h1>
          {% comment %} <div class="product-page__badge-row">
            <span class="product-page__shipping-badge">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              shipping available in India
            </span>
            <span class="product-page__avail-badge {% if product.available %}product-page__avail-badge--in{% else %}product-page__avail-badge--out{% endif %}">
              {% if product.available %}Available{% else %}Sold Out{% endif %}
            </span>
          </div> {% endcomment %}
        </div>

        <!-- SKU / Origin / Reviews -->
        <div class="product-page__meta-row">
          <span>SKU: {{ current_variant.sku | default: '87587' }}</span>
          <span class="product-page__meta-sep">|</span>
          <span>Origin: {{ product.metafields.gem.origin | default: 'Sri Lanka' }}</span>
          <span class="product-page__meta-sep">|</span>
          {% comment %} <span class="product-page__reviews-inline">
            Reviews ({{ product.metafields.reviews.rating_count | default: '23' }})
            <span class="product-page__stars">★★★★★</span>
          </span> {% endcomment %}
        </div>

        <div class="product-page__divider"></div>

        <!-- Price -->
        <div class="product-page__price-row">
          <span class="product-page__price">{{ current_variant.price | money }}</span>
          {%- if product.compare_at_price > product.price -%}
            <span class="product-page__compare-price">{{ product.compare_at_price | money }}</span>
          {%- endif -%}
          <span class="product-page__price-note">(MRP incl. of all taxes)</span>
          <span class="product-page__price-update-badge" id="price-update-badge" style="display:none;">● PRICE UPDATE</span>
        </div>

        <div class="product-page__divider"></div>

        <!-- Tabs -->
        <div class="product-page__tabs">
          <div class="product-page__tab-nav" role="tablist">
            <button class="product-page__tab-btn product-page__tab-btn--active" onclick="switchTab('about', this)" role="tab">About this Gem</button>
            <button class="product-page__tab-btn" onclick="switchTab('know-gem', this)" role="tab">Know your gem</button>
            <button class="product-page__tab-btn" onclick="switchTab('treatment', this)" role="tab">Treatment and Certification</button>
            <button class="product-page__tab-btn" onclick="switchTab('planetary', this)" role="tab">Planetary Alignment</button>
            <button class="product-page__tab-btn" onclick="switchTab('purification', this)" role="tab">Purification and Energisation</button>
            {%- if product.price > 50000000 -%}
              <button class="product-page__tab-btn" onclick="switchTab('special', this)" role="tab">Why this gem is special</button>
            {%- endif -%}
          </div>
          <div class="product-page__tab-pane product-page__tab-pane--active" id="tab-about">
            {%- if product.description != blank -%}
              <div class="product-page__description">
                {{ product.description }}
              </div>
            {%- else -%}
              <h4 class="product-page__tab-heading">About this Gem</h4>
              <p>Discover the unique story and origin of this natural {{ product.type | default: 'gemstone' }}. Each piece in our collection is handpicked for its exceptional clarity, vibrant color, and sacred energy.</p>
            {%- endif -%}

            <!-- Specs Grid -->
            <div class="product-page__specs-grid">
              {%- if product.metafields.custom.gem_type != blank -%}
                <div class="product-page__spec-item">
                  <span class="product-page__spec-label">Gem Type</span>
                  <span class="product-page__spec-value">{{ product.metafields.custom.gem_type }}</span>
                </div>
              {%- endif -%}
              {%- if product.metafields.custom.origin != blank -%}
                <div class="product-page__spec-item">
                  <span class="product-page__spec-label">Origin</span>
                  <span class="product-page__spec-value">{{ product.metafields.custom.origin }}</span>
                </div>
              {%- endif -%}
              {%- if product.metafields.custom.weight_carat != blank or product.metafields.custom.weight_ratti != blank -%}
                <div class="product-page__spec-item">
                  <span class="product-page__spec-label">Weight</span>
                  <span class="product-page__spec-value">
                    {% if product.metafields.custom.weight_carat %}{{ product.metafields.custom.weight_carat }} Carat{% endif %}
                    {% if product.metafields.custom.weight_carat and product.metafields.custom.weight_ratti %} / {% endif %}
                    {% if product.metafields.custom.weight_ratti %}{{ product.metafields.custom.weight_ratti }} Ratti{% endif %}
                  </span>
                </div>
              {%- endif -%}
              {%- if product.metafields.custom.shape_cut != blank or product.metafields.custom.cutting_style != blank -%}
                <div class="product-page__spec-item">
                  <span class="product-page__spec-label">Shape / Cut</span>
                  <span class="product-page__spec-value">
                    {{ product.metafields.custom.shape_cut }} {% if product.metafields.custom.cutting_style %}({{ product.metafields.custom.cutting_style }}){% endif %}
                  </span>
                </div>
              {%- endif -%}
              {%- if product.metafields.custom.transparency != blank -%}
                <div class="product-page__spec-item">
                  <span class="product-page__spec-label">Transparency</span>
                  <span class="product-page__spec-value">{{ product.metafields.custom.transparency }}</span>
                </div>
              {%- endif -%}
              {%- if product.metafields.custom.treatment_status != blank -%}
                <div class="product-page__spec-item">
                  <span class="product-page__spec-label">Treatment</span>
                  <span class="product-page__spec-value">{{ product.metafields.custom.treatment_status }}</span>
                </div>
              {%- endif -%}
              {%- if product.metafields.custom.certification_lab != blank -%}
                <div class="product-page__spec-item">
                  <span class="product-page__spec-label">Certification</span>
                  <span class="product-page__spec-value">{{ product.metafields.custom.certification_lab }}</span>
                </div>
              {%- endif -%}
              {%- if product.metafields.custom.planetary_alignment != blank -%}
                <div class="product-page__spec-item">
                  <span class="product-page__spec-label">Planet</span>
                  <span class="product-page__spec-value">{{ product.metafields.custom.planetary_alignment }}</span>
                </div>
              {%- endif -%}
              {%- if product.metafields.custom.wow_factor != blank -%}
                <div class="product-page__spec-item product-page__spec-item--full">
                  <span class="product-page__spec-label">Special Features</span>
                  <span class="product-page__spec-value">{{ product.metafields.custom.wow_factor | newline_to_br }}</span>
                </div>
              {%- endif -%}
            </div>
          </div>
          <div class="product-page__tab-pane" id="tab-know-gem">
            {%- if product.metafields.gem.know_gem != blank -%}
              {{ product.metafields.gem.know_gem }}
            {%- else -%}
              <h4 class="product-page__tab-heading">Know your gem</h4>
              <p>Understanding your {{ product.type | default: 'gem' }} is the first step in your journey. This piece carries specific physical and vibrational qualities that align with your intentions.</p>
              <ul class="product-page__tab-list">
                <li>Species: {{ product.metafields.custom.species | default: 'Natural Corundum' }}</li>
                <li>Hardness: {{ product.metafields.custom.hardness | default: '9.0 on Mohs scale' }}</li>
                <li>Refractive Index: {{ product.metafields.custom.ri | default: '1.762 - 1.770' }}</li>
                <li>Gravity: {{ product.metafields.custom.sg | default: '4.00' }}</li>
              </ul>
            {%- endif -%}
          </div>
          <div class="product-page__tab-pane" id="tab-treatment">
            {%- if product.metafields.gem.treatment != blank -%}
              {{ product.metafields.gem.treatment }}
            {%- else -%}
              <h4 class="product-page__tab-heading">Treatment and Certification</h4>
              <p>This Blue Sapphire (Neelam) is a 100% natural, unheated gemstone with no artificial enhancements. It has been carefully examined and certified by a reputed gemological laboratory.</p>
              <p style="margin-top:10px;"><strong>Details</strong></p>
              <ul class="product-page__tab-list">
                <li>Treatment : Unheated / No Treatment</li>
                <li>Certification Lab : ITLGR (International Testing Laboratory for Gemstones Research)</li>
                <li>Certificate No : S382185331</li>
                <li>Transparency : Transparent</li>
                <li>Lustre : Vitreous</li>
                <li>Comment : Natural inclusions present, consistent with origin</li>
              </ul>
            {%- endif -%}
          </div>
          <div class="product-page__tab-pane" id="tab-planetary">
            {%- if product.metafields.gem.planetary != blank -%}
              {{ product.metafields.gem.planetary }}
            {%- else -%}
              <h4 class="product-page__tab-heading">Planetary Alignment</h4>
              <p>This gem is harmonized with its ruling celestial body to provide maximum astrological benefits. Wear it to align your personal energy with the cosmic vibrations of {{ product.metafields.gem.planet | default: 'your ruling planet' }}.</p>
            {%- endif -%}
          </div>
          <div class="product-page__tab-pane" id="tab-purification">
            {%- if product.metafields.gem.purification != blank -%}
              {{ product.metafields.gem.purification }}
            {%- else -%}
              <h4 class="product-page__tab-heading">Purification and Energisation</h4>
              <p>Before wearing, it is essential to purify and energize your gem to remove any previous imprints and activate its sacred properties.</p>
              <ul class="product-page__tab-list">
                <li>Wash gently in raw milk and gangajal.</li>
                <li>Chant the specific Beej Mantra 108 times.</li>
                <li>Wear it on the designated finger during the shubh mahurat.</li>
              </ul>
            {%- endif -%}
          </div>
          {%- if product.price > 50000000 -%}
            <div class="product-page__tab-pane" id="tab-special">
              {%- if product.metafields.gem.special_why != blank -%}
                {{ product.metafields.gem.special_why }}
              {%- else -%}
                <h4 class="product-page__tab-heading">Why this gem is special</h4>
                <p>This premium gemstone is among the top 1% of its kind. Its exceptional saturation, rare origin, and master-grade cut make it a truly unique investment and a powerful spiritual tool.</p>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>

        <!-- Customization Info Bar (Shown when customized) -->
        <div id="customize-info-bar" class="product-page__customize-info" style="display:none;">
          <div class="product-page__customize-info-header">
            <span class="product-page__customize-info-label">Customization Selected</span>
            <button class="product-page__reset-btn" onclick="CustomizeApp.reset()">RESET</button>
          </div>
          <div class="product-page__customize-info-details" id="customize-summary-text">
            Ring / 14K Gold / Size 9 / Solitaire
          </div>
        </div>

        <!-- CTA: default (two buttons side-by-side) -->
        <div id="cta-default" class="product-page__dual-cta">
          {%- if product.price > 100000000 -%}
            <a href="mailto:{{ shop.email }}?subject=Inquiry: {{ product.title | escape }}" class="product-page__btn-dark" style="width: 100%; text-decoration: none;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
              CONTACT US FOR PRICE
            </a>
          {%- else -%}
            {%- form 'product', product -%}
              <input type="hidden" name="id" value="{{ current_variant.id }}">
              <input type="hidden" name="quantity" value="1">
              <button
                type="submit"
                class="product-page__btn-outline"
                {% unless product.available %}disabled{% endunless %}
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                ADD LOOSE GEM TO CART
              </button>
            {%- endform -%}
          {%- endif -%}
          <button type="button" class="product-page__btn-dark" onclick="CustomizeApp.open()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            CUSTOMIZE
          </button>
        </div>

        <!-- CTA: customize (single button, shown after customize click) -->
        <div id="cta-customize" style="display:none;">
          {%- form 'product', product -%}
            <input type="hidden" name="id" value="{{ current_variant.id }}">
            <input type="hidden" name="quantity" value="1">
            <input type="hidden" name="properties[Jewelry Type]" value="Ring">
            <input type="hidden" name="properties[Metal]" value="Rose Gold">
            <input type="hidden" name="properties[Metal Purity]" value="14K">
            <input type="hidden" name="properties[Ring Size]" value="Size 9; 49.0mm">
            <input type="hidden" name="properties[Ring Style]" value="Solitaire">
            <button
              type="submit"
              class="product-page__btn-dark product-page__btn-dark--full"
              {% unless product.available %}disabled{% endunless %}
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              ADD TO CART
            </button>
          {%- endform -%}
        </div>

        <!-- Dispatch info -->
        {% comment %} <div class="product-page__dispatch">
          <span>Estimated Dispatch Date: <strong>02 Sept, 2025</strong></span>
          <span class="product-page__dispatch-sep">For Pincode: <strong>120010</strong></span>
          <a href="#" class="product-page__pincode-link">| Change Pincode</a>
        </div> {% endcomment %}

      </div>
    </div>
  </div>
</section>

<!-- Customization Modal Overlay -->
<div class="customize-modal-overlay" id="customize-modal" onclick="CustomizeApp.close()">
  <div class="customize-modal" onclick="event.stopPropagation()">
    <button class="customize-modal__close" onclick="CustomizeApp.close()" aria-label="Close customization">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#666" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>

    <div class="customize-modal__header">
      <h2 class="customize-modal__title">Customize Your Jewellery With This Gemstone.</h2>
    </div>

    <div class="customize-modal__body">
      <!-- 1. Product Type -->
      <div class="customize-step">
        <div class="customize-step__header">
          <span class="customize-step__num">1.</span> What Would You Like To Create?
          <button class="customize-step__reset" onclick="CustomizeApp.reset()">RESET</button>
        </div>
        <div class="customize-options customize-options--grid-2">
          <button class="customize-card" data-opt="type" data-val="Ring" onclick="CustomizeApp.set('type', 'Ring', this)">
            <div class="customize-card__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="14" r="7"/><ellipse cx="12" cy="7" rx="4" ry="3"/></svg>
            </div>
            <span class="customize-card__label">Ring</span>
            <div class="customize-card__check">✓</div>
          </button>
          <button class="customize-card" data-opt="type" data-val="Pendant" onclick="CustomizeApp.set('type', 'Pendant', this)">
            <div class="customize-card__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2v4M12 6c-3 0-5 2-5 5s2 8 5 8 5-5 5-8-2-5-5-5z"/><circle cx="12" cy="11" r="2"/></svg>
            </div>
            <span class="customize-card__label">Pendants</span>
            <div class="customize-card__check">✓</div>
          </button>
        </div>
      </div>

      <!-- 2. Select Metal -->
      <div class="customize-step">
        <div class="customize-step__header"><span class="customize-step__num">2.</span> Select Metal</div>
        <div class="customize-pills">
          <button class="customize-pill" data-opt="metal" data-val="Silver" onclick="CustomizeApp.set('metal', 'Silver', this)">Silver</button>
