<style>
  /* Breadcrumb */
  .product-breadcrumb {
    background: var(--color-bg, #faf8f4);
    padding: 10px 0;
    border-bottom: 1px solid var(--color-border-light, #eee);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 4px;
    font-size: 11px;
    font-family: var(--font-body, 'Inter', sans-serif);
    color: #888;
  }

  .breadcrumb a {
    color: #888;
    text-decoration: none;
  }

  .breadcrumb a:hover { color: var(--color-primary, #1a2a3a); }
  .breadcrumb__sep { color: #bbb; }

  .breadcrumb--pdp {
    margin-bottom: 20px;
  }

  /* Page wrapper */
  .product-page { padding: var(--space-2xl, 40px) 0 var(--space-4xl, 80px); }

  @media (max-width: 768px) {
    .product-page { padding: var(--space-xl, 24px) 16px var(--space-3xl, 60px); }
  }

  .product-page__wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    align-items: flex-start;
    width: 100%;
  }

  /* Gallery */
  .product-page__gallery {
    display: grid;
    grid-template-columns: 70px 36px 1fr;
    gap: 12px;
    padding-right: 32px;
    width: 100%;
  }

  /* Thumbnail strip */
  .product-page__thumbstrip {
    display: flex;
    flex-direction: column;
    gap: 8px;
    max-height: 580px;
    overflow-y: auto;
    scrollbar-width: none;
  }
  .product-page__thumbstrip::-webkit-scrollbar { display: none; }

  .product-page__thumb {
    width: 65px;
    height: 65px;
    border-radius: 6px;
    border: 2px solid transparent;
    overflow: hidden;
    cursor: pointer;
    padding: 0;
    background: var(--color-cream, #f5f0e8);
    flex-shrink: 0;
    transition: border-color 0.2s;
  }
  .product-page__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .product-page__thumb--active,
  .product-page__thumb:hover {
    border-color: var(--color-gold, #b8963e);
  }

  /* Main image */
  .product-page__main-img-wrap {
    position: relative;
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid #eee;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .product-page__main-img-wrap {
      max-height: 65vh;
      max-width: 100%;
    }
  }

  .product-page__main-img {
    width: 100%;
    max-height: 100%;
    display: block;
    object-fit: contain;
  }

  /* Amazon-style zoom preview (desktop only) */
  .product-page__media-item {
    position: relative;
  }

  .product-page__zoom-lens {
    display: none;
    position: absolute;
    width: 200px;
    height: 200px;
    border: 2px solid var(--color-gold, #c9a96e);
    background: rgba(201, 169, 110, 0.15);
    pointer-events: none;
    z-index: 10;
  }

  .product-page__wrapper {
    position: relative;
  }

  .product-page__zoom-result {
    display: none;
    position: absolute;
    top: 0;
    right: 0;
    width: 50%;
    height: 600px;
    border: 1px solid #eee;
    background-color: #fff;
    background-repeat: no-repeat;
    z-index: 100;
    box-shadow: 0 8px 30px rgba(0,0,0,0.15);
    border-radius: 8px;
    overflow: hidden;
  }

  .product-page__main-img-wrap:hover .product-page__main-img {
    cursor: crosshair;
  }

  @media (max-width: 992px) {
    .product-page__zoom-lens,
    .product-page__zoom-result {
      display: none !important;
    }
  }

  .product-page__img-placeholder {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-cream, #f5f0e8);
  }

  /* Cert logos overlay */
  .product-page__cert-logos {
    position: absolute;
    top: 16px;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    padding: 0 20px;
    z-index: 2;
    pointer-events: none;
  }

  .product-page__cert-logo {
    max-height: 52px;
    width: auto;
    object-fit: contain;
  }

  @media (max-width: 768px) {
    .product-page__cert-logo { max-height: 36px; }
  }

  /* Image action icons */
  .product-page__img-actions {
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-items: center;
    padding-top: 8px;
  }

  .product-page__img-action-btn {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(255,255,255,0.9);
    border: 1px solid #e0e0e0;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #444;
    transition: background 0.2s;
  }
  .product-page__img-action-btn:hover { background: #fff; }

  /* Info panel */
  .product-page__info {
    padding-top: 4px;
    padding-left: 32px;
    width: 100%;
  }

  .product-page__vendor {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gold, #b8963e);
    margin-bottom: 6px;
  }

  .product-page__title-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 10px;
  }

  .product-page__title {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: 28px;
    font-weight: 400;
    line-height: 1.2;
    margin: 0;
    color: var(--color-primary, #1a2a3a);
  }

  /* Badges */
  .product-page__badge-row {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    flex-shrink: 0;
  }

  .product-page__shipping-badge {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    color: #555;
  }

  .product-page__avail-badge {
    font-size: 11px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 4px;
  }
  .product-page__avail-badge--in {
    background: #e6f4ea;
    color: #2e7d32;
  }
  .product-page__avail-badge--out {
    background: #fde8e8;
    color: #c62828;
  }

  /* Meta row */
  .product-page__meta-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
    font-size: 12px;
    font-family: var(--font-body, 'Inter', sans-serif);
    color: #555;
    margin-bottom: 14px;
  }
  .product-page__meta-sep { color: #bbb; }
  .product-page__reviews-inline { display: flex; align-items: center; gap: 4px; }
  .product-page__stars { color: #f1c40f; letter-spacing: 1px; font-size: 13px; }

  /* Divider */
  .product-page__divider {
    height: 1px;
    background: var(--color-border-light, #eee);
    margin: 14px 0;
  }

  /* Price */
  .product-page__price-row {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 4px;
  }

  .product-page__price {
    font-size: 24px;
    font-weight: 700;
    color: var(--color-primary, #1a2a3a);
    font-family: var(--font-accent);
  }

  .product-page__compare-price {
    font-size: 15px;
    color: #aaa;
    text-decoration: line-through;
  }

  .product-page__price-note {
    font-size: 11px;
    color: #888;
  }

  .product-page__price-update-badge {
    font-size: 10px;
    font-weight: 700;
    color: #fff;
    background: var(--color-gold, #b8963e);
    padding: 3px 10px;
    border-radius: 20px;
    letter-spacing: 0.05em;
  }

  /* Tabs */
  .product-page__tabs { margin-bottom: 18px; }

  .product-page__tab-nav {
    display: flex;
    border-bottom: 1px solid #e0e0e0;
    margin-bottom: 14px;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }
  .product-page__tab-nav::-webkit-scrollbar { display: none; }

  .product-page__tab-btn {
    flex: 0 0 auto;
    min-width: 155px;
    white-space: nowrap;
    padding: 10px 14px;
    font-size: 12px;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-weight: 500;
    color: #777;
    background: none;
    border: 1px solid #e0e0e0;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.2s;
    margin-bottom: -1px;
    text-align: center;
  }
  .product-page__tab-btn:hover { color: var(--color-primary, #1a2a3a); }
  .product-page__tab-btn--active {
    color: var(--color-primary, #1a2a3a);
    border-bottom-color: var(--color-primary, #1a2a3a);
    font-weight: 600;
  }

  .product-page__tab-pane {
    display: none;
    font-size: 13px;
    font-family: var(--font-body, 'Inter', sans-serif);
    color: #555;
    line-height: 1.7;
    padding: 16px 0;
  }
  .product-page__tab-pane--active { display: block; }

  .product-page__tab-heading {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: 18px;
    font-weight: 600;
    color: var(--color-primary, #1a2a3a);
    margin: 0 0 10px;
  }

  .product-page__tab-list {
    margin: 6px 0 0 16px;
    padding: 0;
    list-style: disc;
  }
  .product-page__tab-list li {
    margin-bottom: 3px;
    font-size: 13px;
  }

  .product-page__read-more {
    display: inline-block;
    margin-top: 8px;
    font-size: 12px;
    font-weight: 700;
    color: var(--color-primary, #1a2a3a);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .product-page__read-more:hover { color: var(--color-gold, #b8963e); }

  /* Customization panel */
  .product-page__customize-panel {
    background: var(--color-cream, #f5f0e8);
    border-radius: 8px;
    padding: 14px 16px;
    margin-bottom: 16px;
  }

  .product-page__customize-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  .product-page__customize-label {
    font-size: 12px;
    font-weight: 600;
    color: var(--color-primary, #1a2a3a);
    letter-spacing: 0.02em;
  }

  .product-page__reset-btn {
    font-size: 11px;
    font-weight: 600;
    color: var(--color-gold, #b8963e);
    background: none;
    border: none;
    cursor: pointer;
    letter-spacing: 0.05em;
  }

  .product-page__customize-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .product-page__customize-cell {
    background: #fff;
    border-radius: 6px;
    padding: 8px 12px;
    border: 1px solid #e0e0e0;
  }
  .product-page__customize-cell--wide { grid-column: 1 / -1; }

  .product-page__customize-cell label {
    display: block;
    font-size: 10px;
    color: #888;
    margin-bottom: 4px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .product-page__customize-val {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 500;
    color: var(--color-primary, #1a2a3a);
  }

  .product-page__metal-swatch {
    width: 20px;
    height: 14px;
    border-radius: 3px;
    flex-shrink: 0;
  }
  .product-page__metal-swatch--rose {
    background: linear-gradient(135deg, #e8c4a0, #c9956c);
  }

  .product-page__style-swatch {
    width: 20px;
    height: 20px;
    background: #f0f0f0;
    border-radius: 3px;
    border: 1px solid #ddd;
    flex-shrink: 0;
  }

  /* CTA buttons */
  .product-page__dual-cta {
    display: flex;
    gap: 10px;
    margin-bottom: 10px;
  }
  .product-page__dual-cta form {
    flex: 1;
  }

  .product-page__btn-outline {
    width: 100%;
    padding: 14px 20px;
    border: 1.5px solid var(--color-primary, #1a2a3a);
    border-radius: 6px;
    font-size: 12px;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: #fff;
    color: var(--color-primary, #1a2a3a);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: all 0.2s;
  }
  .product-page__btn-outline:hover {
    background: var(--color-primary, #1a2a3a);
    color: #fff;
  }

  .product-page__btn-dark {
    flex: 1;
    width: 100%;
    padding: 14px 20px;
    border: none;
    border-radius: 6px;
    font-size: 12px;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: var(--color-primary, #1a2a3a);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: background 0.2s;
  }
  .product-page__btn-dark:hover { background: #2c4a3e; }
  .product-page__btn-dark--full { margin-top: 0; }

  /* Dispatch */
  .product-page__dispatch {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 11px;
    color: #555;
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px solid var(--color-border-light, #eee);
  }
  .product-page__dispatch strong { color: var(--color-primary, #1a2a3a); }
  .product-page__dispatch-sep { color: #bbb; }
  .product-page__pincode-link {
    color: var(--color-gold, #b8963e);
    text-decoration: none;
    font-weight: 500;
  }
  .product-page__pincode-link:hover { text-decoration: underline; }

  /* ====================== */
  /* You May Also Like       */
  /* ====================== */
  .product-recs {
    background: var(--color-bg, #faf8f4);
    padding: var(--space-3xl, 60px) 0 var(--space-4xl, 80px);
    position: relative;
  }

  .product-recs__title {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: 32px;
    font-weight: 600;
    font-style: italic;
    text-align: center;
    color: var(--color-primary, #1a2a3a);
    margin-bottom: 8px;
  }

  .product-recs__header-row {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    margin-bottom: 24px;
  }

  .product-recs__view-all {
    font-size: 13px;
    font-family: var(--font-body, 'Inter', sans-serif);
    color: var(--color-primary, #1a2a3a);
    text-decoration: underline;
    text-underline-offset: 3px;
    font-weight: 500;
  }
  .product-recs__view-all:hover { color: var(--color-gold, #b8963e); }

  .product-recs__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
  }

  @media (max-width: 1024px) {
    .product-recs__grid { grid-template-columns: repeat(4, 1fr); }
  }

  @media (max-width: 768px) {
    .product-recs__grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
  }

  @media (max-width: 480px) {
    .product-recs__grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  }

  .product-recs__card {
    min-width: 0;
  }

  .product-recs__card-img {
    display: block;
    background: #fff;
    border-radius: 10px;
    border: 1px solid #eee;
    overflow: hidden;
    aspect-ratio: 1;
    width: 100%;
  }

  .product-recs__card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product-recs__card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f5f0e8;
  }

  .product-recs__card-info {
    padding: 10px 4px 6px;
  }

  .product-recs__card-name {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 13px;
    font-weight: 500;
    color: var(--color-primary, #1a2a3a);
    margin: 0 0 3px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .product-recs__card-price {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 12px;
    font-weight: 700;
    color: var(--color-primary, #1a2a3a);
    margin: 0;
  }

  .product-recs__details-btn {
    display: block;
    width: 100%;
    text-align: center;
    padding: 9px 12px;
    border: 1px solid #ddd;
    border-radius: 6px;
    font-size: 11px;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-primary, #1a2a3a);
    text-decoration: none;
    background: #fff;
    transition: all 0.2s;
    box-sizing: border-box;
  }
  .product-recs__details-btn:hover {
    background: var(--color-primary, #1a2a3a);
    color: #fff;
    border-color: var(--color-primary, #1a2a3a);
  }

  /* ======================== */
  /* Buying Process (PDP)     */
  /* ======================== */
  .pdp-buying-process {
    background: #d8c3ad;
    text-align: center;
    padding: var(--space-3xl, 60px) 0 var(--space-4xl, 80px);
  }

  .pdp-bp__heading {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: 36px;
    font-weight: 400;
    font-style: italic;
    color: var(--color-primary, #1a2a3a);
    margin: 0 0 8px;
  }

  .pdp-bp__subheading {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 14px;
    color: #555;
    margin: 0 0 var(--space-3xl, 48px);
  }

  .pdp-bp__grid {
    display: flex;
    justify-content: space-between;
    gap: var(--space-md, 16px);
    flex-wrap: wrap;
  }

  .pdp-bp__item {
    flex: 1;
    min-width: 150px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .pdp-bp__icon-wrap {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-lg, 20px);
    position: relative;
    box-shadow: 0 4px 15px rgba(0,0,0,0.06);
  }

  .pdp-bp__icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pdp-bp__icon svg {
    width: 100%;
    height: 100%;
  }

  .pdp-bp__number {
    position: absolute;
    top: -4px;
    right: -4px;
    width: 24px;
    height: 24px;
    background: #2d4a3e;
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 600;
    font-family: var(--font-body, 'Inter', sans-serif);
    border: 2px solid #d8c3ad;
  }

  .pdp-bp__step-title {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 600;
    margin: 0 0 var(--space-sm, 8px);
    color: var(--color-primary, #1a2a3a);
  }

  .pdp-bp__step-desc {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 12px;
    color: #555;
    line-height: 1.5;
    max-width: 200px;
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 992px) {
    .product-page__wrapper { grid-template-columns: 1fr; gap: var(--space-2xl, 40px); }
    .product-page__gallery, .product-page__info { padding-left: 0; padding-right: 0; }
  }

  @media (max-width: 768px) {
    .product-page__wrapper {
      overflow: hidden;
    }

    .product-page__gallery {
      display: flex;
      flex-direction: column;
      gap: 16px;
      max-width: 100%;
      overflow: hidden;
    }

    .product-page__main-img-wrap {
      order: 1;
    }

    .product-page__img-actions {
      display: none;
    }

    .product-page__thumbstrip {
      order: 3;
      flex-direction: row;
      overflow-x: auto;
      max-height: none;
      padding: 0 0 10px;
      justify-content: flex-start;
      gap: 10px;
      scrollbar-width: none;
    }
    .product-page__thumbstrip::-webkit-scrollbar { display: none; }

    .product-page__thumb {
      width: 75px;
      height: 75px;
      flex-shrink: 0;
    }

    .product-page__title-row {
      flex-direction: column;
      gap: 8px;
    }

    .product-page__title {
      font-size: 22px;
    }

    .product-page__badge-row {
      flex-shrink: 1;
    }

    .product-page__meta-row {
      flex-wrap: wrap;
      font-size: 11px;
    }

    .product-page__price {
      font-size: 22px;
    }

    .product-page__dual-cta {
      flex-direction: column;
      gap: 12px;
    }
    .product-page__dual-cta form {
      width: 100%;
      flex: none;
    }
  }

  @media (max-width: 768px) {
    .pdp-bp__grid {
      flex-direction: column;
      align-items: center;
      gap: var(--space-2xl, 32px);
    }
    .pdp-bp__heading { font-size: 28px; }
  }

  .product-page__description {
    font-size: 14px;
    line-height: 1.6;
    color: #555;
    margin-bottom: 20px;
  }

  /* Specs Grid in About Tab */
  .product-page__specs-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-top: 20px;
  }

  .product-page__spec-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 12px 16px;
    background: #f9f9f9;
    border-radius: 8px;
    border: 1px solid #eee;
  }

  .product-page__spec-item--full {
    grid-column: 1 / -1;
  }

  .product-page__spec-label {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #999;
  }

  .product-page__spec-value {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-primary, #1a2a3a);
  }

  .product-page__thumb-video-icon {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: rgba(255,255,255,0.8);
    border-radius: 50%;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    color: #000;
  }
  .product-page__thumb-video-icon svg { width: 12px; height: 12px; }
  .product-page__thumb { position: relative; }
  .product-page__video { width: 100%; height: auto; aspect-ratio: 1; border-radius: 12px; }

  /* Video preview with play button overlay */
  .product-page__video-preview {
    position: relative;
    cursor: pointer;
    width: 100%;
    height: 100%;
  }

  .product-page__video-play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 72px;
    height: 72px;
    background: rgba(0, 0, 0, 0.55);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.25s ease;
    z-index: 5;
  }

  .product-page__video-play-btn svg {
    margin-left: 4px;
  }

  .product-page__video-preview:hover .product-page__video-play-btn {
    background: rgba(0, 0, 0, 0.75);
    transform: translate(-50%, -50%) scale(1.1);
  }

  /* Video Popup Modal */
  .video-popup-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.85);
    z-index: 10000;
    align-items: center;
    justify-content: center;
  }

  .video-popup-overlay.is-open {
    display: flex;
  }

  .video-popup {
    position: relative;
    width: 90vw;
    max-width: 900px;
    aspect-ratio: 16 / 9;
    background: #000;
    border-radius: 12px;
    overflow: hidden;
  }

  .video-popup__close {
    position: absolute;
    top: -44px;
    right: 0;
    width: 36px;
    height: 36px;
    background: rgba(255,255,255,0.15);
    border: none;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 10;
    transition: background 0.2s;
  }

  .video-popup__close:hover {
    background: rgba(255,255,255,0.3);
  }

  .video-popup__content {
    width: 100%;
    height: 100%;
  }

  .video-popup__content video,
  .video-popup__content iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  /* ======================== */
  /* Customization Modal      */
  /* ======================== */
  .customize-modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 10000;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }
  .customize-modal-overlay.is-active { display: flex; }

  .customize-modal {
    background: #fff;
    width: 100%;
    max-width: 700px;
    max-height: 90vh;
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    position: relative;
    box-shadow: 0 20px 60px rgba(0,0,0,0.15);
    overflow: hidden;
  }

  .customize-modal__close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    cursor: pointer;
    z-index: 10;
  }

  .customize-modal__header {
    padding: 24px 32px 14px;
    border-bottom: 1px solid #efefef;
  }

  .customize-modal__title {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 16px;
    font-weight: 600;
    margin: 0;
    color: #1a1a1a;
  }

  .customize-modal__body {
    flex: 1;
    overflow-y: auto;
    padding: 24px 32px;
  }

  .customize-step {
    margin-bottom: 32px;
  }

  .customize-step__header {
    font-size: 13px;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .customize-step__num {
    color: #2d4a3e;
    margin-right: 4px;
  }

  .customize-step__reset {
    font-size: 10px;
    font-weight: 700;
    color: #4a6fa5;
    background: none;
    border: none;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .customize-step__link {
    font-size: 10px;
    font-weight: 600;
    color: #4a6fa5;
    text-decoration: underline;
  }

  /* Cards Grid */
  .customize-options--grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .customize-card {
    background: #fff;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    cursor: pointer;
    transition: all 0.2s;
    position: relative;
    width: 100%;
  }

  .customize-card:hover { border-color: #2d4a3e; }
  .customize-card.is-active {
    border-color: #2d4a3e;
    background: #f8faf9;
    border-width: 2px;
  }

  .customize-card__icon {
    width: 48px;
    height: 48px;
    margin-bottom: 12px;
    color: #2d4a3e;
  }

  .customize-card__label {
    font-size: 13px;
    font-weight: 500;
    color: #333;
  }

  .customize-card__check {
    position: absolute;
    top: 8px;
    left: 8px;
    width: 18px;
    height: 18px;
    background: #2d4a3e;
    color: #fff;
    border-radius: 4px;
    display: none;
    align-items: center;
    justify-content: center;
    font-size: 10px;
  }
  .customize-card.is-active .customize-card__check { display: flex; }

  /* Pills */
  .customize-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .customize-pill {
    padding: 7px 16px;
    border: 1px solid #e0e0e0;
    border-radius: 4px;
    background: #f9f9f9;
    font-size: 12px;
    font-weight: 500;
    color: #444;
    cursor: pointer;
    transition: all 0.2s;
    border: 1px solid #e0e0e0;
  }

  .customize-pill:hover { background: #eee; }
  .customize-pill.is-active {
    background: #2d4a3e;
    color: #fff;
    border-color: #2d4a3e;
  }

  .customize-pill--large {
    padding: 8px 12px;
    min-width: 110px;
    text-align: left;
  }

  .customize-pill small {
    display: block;
    font-size: 9px;
    opacity: 0.8;
    margin-top: 1px;
  }

  /* Style Scroller */
  .customize-styles-scroll {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    padding-bottom: 8px;
    scrollbar-width: thin;
  }

  .customize-style-card {
    flex: 0 0 110px;
    background: #fff;
    border: 1px solid #e0e0e0;
    border-radius: 6px;
    padding: 8px;
    cursor: pointer;
    position: relative;
    transition: all 0.2s;
  }

  .customize-style-card:hover { border-color: #2d4a3e; }
  .customize-style-card.is-active {
    border-color: #2d4a3e;
    background: #f8faf9;
    border-width: 2px;
  }

  .customize-style-card__img {
    aspect-ratio: 1;
    background: #f0f0f0;
    border-radius: 4px;
    margin-bottom: 6px;
    overflow: hidden;
  }
  .customize-style-card__img img { width: 100%; height: 100%; object-fit: cover; }

  .customize-style-card__label {
    font-size: 11px;
    text-align: center;
    display: block;
    color: #333;
  }
  .customize-style-card.is-active .customize-card__check { display: flex; }

  /* Footer */
  .customize-modal__footer {
    padding: 0;
  }

  .customize-modal__confirm {
    width: 100%;
    background: #2d4a3e;
    color: #fff;
    border: none;
    padding: 16px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    cursor: pointer;
    transition: background 0.2s;
  }
  .customize-modal__confirm:hover { background: #1f352c; }

  /* Summary Bar in Page */
  .product-page__customize-info {
    background: #f8faf9;
    border: 1px solid #d1dbd6;
    border-radius: 8px;
    padding: 12px 16px;
    margin-bottom: var(--space-lg, 20px);
  }

  .product-page__customize-info-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 4px;
  }

  .product-page__customize-info-label {
    font-size: 10px;
    font-weight: 700;
    color: #2d4a3e;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .product-page__customize-info-details {
    font-size: 12px;
    font-weight: 500;
    color: #333;
  }

  @media (max-width: 768px) {
    .video-popup {
      width: 95vw;
      border-radius: 8px;
    }
    .video-popup__close {
      top: -40px;
    }
    .product-page__video-play-btn {
      width: 56px;
      height: 56px;
    }
    .product-page__video-play-btn svg {
      width: 36px;
      height: 36px;
    }
  }
</style>

<script>
  function setMainMedia(mediaId, btn) {
    document.querySelectorAll('.product-page__media-item').forEach(item => {
      item.style.display = 'none';
      item.classList.remove('is-active');
    });

    const selectedMedia = document.querySelector(`.product-page__media-item[data-media-id="${mediaId}"]`);
    if (selectedMedia) {
      selectedMedia.style.display = 'block';
      selectedMedia.classList.add('is-active');
    }
    document.querySelectorAll('.product-page__thumb').forEach(t => t.classList.remove('product-page__thumb--active'));
    btn.classList.add('product-page__thumb--active');
  }

  function switchTab(tabId, btn) {
    document.querySelectorAll('.product-page__tab-pane').forEach(p => p.classList.remove('product-page__tab-pane--active'));
    document.querySelectorAll('.product-page__tab-btn').forEach(b => b.classList.remove('product-page__tab-btn--active'));
    const pane = document.getElementById('tab-' + tabId);
    if (pane) pane.classList.add('product-page__tab-pane--active');
    btn.classList.add('product-page__tab-btn--active');
  }

  const CustomizeApp = {
    state: {
      type: 'Ring',
      metal: 'Silver',
      purity: '14K',
      size: 'Size 9: 49.0mm',
      style: 'Solitaire'
    },

    init: function() {
      // Sync initial state classes
      Object.keys(this.state).forEach(cat => {
        const val = this.state[cat];
        const el = document.querySelector(`.customize-modal [data-opt="${cat}"][data-val="${val}"]`);
        if (el) el.classList.add('is-active');
      });
    },

    open: function() {
      const modal = document.getElementById('customize-modal');
      if (modal) {
        modal.classList.add('is-active');
        document.body.style.overflow = 'hidden';
        this.init();
      }
    },

    close: function() {
      const modal = document.getElementById('customize-modal');
      if (modal) {
        modal.classList.remove('is-active');
        document.body.style.overflow = '';
      }
    },

    set: function(cat, val, el) {
      this.state[cat] = val;
      // UI update
      const container = el.closest('.customize-step') || el.parentElement;
      const siblings = container.querySelectorAll(`[data-opt="${cat}"]`);
      siblings.forEach(s => s.classList.remove('is-active'));
      el.classList.add('is-active');

      // If Pendants is selected, hide the Size step
      const stepSize = document.getElementById('step-size');
      if (cat === 'type') {
        if (val === 'Pendant') {
          if (stepSize) stepSize.style.display = 'none';
        } else {
          if (stepSize) stepSize.style.display = 'block';
        }
      }
    },

    confirm: function() {
      const summary = `${this.state.type} / ${this.state.metal} / ${this.state.purity}${this.state.type === 'Ring' ? ' / ' + this.state.size : ''} / ${this.state.style}`;
      document.getElementById('customize-summary-text').innerText = summary;
      
      // Update hidden form inputs
      const form = document.querySelector('#cta-customize form');
      if (form) {
        form.querySelector('[name="properties[Jewelry Type]"]').value = this.state.type;
        form.querySelector('[name="properties[Metal]"]').value = this.state.metal;
        form.querySelector('[name="properties[Metal Purity]"]').value = this.state.purity;
        form.querySelector('[name="properties[Ring Size]"]').value = this.state.type === 'Ring' ? this.state.size : 'N/A';
        form.querySelector('[name="properties[Ring Style]"]').value = this.state.style;
      }

      document.getElementById('customize-info-bar').style.display = 'block';
      document.getElementById('cta-default').style.display = 'none';
      document.getElementById('cta-customize').style.display = 'flex';
      
      this.close();
    },

    reset: function() {
      document.getElementById('customize-info-bar').style.display = 'none';
      document.getElementById('cta-default').style.display = 'flex';
      document.getElementById('cta-customize').style.display = 'none';
      this.close();
    }
  };

  // Video Popup
  function openVideoPopup(el) {
    var overlay = document.getElementById('video-popup-overlay');
    var content = document.getElementById('video-popup-content');
    var type = el.getAttribute('data-video-type');

    if (type === 'external') {
      var url = el.getAttribute('data-video-url');
      content.innerHTML = '<iframe src="' + url + '" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe>';
    } else {
      var sourceEl = el.querySelector('.product-page__video-source');
      if (sourceEl) {
        var video = sourceEl.cloneNode(true);
        video.style.display = 'block';
        video.setAttribute('controls', '');
        video.setAttribute('autoplay', '');
        video.setAttribute('loop', '');
        content.innerHTML = '';
        content.appendChild(video);
      }
    }

    overlay.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function closeVideoPopup() {
    var overlay = document.getElementById('video-popup-overlay');
    var content = document.getElementById('video-popup-content');
    overlay.classList.remove('is-open');
    document.body.style.overflow = '';
    // Stop video playback
    setTimeout(function() { content.innerHTML = ''; }, 300);
  }

  function copyToClipboard(text, btn) {
    if (navigator.share) {
      navigator.share({ title: document.title, url: text });
      return;
    }
    const temp = document.createElement('input');
    document.body.appendChild(temp);
    temp.value = text;
    temp.select();
    document.execCommand('copy');
    document.body.removeChild(temp);
    
    const icon = btn.innerHTML;
    btn.innerHTML = '<span style="font-size:10px;font-weight:bold;">COPIED</span>';
    setTimeout(() => { btn.innerHTML = icon; }, 2000);
  }

  // Close on Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeVideoPopup();
  });

  function zoomActiveImage() {
    const activeMedia = document.querySelector('.product-page__media-item.is-active img');
    if (activeMedia) {
      if (activeMedia.requestFullscreen) {
        activeMedia.requestFullscreen();
      } else if (activeMedia.webkitRequestFullscreen) {
        activeMedia.webkitRequestFullscreen();
      } else if (activeMedia.msRequestFullscreen) {
        activeMedia.msRequestFullscreen();
      }
    }
  }

  // Amazon-style Image Zoom (desktop only)
  (function() {
    if (window.innerWidth <= 992) return;

    var wrap = document.querySelector('.product-page__main-img-wrap');
    var lens = document.getElementById('zoom-lens');
    var result = document.getElementById('zoom-result');
    if (!wrap || !lens || !result) return;

    var LENS_W = 200, LENS_H = 200;

    function getActiveImg() {
      return wrap.querySelector('.product-page__media-item.is-active .product-page__main-img');
    }

    wrap.addEventListener('mouseenter', function() {
      var img = getActiveImg();
      if (!img) return;
      var zoomSrc = img.getAttribute('data-zoom-src') || img.src;
      // Preload high-res image
      var preload = new Image();
      preload.src = zoomSrc;
      result.style.backgroundImage = 'url(' + zoomSrc + ')';
    });

    wrap.addEventListener('mousemove', function(e) {
      var img = getActiveImg();
      if (!img) return;

      var rect = img.getBoundingClientRect();
      var wrapRect = wrap.getBoundingClientRect();
      var x = e.clientX - rect.left;
      var y = e.clientY - rect.top;

      if (x < 0 || y < 0 || x > rect.width || y > rect.height) {
        lens.style.display = 'none';
        result.style.display = 'none';
        return;
      }

      lens.style.display = 'block';
      result.style.display = 'block';

      // Clamp lens so it stays within the image
      var lensX = Math.max(0, Math.min(x - LENS_W / 2, rect.width - LENS_W));
      var lensY = Math.max(0, Math.min(y - LENS_H / 2, rect.height - LENS_H));

      // Position lens relative to wrap
      lens.style.left = (lensX + rect.left - wrapRect.left) + 'px';
      lens.style.top = (lensY + rect.top - wrapRect.top) + 'px';

      // Result panel dimensions
      var resultRect = result.getBoundingClientRect();
      var RESULT_W = resultRect.width;
      var RESULT_H = resultRect.height;

      // Zoom ratio: how much bigger the result is than the lens
      var ratioX = RESULT_W / LENS_W;
      var ratioY = RESULT_H / LENS_H;

      // Background = full image scaled up by ratio
      result.style.backgroundSize = (rect.width * ratioX) + 'px ' + (rect.height * ratioY) + 'px';
      result.style.backgroundPosition = '-' + (lensX * ratioX) + 'px -' + (lensY * ratioY) + 'px';
    });

    wrap.addEventListener('mouseleave', function() {
      lens.style.display = 'none';
      result.style.display = 'none';
    });
  })();

</script>

{% schema %}
{
  "name": "Product Page",
  "settings": [
    {
      "type": "image_picker",
      "id": "cert_logo",
      "label": "Certification Logo (overlaid on product image)"
    },
    {
      "type": "text",
      "id": "default_pincode",
      "label": "Default Pincode",
      "default": "110001"
    }
  ],
  "presets": [
    {
      "name": "Product Page"
    }
  ]
}
{% endschema %}
