<script>
  function setMainMedia(mediaId, btn) {
    document.querySelectorAll('.product-page__media-item').forEach(item => {
      item.style.display = 'none';
      item.classList.remove('is-active');
      // Pause any playing videos
      const video = item.querySelector('video');
      if (video) video.pause();
      const iframe = item.querySelector('iframe');
      if (iframe) {
        const src = iframe.src;
        iframe.src = src; // Resetting src stops the video
      }
    });

    const selectedMedia = document.querySelector(`.product-page__media-item[data-media-id="${mediaId}"]`);
    if (selectedMedia) {
      selectedMedia.style.display = 'block';
      selectedMedia.classList.add('is-active');
    }
    document.querySelectorAll('.product-page__thumb').forEach(t => t.classList.remove('product-page__thumb--active'));
    btn.classList.add('product-page__thumb--active');
  }

  function switchTab(tabId, btn) {
    document.querySelectorAll('.product-page__tab-pane').forEach(p => p.classList.remove('product-page__tab-pane--active'));
    document.querySelectorAll('.product-page__tab-btn').forEach(b => b.classList.remove('product-page__tab-btn--active'));
    const pane = document.getElementById('tab-' + tabId);
    if (pane) pane.classList.add('product-page__tab-pane--active');
    btn.classList.add('product-page__tab-btn--active');
  }

  function showCustomize() {
    document.getElementById('customize-panel').style.display = 'block';
    document.getElementById('cta-default').style.display = 'none';
    document.getElementById('cta-customize').style.display = 'flex';
    document.getElementById('price-update-badge').style.display = 'inline-flex';
  }

  function resetCustomize() {
    document.getElementById('customize-panel').style.display = 'none';
    document.getElementById('cta-default').style.display = 'flex';
    document.getElementById('cta-customize').style.display = 'none';
    document.getElementById('price-update-badge').style.display = 'none';
  }

  // Amazon-style Image Zoom (desktop only)
  (function() {
    if (window.innerWidth <= 992) return;

    var wrap = document.querySelector('.product-page__main-img-wrap');
    var lens = document.getElementById('zoom-lens');
    var result = document.getElementById('zoom-result');
    if (!wrap || !lens || !result) return;

    var LENS_W = 200, LENS_H = 200;
    var RESULT_W = 500, RESULT_H = 500;

    function getActiveImg() {
      var active = wrap.querySelector('.product-page__media-item.is-active .product-page__main-img');
      return active;
    }

    wrap.addEventListener('mouseenter', function() {
      var img = getActiveImg();
      if (!img) return;
      var zoomSrc = img.getAttribute('data-zoom-src') || img.src;
      result.style.backgroundImage = 'url(' + zoomSrc + ')';
    });

    wrap.addEventListener('mousemove', function(e) {
      var img = getActiveImg();
      if (!img) return;

      var rect = img.getBoundingClientRect();
      var x = e.clientX - rect.left;
      var y = e.clientY - rect.top;

      if (x < 0 || y < 0 || x > rect.width || y > rect.height) {
        lens.style.display = 'none';
        result.style.display = 'none';
        return;
      }

      lens.style.display = 'block';
      result.style.display = 'block';

      // Clamp lens position
      var lensX = Math.max(0, Math.min(x - LENS_W / 2, rect.width - LENS_W));
      var lensY = Math.max(0, Math.min(y - LENS_H / 2, rect.height - LENS_H));

      lens.style.left = (lensX + (rect.left - wrap.getBoundingClientRect().left)) + 'px';
      lens.style.top = (lensY + (rect.top - wrap.getBoundingClientRect().top)) + 'px';

      // Calculate zoom ratio
      var ratioX = RESULT_W / LENS_W;
      var ratioY = RESULT_H / LENS_H;

      result.style.backgroundSize = (rect.width * ratioX) + 'px ' + (rect.height * ratioY) + 'px';
      result.style.backgroundPosition = '-' + (lensX * ratioX) + 'px -' + (lensY * ratioY) + 'px';
    });

    wrap.addEventListener('mouseleave', function() {
      lens.style.display = 'none';
      result.style.display = 'none';
    });
  })();

</script>

