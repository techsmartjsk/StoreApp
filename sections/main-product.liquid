  /* Certification Summary */
  .product-page__cert-summary {
    margin-top: 24px;
    padding: 20px;
    background: #fcfcfc;
    border: 1px solid #eee;
    border-radius: 8px;
  }
  .product-page__cert-field {
    margin-bottom: 12px;
  }
  .product-page__cert-label {
    display: block;
    font-size: 11px;
    color: #777;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 4px;
  }
  .product-page__cert-val {
    font-size: 15px;
    font-weight: 600;
    color: #1a1a1a;
  }
  .product-page__cert-verify {
    display: inline-block;
    margin-top: 8px;
    font-size: 13px;
    color: #2d4a3e;
    text-decoration: underline;
    font-weight: 600;
  }

  .product-page__thumb-video-icon {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: rgba(255,255,255,0.8);
    border-radius: 50%;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    color: #000;
  }
  .product-page__thumb-video-icon svg { width: 12px; height: 12px; }
  .product-page__thumb { position: relative; }
  .product-page__video { width: 100%; height: auto; aspect-ratio: 1; border-radius: 12px; }

  /* Video preview with play button overlay */
  .product-page__video-preview {
    position: relative;
    cursor: pointer;
    width: 100%;
    height: 100%;
  }

  .product-page__video-play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 72px;
    height: 72px;
    background: rgba(0, 0, 0, 0.55);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.25s ease;
    z-index: 5;
  }

  .product-page__video-play-btn svg {
    margin-left: 4px;
  }

  .product-page__video-preview:hover .product-page__video-play-btn {
    background: rgba(0, 0, 0, 0.75);
    transform: translate(-50%, -50%) scale(1.1);
  }

  /* Video Popup Modal */
  .video-popup-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.85);
    z-index: 10000;
    align-items: center;
    justify-content: center;
  }

  .video-popup-overlay.is-open {
    display: flex;
  }

  .video-popup {
    position: relative;
    width: 90vw;
    max-width: 900px;
    aspect-ratio: 16 / 9;
    background: #000;
    border-radius: 12px;
    overflow: hidden;
  }

  .video-popup__close {
    position: absolute;
    top: -44px;
    right: 0;
    width: 36px;
    height: 36px;
    background: rgba(255,255,255,0.15);
    border: none;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 10;
    transition: background 0.2s;
  }

  .video-popup__close:hover {
    background: rgba(255,255,255,0.3);
  }

  .video-popup__content {
    width: 100%;
    height: 100%;
  }

  .video-popup__content video,
  .video-popup__content iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  /* ======================== */
  /* Customization Modal      */
  /* ======================== */
  .customize-modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 10000;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }
  .customize-modal-overlay.is-active { display: flex; }

  .customize-modal {
    background: #fff;
    width: 100%;
    max-width: 700px;
    max-height: 90vh;
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    position: relative;
    box-shadow: 0 20px 60px rgba(0,0,0,0.15);
    overflow: hidden;
  }

  .customize-modal__close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    cursor: pointer;
    z-index: 10;
  }

  .customize-modal__header {
    padding: 24px 32px 14px;
    border-bottom: 1px solid #efefef;
  }

  .customize-modal__title {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 16px;
    font-weight: 600;
    margin: 0;
    color: #1a1a1a;
  }

  .customize-modal__body {
    flex: 1;
    overflow-y: auto;
    padding: 24px 32px;
  }

  .customize-step {
    margin-bottom: 32px;
  }

  .customize-step__header {
    font-size: 13px;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .customize-step__num {
    color: #2d4a3e;
    margin-right: 4px;
  }

  .customize-step__reset {
    font-size: 10px;
    font-weight: 700;
    color: #4a6fa5;
    background: none;
    border: none;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .customize-step__link {
    font-size: 10px;
    font-weight: 600;
    color: #4a6fa5;
    text-decoration: underline;
  }

  /* Cards Grid */
  .customize-options--grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .customize-card {
    background: #fff;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    cursor: pointer;
    transition: all 0.2s;
    position: relative;
    width: 100%;
  }

  .customize-card:hover { border-color: #2d4a3e; }
  .customize-card.is-active {
    border-color: #2d4a3e;
    background: #f8faf9;
    border-width: 2px;
  }

  .customize-card__icon {
    width: 48px;
    height: 48px;
    margin-bottom: 12px;
    color: #2d4a3e;
  }

  .customize-card__label {
    font-size: 13px;
    font-weight: 500;
    color: #333;
  }

  .customize-card__check {
    position: absolute;
    top: 8px;
    left: 8px;
    width: 18px;
    height: 18px;
    background: #2d4a3e;
    color: #fff;
    border-radius: 4px;
    display: none;
    align-items: center;
    justify-content: center;
    font-size: 10px;
  }
  .customize-card.is-active .customize-card__check { display: flex; }

  /* Pills */
  .customize-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .customize-pill {
    padding: 7px 16px;
    border: 1px solid #e0e0e0;
    border-radius: 4px;
    background: #f9f9f9;
    font-size: 12px;
    font-weight: 500;
    color: #444;
    cursor: pointer;
    transition: all 0.2s;
    border: 1px solid #e0e0e0;
  }

  .customize-pill:hover { background: #eee; }
  .customize-pill.is-active {
    background: #2d4a3e;
    color: #fff;
    border-color: #2d4a3e;
  }

  .customize-pill--large {
    padding: 8px 12px;
    min-width: 110px;
    text-align: left;
  }

  .customize-pill small {
    display: block;
    font-size: 9px;
    opacity: 0.8;
    margin-top: 1px;
  }

  /* Style Scroller */
  .customize-styles-scroll {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    padding-bottom: 8px;
    scrollbar-width: thin;
  }

  .customize-style-card {
    flex: 0 0 110px;
    background: #fff;
    border: 1px solid #e0e0e0;
    border-radius: 6px;
    padding: 8px;
    cursor: pointer;
    position: relative;
    transition: all 0.2s;
  }

  .customize-style-card:hover { border-color: #2d4a3e; }
  .customize-style-card.is-active {
    border-color: #2d4a3e;
    background: #f8faf9;
    border-width: 2px;
  }

  .customize-style-card__img {
    aspect-ratio: 1;
    background: #f0f0f0;
    border-radius: 4px;
    margin-bottom: 6px;
    overflow: hidden;
  }
  .customize-style-card__img img { width: 100%; height: 100%; object-fit: cover; }

  .customize-style-card__label {
    font-size: 11px;
    text-align: center;
    display: block;
    color: #333;
  }
  .customize-style-card.is-active .customize-card__check { display: flex; }

  /* Footer */
  .customize-modal__footer {
    padding: 0;
  }

  .customize-modal__confirm {
    width: 100%;
    background: #2d4a3e;
    color: #fff;
    border: none;
    padding: 16px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    cursor: pointer;
    transition: background 0.2s;
  }
  .customize-modal__confirm:hover { background: #1f352c; }

  /* Summary Bar in Page */
  .product-page__customize-info {
    background: #f8faf9;
    border: 1px solid #d1dbd6;
    border-radius: 8px;
    padding: 12px 16px;
    margin-bottom: var(--space-lg, 20px);
  }

  .product-page__customize-info-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 4px;
  }

  .product-page__customize-info-label {
    font-size: 10px;
    font-weight: 700;
    color: #2d4a3e;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .product-page__customize-info-details {
    font-size: 12px;
    font-weight: 500;
    color: #333;
  }

  @media (max-width: 768px) {
    .video-popup {
      width: 95vw;
      border-radius: 8px;
    }
    .video-popup__close {
      top: -40px;
    }
    .product-page__video-play-btn {
      width: 56px;
      height: 56px;
    }
    .product-page__video-play-btn svg {
      width: 36px;
      height: 36px;
    }
  }
  .product-recs__none {
    grid-column: 1 / -1;
    text-align: center;
    padding: 40px 0;
    color: #666;
    font-size: 14px;
    font-family: var(--font-body);
    background: #fdfaf5;
    border-radius: 8px;
    margin-top: 20px;
  }
</style>

<script>
  function setMainMedia(mediaId, btn) {
    document.querySelectorAll('.product-page__media-item').forEach(item => {
      item.style.display = 'none';
      item.classList.remove('is-active');
    });

    const selectedMedia = document.querySelector(`.product-page__media-item[data-media-id="${mediaId}"]`);
    if (selectedMedia) {
      selectedMedia.style.display = 'block';
      selectedMedia.classList.add('is-active');
    }
    document.querySelectorAll('.product-page__thumb').forEach(t => t.classList.remove('product-page__thumb--active'));
    btn.classList.add('product-page__thumb--active');
  }

  function switchTab(tabId, btn) {
    document.querySelectorAll('.product-page__tab-pane').forEach(p => p.classList.remove('product-page__tab-pane--active'));
    document.querySelectorAll('.product-page__tab-btn').forEach(b => b.classList.remove('product-page__tab-btn--active'));
    const pane = document.getElementById('tab-' + tabId);
    if (pane) pane.classList.add('product-page__tab-pane--active');
    btn.classList.add('product-page__tab-btn--active');
  }

  function updateCertFee(select) {
    const option = select.options[select.selectedIndex];
    const feeInPaise = parseInt(option.getAttribute('data-fee')) || 0;
    const note = document.getElementById('cert-fee-note-{{ section.id }}');
    
    if (feeInPaise > 0) {
      const feeFormatted = (feeInPaise / 100).toLocaleString('en-IN', {
        style: 'currency',
        currency: 'INR',
        minimumFractionDigits: 0
      });
      note.textContent = `+ ${feeFormatted} Certification Fee`;
      note.style.display = 'block';
    } else {
      note.style.display = 'none';
      note.textContent = '';
    }
    
    // Update global state for price calculation
    CustomizeApp.state.certFee = feeInPaise;
    CustomizeApp.updateTotalPrice();
  }

  // Intercept Add to Cart to include Certification properties and parallel items
  document.addEventListener('DOMContentLoaded', function() {
    const productForms = document.querySelectorAll('form[action^="/cart/add"]');
    
    productForms.forEach(form => {
      form.addEventListener('submit', function(e) {
        const certSelect = document.getElementById('CertificationField-{{ section.id }}');
        const certVal = certSelect ? certSelect.value : 'None';
        
        // Parallel Add Logic
        if (e.cancelable) e.preventDefault();
        const itemsToCart = [];
        
        // 1. Gemstone Product
        const variantIdInput = form.querySelector('[name="id"]');
        if (!variantIdInput) return;

        itemsToCart.push({
          id: variantIdInput.value,
          quantity: 1,
          properties: {
            {% if product.metafields.custom.weight_carat != blank or product.metafields.custom.weight_carats != blank %}
            'Weight': '{{ product.metafields.custom.weight_carat | default: product.metafields.custom.weight_carats | escape }} Carat',
            {% elsif product.metafields.custom.weight_ratti != blank %}
            'Weight (Ratti)': '{{ product.metafields.custom.weight_ratti | escape }} Ratti',
            {% endif %}
            'Origin': '{{ product.metafields.custom.origin | default: "Ceylon / Sri Lanka" | escape }}',
            'Gem Type': '{{ product.metafields.custom.gem_type | default: product.type | escape }}',
            'Certification': certVal,
            '_certification_lab': '{{ product.metafields.custom.certification_lab | escape }}',
            'Shape / Cut': '{{ product.metafields.custom.shape_cut | escape }}',
            'Treatment': '{{ product.metafields.custom.treatment_status | escape }}',
            'Jewelry Type': CustomizeApp.state.type || 'None',
            'Metal': CustomizeApp.state.metal || 'None',
            'Style': CustomizeApp.state.style || 'None',
            '_customization_fee_raw': CustomizeApp.state.certFee + CustomizeApp.state.metalFee + CustomizeApp.state.styleFee,
            '_master_id': Date.now()
          }
        });

        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: itemsToCart })
        })
        .then(res => res.json())
        .then(() => {
          const btn = form.querySelector('button[type="submit"]');
          if (btn) {
            const originalText = btn.innerHTML;
            btn.innerHTML = '✓ ADDED TO CART';
            btn.style.backgroundColor = '#27ae60';
            setTimeout(() => {
              btn.innerHTML = originalText;
              btn.style.backgroundColor = '';
              window.location.href = '/cart';
            }, 1000);
          } else {
            window.location.href = '/cart';
          }
        })
        .catch(err => {
          console.error("Cart Error:", err);
          form.submit();
        });
      });
    });
  });

  const CustomizeApp = {
    basePrice: {{ product.price }},
    state: {
      type: 'Ring',
      metal: 'Panchdhatu (Brass)',
      style: 'None',
      certFee: 0,
      metalFee: 0,
      styleFee: 0
    },

    init: function() {
      // Sync initial state classes
      Object.keys(this.state).forEach(cat => {
        const val = this.state[cat];
        const el = document.querySelector(`.customize-modal [data-opt="${cat}"][data-val="${val}"]`);
        if (el) el.classList.add('is-active');
      });
      this.updateTotalPrice();
    },

    open: function() {
      const modal = document.getElementById('customize-modal');
      if (modal) {
        modal.classList.add('is-active');
        document.body.style.overflow = 'hidden';
        this.init();
      }
    },

    close: function() {
      const modal = document.getElementById('customize-modal');
      if (modal) {
        modal.classList.remove('is-active');
        document.body.style.overflow = '';
      }
    },

    set: function(cat, val, el, fee = 0) {
      this.state[cat] = val;
      if (cat === 'metal') this.state.metalFee = parseInt(fee) || 0;
      if (cat === 'style') this.state.styleFee = parseInt(fee) || 0;

      // UI update
      const container = el.closest('.customize-step') || el.parentElement;
      const siblings = container.querySelectorAll(`[data-opt="${cat}"]`);
      siblings.forEach(s => s.classList.remove('is-active'));
      el.classList.add('is-active');

      if (cat === 'type') {
        const typeText = document.getElementById('selected-type-text');
        if (typeText) typeText.innerText = val.toUpperCase();
      }

      this.updateTotalPrice();
    },

    resetStep: function(cat) {
      const siblings = document.querySelectorAll(`.customize-modal [data-opt="${cat}"]`);
      siblings.forEach(s => s.classList.remove('is-active'));
      this.state[cat] = 'None';
      if (cat === 'metal') this.state.metalFee = 0;
      if (cat === 'style') this.state.styleFee = 0;
      this.updateTotalPrice();
    },

    updateTotalPrice: function() {
      const totalPaise = this.basePrice + this.state.certFee + this.state.metalFee + this.state.styleFee;
      const formattedPrice = (totalPaise / 100).toLocaleString('en-IN', {
        style: 'currency',
        currency: 'INR',
        minimumFractionDigits: 0
      });

      const priceElements = document.querySelectorAll('.product-page__price');
      priceElements.forEach(el => {
        el.innerText = formattedPrice;
      });

      // Show update badge if price increased
      const badge = document.getElementById('price-update-badge');
      if (badge) {
        badge.style.display = (totalPaise > this.basePrice) ? 'inline-block' : 'none';
      }
    },

    confirm: function() {
      let summary = this.state.type;
      if (this.state.metal && this.state.metal !== 'None') summary += ` / ${this.state.metal}`;
      if (this.state.style && this.state.style !== 'None') summary += ` / ${this.state.style}`;
      
      document.getElementById('customize-summary-text').innerText = summary;
      
      // Update hidden form inputs for properties
      const forms = document.querySelectorAll('form[action^="/cart/add"]');
      forms.forEach(form => {
        this.setHiddenProperty(form, 'Jewelry Type', this.state.type);
        this.setHiddenProperty(form, 'Metal', this.state.metal);
        this.setHiddenProperty(form, 'Style', this.state.style);
        
        // Add total customization fee as a visible property
        const totalFee = (this.state.metalFee + this.state.styleFee + this.state.certFee) / 100;
        this.setHiddenProperty(form, 'Customization Fee', 'Rs. ' + totalFee.toLocaleString('en-IN'));
        this.setHiddenProperty(form, '_customization_fee_raw', this.state.metalFee + this.state.styleFee + this.state.certFee);
      });

      document.getElementById('customize-info-bar').style.display = 'block';
      document.getElementById('cta-default').style.display = 'none';
      document.getElementById('cta-customize').style.display = 'flex';
      
      this.close();
    },

    setHiddenProperty: function(form, name, value) {
      let input = form.querySelector(`input[name="properties[${name}]"]`);
      if (!input) {
        input = document.createElement('input');
        input.type = 'hidden';
        input.name = `properties[${name}]`;
        form.appendChild(input);
      }
      input.value = value;
    },

    reset: function() {
      this.state.metal = 'Panchdhatu (Brass)';
      this.state.style = 'None';
      this.state.metalFee = 0;
      this.state.styleFee = 0;
      
      document.getElementById('customize-info-bar').style.display = 'none';
      document.getElementById('cta-default').style.display = 'flex';
      document.getElementById('cta-customize').style.display = 'none';
      
      this.updateTotalPrice();
      this.close();
    }
  };

  // Video Popup
  function openVideoPopup(el) {
    var overlay = document.getElementById('video-popup-overlay');
    var content = document.getElementById('video-popup-content');
    var type = el.getAttribute('data-video-type');

    if (type === 'external') {
      var url = el.getAttribute('data-video-url');
      content.innerHTML = '<iframe src="' + url + '" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe>';
    } else {
      var sourceEl = el.querySelector('.product-page__video-source');
      if (sourceEl) {
        var video = sourceEl.cloneNode(true);
        video.style.display = 'block';
        video.setAttribute('controls', '');
        video.setAttribute('autoplay', '');
        video.setAttribute('loop', '');
        content.innerHTML = '';
        content.appendChild(video);
      }
    }

    overlay.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function closeVideoPopup() {
    var overlay = document.getElementById('video-popup-overlay');
    var content = document.getElementById('video-popup-content');
    overlay.classList.remove('is-open');
    document.body.style.overflow = '';
    // Stop video playback
    setTimeout(function() { content.innerHTML = ''; }, 300);
  }

  function copyToClipboard(text, btn) {
    if (navigator.share) {
      navigator.share({ title: document.title, url: text });
      return;
    }
    const temp = document.createElement('input');
    document.body.appendChild(temp);
    temp.value = text;
    temp.select();
    document.execCommand('copy');
    document.body.removeChild(temp);
    
    const icon = btn.innerHTML;
    btn.innerHTML = '<span style="font-size:10px;font-weight:bold;">COPIED</span>';
    setTimeout(() => { btn.innerHTML = icon; }, 2000);
  }

  // Close on Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeVideoPopup();
  });

  function zoomActiveImage() {
    const activeMedia = document.querySelector('.product-page__media-item.is-active img');
    if (activeMedia) {
      if (activeMedia.requestFullscreen) {
        activeMedia.requestFullscreen();
      } else if (activeMedia.webkitRequestFullscreen) {
        activeMedia.webkitRequestFullscreen();
      } else if (activeMedia.msRequestFullscreen) {
        activeMedia.msRequestFullscreen();
      }
    }
  }

  // Amazon-style Image Zoom (desktop only)
  (function() {
    if (window.innerWidth <= 992) return;

    var wrap = document.querySelector('.product-page__main-img-wrap');
    var lens = document.getElementById('zoom-lens');
    var result = document.getElementById('zoom-result');
    if (!wrap || !lens || !result) return;

    var LENS_W = 200, LENS_H = 200;

    function getActiveImg() {
      return wrap.querySelector('.product-page__media-item.is-active .product-page__main-img');
    }

    wrap.addEventListener('mouseenter', function() {
      var img = getActiveImg();
      if (!img) return;
      var zoomSrc = img.getAttribute('data-zoom-src') || img.src;
      // Preload high-res image
      var preload = new Image();
      preload.src = zoomSrc;
      result.style.backgroundImage = 'url(' + zoomSrc + ')';
    });

    wrap.addEventListener('mousemove', function(e) {
      var img = getActiveImg();
      if (!img) return;

      var rect = img.getBoundingClientRect();
      var wrapRect = wrap.getBoundingClientRect();
      var x = e.clientX - rect.left;
      var y = e.clientY - rect.top;

      if (x < 0 || y < 0 || x > rect.width || y > rect.height) {
        lens.style.display = 'none';
        result.style.display = 'none';
        return;
      }

      lens.style.display = 'block';
      result.style.display = 'block';

      // Clamp lens so it stays within the image
      var lensX = Math.max(0, Math.min(x - LENS_W / 2, rect.width - LENS_W));
      var lensY = Math.max(0, Math.min(y - LENS_H / 2, rect.height - LENS_H));

      // Position lens relative to wrap
      lens.style.left = (lensX + rect.left - wrapRect.left) + 'px';
      lens.style.top = (lensY + rect.top - wrapRect.top) + 'px';

      // Result panel dimensions
      var resultRect = result.getBoundingClientRect();
      var RESULT_W = resultRect.width;
      var RESULT_H = resultRect.height;

      // Zoom ratio: how much bigger the result is than the lens
      var ratioX = RESULT_W / LENS_W;
      var ratioY = RESULT_H / LENS_H;

      // Background = full image scaled up by ratio
      result.style.backgroundSize = (rect.width * ratioX) + 'px ' + (rect.height * ratioY) + 'px';
      result.style.backgroundPosition = '-' + (lensX * ratioX) + 'px -' + (lensY * ratioY) + 'px';
    });

    wrap.addEventListener('mouseleave', function() {
      lens.style.display = 'none';
      result.style.display = 'none';
    });
  })();

</script>

