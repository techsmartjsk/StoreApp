{%- comment -%}Main Product Section{%- endcomment -%}

{%- assign current_variant = product.selected_or_first_available_variant -%}

{%- comment -%} Removed the top breadcrumb to move it closer to the image {%- endcomment -%}

<section class="product-page" id="product-{{ product.id }}">
  <div class="page-width">
    <!-- Breadcrumb moved here -->
    <nav class="breadcrumb breadcrumb--pdp" aria-label="breadcrumb">
      <a href="/">Home</a>
      <span class="breadcrumb__sep">›</span>
      {%- if product.collections.first -%}
        <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a>
        <span class="breadcrumb__sep">›</span>
      {%- endif -%}
      <a href="{{ product.url }}">{{ product.title }}</a>
    </nav>

    <div class="product-page__wrapper">

      <!-- Gallery -->
      <div class="product-page__gallery">

        <!-- Vertical thumbnail strip -->
        <div class="product-page__thumbstrip">
          {%- for media in product.media -%}
            <button
              class="product-page__thumb{% if forloop.first %} product-page__thumb--active{% endif %}"
              onclick="setMainMedia('{{ media.id }}', this)"
              aria-label="View {{ media.media_type | replace: '_', ' ' }} {{ forloop.index }}"
              data-media-id="{{ media.id }}"
            >
              {%- if media.media_type contains 'video' -%}
                <div class="product-page__thumb-video-icon">
                  {% render 'icon', name: 'play' %}
                </div>
              {%- endif -%}
              <img
                src="{{ media.preview_image | image_url: width: 120 }}"
                alt="{{ media.alt | default: product.title | escape }}"
                loading="lazy"
              >
            </button>
          {%- endfor -%}
        </div>

        <!-- Action icons (between thumbs and image) -->
        <div class="product-page__img-actions">
          <button class="product-page__img-action-btn" aria-label="Share" onclick="navigator.share ? navigator.share({title:'{{ product.title | escape }}',url:window.location.href}) : null">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          </button>
          <button class="product-page__img-action-btn" aria-label="Wishlist">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </button>
          <button class="product-page__img-action-btn" aria-label="Zoom" onclick="document.getElementById('main-product-image').requestFullscreen ? document.getElementById('main-product-image').requestFullscreen() : null">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>
          </button>
        </div>

        <!-- Main image -->
        <div class="product-page__main-img-wrap">
          <!-- Certification logos overlaid on image -->
          <div class="product-page__cert-logos">
            {%- if section.settings.cert_logo != blank -%}
              <img src="{{ section.settings.cert_logo | image_url: width: 160 }}" alt="Certification" class="product-page__cert-logo product-page__cert-logo--left">
            {%- endif -%}
            <img src="{{ 'brand-logo.svg' | asset_url }}" alt="{{ shop.name }}" class="product-page__cert-logo product-page__cert-logo--right">
          </div>

          <!-- Zoom highlight lens -->
          <div class="product-page__zoom-lens" id="zoom-lens"></div>
          <!-- Zoom result panel (Amazon-style) -->
          <div class="product-page__zoom-result" id="zoom-result"></div>

          <div id="product-page-media-container">
            {%- if product.featured_media -%}
              {%- for media in product.media -%}
                <div class="product-page__media-item {% if media.id == product.featured_media.id %}is-active{% endif %}" data-media-id="{{ media.id }}" style="display: {% if media.id == product.featured_media.id %}block{% else %}none{% endif %};">
                  {%- case media.media_type -%}
                    {%- when 'image' -%}
                      <img
                        src="{{ media | image_url: width: 1000 }}"
                        data-zoom-src="{{ media | image_url: width: 2000 }}"
                        alt="{{ media.alt | default: product.title | escape }}"
                        class="product-page__main-img"
                        id="main-product-image-{{ media.id }}"
                      >
                    {%- when 'external_video' -%}
                      {{ media | external_video_tag: class: 'product-page__video', loading: "lazy" }}
                    {%- when 'video' -%}
                      {{ media | video_tag: class: 'product-page__video', controls: true, loop: true, loading: "lazy" }}
                  {%- endcase -%}
                </div>
              {%- endfor -%}
            {%- else -%}
              <div class="product-page__img-placeholder">
                <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>

      <!-- Product Info -->
      <div class="product-page__info">

        <!-- Vendor -->
        {%- if product.vendor -%}
          <p class="product-page__vendor">{{ product.vendor }}</p>
        {%- endif -%}

        <!-- Title + badges row -->
        <div class="product-page__title-row">
          <h1 class="product-page__title">{{ product.title }}</h1>
          <div class="product-page__badge-row">
            <span class="product-page__shipping-badge">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              shipping available in India
            </span>
            <span class="product-page__avail-badge {% if product.available %}product-page__avail-badge--in{% else %}product-page__avail-badge--out{% endif %}">
              {% if product.available %}Available{% else %}Sold Out{% endif %}
            </span>
          </div>
        </div>

        <!-- SKU / Origin / Reviews -->
        <div class="product-page__meta-row">
          <span>SKU: {{ current_variant.sku | default: '87587' }}</span>
          <span class="product-page__meta-sep">|</span>
          <span>Origin: {{ product.metafields.gem.origin | default: 'Sri Lanka' }}</span>
          <span class="product-page__meta-sep">|</span>
          <span class="product-page__reviews-inline">
            Reviews ({{ product.metafields.reviews.rating_count | default: '23' }})
            <span class="product-page__stars">★★★★★</span>
          </span>
        </div>

        <div class="product-page__divider"></div>

        <!-- Price -->
        <div class="product-page__price-row">
          <span class="product-page__price">{{ current_variant.price | money }}</span>
          {%- if product.compare_at_price > product.price -%}
            <span class="product-page__compare-price">{{ product.compare_at_price | money }}</span>
          {%- endif -%}
          <span class="product-page__price-note">(MRP incl. of all taxes)</span>
          <span class="product-page__price-update-badge" id="price-update-badge" style="display:none;">● PRICE UPDATE</span>
        </div>

        <div class="product-page__divider"></div>

        <!-- Tabs -->
        <div class="product-page__tabs">
          <div class="product-page__tab-nav" role="tablist">
            <button class="product-page__tab-btn product-page__tab-btn--active" onclick="switchTab('about', this)" role="tab">About this Gem</button>
            <button class="product-page__tab-btn" onclick="switchTab('treatment', this)" role="tab">Treatment & Certification</button>
            <button class="product-page__tab-btn" onclick="switchTab('planetary', this)" role="tab">Planetary Alignment</button>
          </div>
          <div class="product-page__tab-pane product-page__tab-pane--active" id="tab-about">
            {%- if product.description != blank -%}
              {{ product.description }}
            {%- else -%}
              <h4 class="product-page__tab-heading">Blue Sapphire</h4>
              <p>Welcome to our world of Blue Sapphires — steady, sacred, and unshaken. Each gem here is selected not just for its natural beauty, but for its power to ground, clarify, and protect. We invite you to explore slowly. Let belief, not urgency, guide your choice.</p>
              <p style="margin-top:10px;"><strong>Description</strong></p>
              <ul class="product-page__tab-list">
                <li>Weight Carat : 0.38</li>
                <li>Weight Ratti : 0.42</li>
                <li>Shape : Octagon</li>
                <li>Cut : Faceted</li>
                <li>Composition : Natural</li>
                <li>Certificate Number : S382185331...</li>
              </ul>
            {%- endif -%}
            <a href="#" class="product-page__read-more">Read More</a>
          </div>
          <div class="product-page__tab-pane" id="tab-treatment">
            {%- if product.metafields.gem.treatment != blank -%}
              {{ product.metafields.gem.treatment }}
            {%- else -%}
              <h4 class="product-page__tab-heading">Treatment & Certification</h4>
              <p>This Blue Sapphire (Neelam) is a 100% natural, unheated gemstone with no artificial enhancements. It has been carefully examined and certified by a reputed gemological laboratory.</p>
              <p style="margin-top:10px;"><strong>Details</strong></p>
              <ul class="product-page__tab-list">
                <li>Treatment : Unheated / No Treatment</li>
                <li>Certification Lab : ITLGR (International Testing Laboratory for Gemstones Research)</li>
                <li>Certificate No : S382185331</li>
                <li>Transparency : Transparent</li>
                <li>Lustre : Vitreous</li>
                <li>Comment : Natural inclusions present, consistent with origin</li>
              </ul>
            {%- endif -%}
            <a href="#" class="product-page__read-more">Read More</a>
          </div>
          <div class="product-page__tab-pane" id="tab-planetary">
            {%- if product.metafields.gem.planetary != blank -%}
              {{ product.metafields.gem.planetary }}
            {%- else -%}
              <h4 class="product-page__tab-heading">Planetary Alignment</h4>
              <p>Blue Sapphire is associated with the planet Saturn (Shani). It is one of the most powerful gemstones in Vedic astrology, known for its ability to bring rapid results — both positive and transformative.</p>
              <p style="margin-top:10px;"><strong>Astrological Properties</strong></p>
              <ul class="product-page__tab-list">
                <li>Planet : Saturn (Shani)</li>
                <li>Zodiac Sign : Capricorn (Makar) & Aquarius (Kumbh)</li>
                <li>Chakra : Third Eye (Ajna)</li>
                <li>Day to Wear : Saturday</li>
                <li>Metal : Silver or White Gold (Panchdhatu)</li>
                <li>Finger : Middle finger of the right hand</li>
              </ul>
            {%- endif -%}
            <a href="#" class="product-page__read-more">Read More</a>
          </div>
        </div>

        <!-- Customization Panel (shown after clicking CUSTOMIZE) -->
        <div class="product-page__customize-panel" id="customize-panel" style="display:none;">
          <div class="product-page__customize-header">
            <span class="product-page__customize-label">Customization Details</span>
            <button class="product-page__reset-btn" onclick="resetCustomize()">RESET</button>
          </div>
          <div class="product-page__customize-grid">
            <div class="product-page__customize-cell">
              <label>Jewelry Type</label>
              <div class="product-page__customize-val">
                <span>Ring</span>
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              </div>
            </div>
            <div class="product-page__customize-cell">
              <label>Select Metal</label>
              <div class="product-page__customize-val">
                <span class="product-page__metal-swatch product-page__metal-swatch--rose"></span>
                <span>Rose Gold</span>
              </div>
            </div>
            <div class="product-page__customize-cell">
              <label>Metal Purity</label>
              <div class="product-page__customize-val"><span>14K</span></div>
            </div>
            <div class="product-page__customize-cell">
              <label>Ring Size</label>
              <div class="product-page__customize-val"><span>Size 9; 49.0mm</span></div>
            </div>
            <div class="product-page__customize-cell product-page__customize-cell--wide">
              <label>Ring Style</label>
              <div class="product-page__customize-val">
                <span class="product-page__style-swatch"></span>
                <span>Solitaire</span>
              </div>
            </div>
          </div>
        </div>

        <!-- CTA: default (two buttons side-by-side) -->
        <div id="cta-default" class="product-page__dual-cta">
          {%- form 'product', product -%}
            <input type="hidden" name="id" value="{{ current_variant.id }}">
            <input type="hidden" name="quantity" value="1">
            <button
              type="submit"
              class="product-page__btn-outline"
              {% unless product.available %}disabled{% endunless %}
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              ADD LOOSE GEM TO CART
            </button>
          {%- endform -%}
          <button type="button" class="product-page__btn-dark" onclick="showCustomize()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            CUSTOMIZE
          </button>
        </div>

        <!-- CTA: customize (single button, shown after customize click) -->
        <div id="cta-customize" style="display:none;">
          {%- form 'product', product -%}
            <input type="hidden" name="id" value="{{ current_variant.id }}">
            <input type="hidden" name="quantity" value="1">
            <input type="hidden" name="properties[Jewelry Type]" value="Ring">
            <input type="hidden" name="properties[Metal]" value="Rose Gold">
            <input type="hidden" name="properties[Metal Purity]" value="14K">
            <input type="hidden" name="properties[Ring Size]" value="Size 9; 49.0mm">
            <input type="hidden" name="properties[Ring Style]" value="Solitaire">
            <button
              type="submit"
              class="product-page__btn-dark product-page__btn-dark--full"
              {% unless product.available %}disabled{% endunless %}
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              ADD TO CART
            </button>
          {%- endform -%}
        </div>

        <!-- Dispatch info -->
        <div class="product-page__dispatch">
          <span>Estimated Dispatch Date: <strong>02 Sept, 2025</strong></span>
          <span class="product-page__dispatch-sep">For Pincode: <strong>120010</strong></span>
          <a href="#" class="product-page__pincode-link">| Change Pincode</a>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- You May Also Like -->
<section class="product-recs" id="product-recs">
  <div class="page-width">
    <h2 class="product-recs__title">You May Also Like</h2>
    <div class="product-recs__header-row">
      <span></span>
      <a href="/collections/all" class="product-recs__view-all">View All &rarr;</a>
    </div>
    <div class="product-recs__grid">
      {%- assign has_products = false -%}
      {%- for p in collections.all.products limit: 5 -%}
        {%- assign has_products = true -%}
        <div class="product-recs__card">
          <a href="{{ p.url }}" class="product-recs__card-img">
            {%- if p.featured_image -%}
              <img src="{{ p.featured_image | image_url: width: 300 }}" alt="{{ p.title | escape }}" loading="lazy">
            {%- else -%}
              <div class="product-recs__card-placeholder">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
              </div>
            {%- endif -%}
          </a>
          <div class="product-recs__card-info">
            <h4 class="product-recs__card-name">{{ p.title }}</h4>
            <p class="product-recs__card-price">Price: {{ p.price | money }}</p>
          </div>
          <a href="{{ p.url }}" class="product-recs__details-btn">VIEW DETAILS</a>
        </div>
      {%- endfor -%}

      {%- unless has_products -%}
        {%- for i in (1..5) -%}
          <div class="product-recs__card">
            <div class="product-recs__card-img">
              <div class="product-recs__card-placeholder">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
              </div>
            </div>
            <div class="product-recs__card-info">
              <h4 class="product-recs__card-name">Product Name</h4>
              <p class="product-recs__card-price">Price: {{ p.price | money }}</p>
            </div>
            <a href="/collections/all" class="product-recs__details-btn">VIEW DETAILS</a>
          </div>
        {%- endfor -%}
      {%- endunless -%}
    </div>

  </div>
</section>

<!-- Buying Process (above footer) -->
<section class="pdp-buying-process" id="pdp-buying-process">
  <div class="page-width">
    <h2 class="pdp-bp__heading">Easy Buying Process</h2>
    <p class="pdp-bp__subheading">Discover semi-precious gemstones that bring similar planetary benefits</p>

    <div class="pdp-bp__grid">
      <!-- Step 1 -->
      <div class="pdp-bp__item">
        <div class="pdp-bp__icon-wrap">
          <div class="pdp-bp__icon">
            <img
              src="{{ 'bp-browse.svg' | asset_url }}"
              alt="Browse Collection"
              class="pdp-bp__icon-img"
            >
          </div>
          <div class="pdp-bp__number">1</div>
        </div>
        <h3 class="pdp-bp__step-title">BROWSE COLLECTION</h3>
        <p class="pdp-bp__step-desc">Find your perfect gemstone by gem type or planet type.</p>
      </div>

      <!-- Step 2 -->
      <div class="pdp-bp__item">
        <div class="pdp-bp__icon-wrap">
          <div class="pdp-bp__icon">
            <img
              src="{{ 'bp-choose.svg' | asset_url }}"
              alt="Browse Collection"
              class="pdp-bp__icon-img"
            >
          </div>
          <div class="pdp-bp__number">2</div>
        </div>
        <h3 class="pdp-bp__step-title">CHOOSE A DESIGN</h3>
        <p class="pdp-bp__step-desc">Select from over 100 designs available in our design bank.</p>
      </div>

      <!-- Step 3 -->
      <div class="pdp-bp__item">
        <div class="pdp-bp__icon-wrap">
          <div class="pdp-bp__icon">
            <img
              src="{{ 'bp-consult.svg' | asset_url }}"
              alt="Browse Collection"
              class="pdp-bp__icon-img"
            >
          </div>
          <div class="pdp-bp__number">3</div>
        </div>
        <h3 class="pdp-bp__step-title">CONSULT CONCIERGE</h3>
        <p class="pdp-bp__step-desc">Get personalized options, perspective, help, and information from our experts.</p>
      </div>

      <!-- Step 4 -->
      <div class="pdp-bp__item">
        <div class="pdp-bp__icon-wrap">
          <div class="pdp-bp__icon">
            <img
              src="{{ 'bp-checkout.svg' | asset_url }}"
              alt="Browse Collection"
              class="pdp-bp__icon-img"
            >
          </div>
          <div class="pdp-bp__number">4</div>
        </div>
        <h3 class="pdp-bp__step-title">CHECKOUT</h3>
        <p class="pdp-bp__step-desc">Choose from various convenient payment options, including UPI, card, and EMI/COD.</p>
      </div>

      <!-- Step 5 -->
      <div class="pdp-bp__item">
        <div class="pdp-bp__icon-wrap">
          <div class="pdp-bp__icon">
            <img src="{{ 'feature-shipping.svg' | asset_url }}" alt="Receive Gemstone" style="width:100%;height:100%;object-fit:contain;">
          </div>
          <div class="pdp-bp__number">5</div>
        </div>
        <h3 class="pdp-bp__step-title">RECEIVE GEMSTONE</h3>
        <p class="pdp-bp__step-desc">We deliver to over 19,000 PIN codes across India and to over 180 countries globally.</p>
      </div>
    </div>
  </div>
</section>

<style>
  /* Breadcrumb */
  .product-breadcrumb {
    background: var(--color-bg, #faf8f4);
    padding: 10px 0;
    border-bottom: 1px solid var(--color-border-light, #eee);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 4px;
    font-size: 11px;
    font-family: var(--font-body, 'Inter', sans-serif);
    color: #888;
  }

  .breadcrumb a {
    color: #888;
    text-decoration: none;
  }

  .breadcrumb a:hover { color: var(--color-primary, #1a2a3a); }
  .breadcrumb__sep { color: #bbb; }

  .breadcrumb--pdp {
    margin-bottom: 20px;
  }

  /* Page wrapper */
  .product-page { padding: var(--space-2xl, 40px) 0 var(--space-4xl, 80px); }

  @media (max-width: 768px) {
    .product-page { padding: var(--space-xl, 24px) 16px var(--space-3xl, 60px); }
  }

  .product-page__wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl, 60px);
    align-items: flex-start;
  }

  /* Gallery */
  .product-page__gallery {
    display: grid;
    grid-template-columns: 70px 36px 1fr;
    gap: 12px;
  }

  /* Thumbnail strip */
  .product-page__thumbstrip {
    display: flex;
    flex-direction: column;
    gap: 8px;
    max-height: 580px;
    overflow-y: auto;
    scrollbar-width: none;
  }
  .product-page__thumbstrip::-webkit-scrollbar { display: none; }

  .product-page__thumb {
    width: 65px;
    height: 65px;
    border-radius: 6px;
    border: 2px solid transparent;
    overflow: hidden;
    cursor: pointer;
    padding: 0;
    background: var(--color-cream, #f5f0e8);
    flex-shrink: 0;
    transition: border-color 0.2s;
  }
  .product-page__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .product-page__thumb--active,
  .product-page__thumb:hover {
    border-color: var(--color-gold, #b8963e);
  }

  /* Main image */
  .product-page__main-img-wrap {
