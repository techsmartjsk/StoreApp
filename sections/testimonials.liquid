{%- comment -%}
  Testimonials Section
{%- endcomment -%}

<section class="testimonials" id="section-{{ section.id }}">
  <div class="testimonials__header" style="background-color: var(--color-primary); color: #fff; text-align: center; padding: var(--space-xl) 0;">
    <h2 class="section-heading" style="color: #fff; margin: 0; font-size: 20px; letter-spacing: 0.1em; text-transform: uppercase;">{{ section.settings.heading }}</h2>
  </div>

  <div class="page-width" style="padding-top: var(--space-3xl); padding-bottom: var(--space-4xl);">
    <div class="testimonials__grid" style="display: flex; gap: 20px; justify-content: flex-start; align-items: center; overflow-x: auto; padding: 20px 0; -webkit-overflow-scrolling: touch; scroll-snap-type: x mandatory;">
      {%- for block in section.blocks -%}
        <div class="testimonial-card {% if forloop.index == 3 %}testimonial-card--active{% endif %}" {{ block.shopify_attributes }} style="background: #fff; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); padding: 20px; width: 280px; flex-shrink: 0; scroll-snap-align: center; {% if forloop.index == 3 %}transform: scale(1.05); border: 1px solid #ddd; z-index:2;{% else %}opacity: 0.7; transform: scale(0.95);{% endif %} text-align: center;">
          <div class="testimonial-card__avatar" style="width: 40px; height: 40px; border-radius: 50%; background: #eee; margin: 0 auto 10px; overflow: hidden;">
            <svg viewBox="0 0 24 24" fill="#ccc" style="width:100%; height:100%;"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
          </div>
          <h4 style="margin: 0 0 4px; font-size: 11px;">{{ block.settings.author_name }}</h4>
          <div style="font-size: 9px; color: #777; margin-bottom: 8px;">{{ block.settings.date }}</div>
          <div style="color: #f1c40f; font-size: 10px; margin-bottom: 12px; display:flex; justify-content:center; align-items:center; gap:2px;">
            <span>{{ block.settings.rating }} Rating | </span>
            <span>★★★★★</span>
          </div>
          <div style="display:flex; justify-content:center; gap:5px; margin-bottom: 12px;">
             <div style="width:30px; height:30px; background:#f5f5f5; border:1px solid #eee;"></div>
             <div style="width:30px; height:30px; background:#f5f5f5; border:1px solid #eee;"></div>
             <div style="width:30px; height:30px; background:#f5f5f5; border:1px solid #eee;"></div>
          </div>
          <h5 style="font-size: 10px; margin: 0 0 5px; text-align:left;">{{ block.settings.review_title }}</h5>
          <p style="font-size: 9px; color: #555; text-align: left; line-height: 1.5; margin: 0;">{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
    
    <div style="display: flex; justify-content: center; gap: 5px; margin-top: 20px;">
      <div style="width: 20px; height: 3px; background: var(--color-gold);"></div>
      <div style="width: 20px; height: 3px; background: #eee;"></div>
      <div style="width: 20px; height: 3px; background: #eee;"></div>
      <div style="width: 20px; height: 3px; background: #eee;"></div>
      <div style="width: 20px; height: 3px; background: #eee;"></div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "OUR CUSTOMERS LOVE US"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
          "id": "author_name",
          "label": "Author Name",
          "default": "Neha Sharma"
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date",
          "default": "on 2nd sept, 2025"
        },
        {
          "type": "text",
          "id": "rating",
          "label": "Rating",
          "default": "4.5"
        },
        {
          "type": "text",
          "id": "review_title",
          "label": "Review Title",
          "default": "Heading of the review, with lot of... and abbreviations to make it feel like written by human"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review Text",
          "default": "The blue sapphire stone is one of the few charmers that have held the attention of jewelry lovers for centuries..."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "review" },
        { "type": "review" },
        { "type": "review" },
        { "type": "review" },
        { "type": "review" }
      ]
    }
  ]
}
{% endschema %}
