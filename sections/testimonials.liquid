{%- comment -%}
  Testimonials Section
{%- endcomment -%}

<section class="testimonials" id="section-{{ section.id }}">
  <div class="testimonials__header">
    <h2 class="testimonials__title">{{ section.settings.heading }}</h2>
  </div>

  <div class="testimonials__body" id="testimonials-section-{{ section.id }}">

    <!-- Prev / Next buttons -->
    <button class="testimonials__nav testimonials__nav--prev" aria-label="Previous review">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
    </button>

    <div class="testimonials__track-wrap">
      <div class="testimonials__carousel" id="testimonials-carousel-{{ section.id }}">
        {%- for block in section.blocks -%}
          <div class="testimonial-card" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
            <div class="testimonial-card__top">
              <div class="testimonial-card__avatar-wrap">
                <div class="testimonial-card__avatar">
                  {%- if block.settings.avatar != blank -%}
                    <img src="{{ block.settings.avatar | image_url: width: 80 }}" alt="{{ block.settings.author_name }}" loading="lazy">
                  {%- else -%}
                    <svg viewBox="0 0 24 24" fill="#ccc"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
                  {%- endif -%}
                </div>
                <div class="testimonial-card__source-badge">
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" width="14" height="14"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
                </div>
              </div>
              <h4 class="testimonial-card__name">{{ block.settings.author_name }}</h4>
              <div class="testimonial-card__date">{{ block.settings.date }}</div>
              <div class="testimonial-card__rating">
                {%- assign rating = block.settings.rating | times: 1.0 -%}
                {%- assign rating_floor = rating | floor -%}
                {%- assign rating_ceil = rating | ceil -%}
                {%- assign is_half = false -%}
                {%- if rating_floor != rating_ceil -%}{%- assign is_half = true -%}{%- endif -%}
                <span class="testimonial-card__rating-text">{{ block.settings.rating }} Rating</span>
                <span class="testimonial-card__rating-sep">|</span>
                <span class="testimonial-card__stars">
                  {%- for i in (1..5) -%}
                    {%- if i <= rating_floor -%}★{%- elsif is_half and i == rating_ceil -%}★{%- else -%}☆{%- endif -%}
                  {%- endfor -%}
                </span>
              </div>
            </div>
            {%- if block.settings.product_image_1 != blank or block.settings.product_image_2 != blank or block.settings.product_image_3 != blank -%}
              <div class="testimonial-card__images">
                {%- if block.settings.product_image_1 != blank -%}<div class="testimonial-card__img-thumb"><img src="{{ block.settings.product_image_1 | image_url: width: 60 }}" alt="" loading="lazy"></div>{%- endif -%}
                {%- if block.settings.product_image_2 != blank -%}<div class="testimonial-card__img-thumb"><img src="{{ block.settings.product_image_2 | image_url: width: 60 }}" alt="" loading="lazy"></div>{%- endif -%}
                {%- if block.settings.product_image_3 != blank -%}<div class="testimonial-card__img-thumb"><img src="{{ block.settings.product_image_3 | image_url: width: 60 }}" alt="" loading="lazy"></div>{%- endif -%}
              </div>
            {%- endif -%}
            {%- if block.settings.review_title != blank -%}<h5 class="testimonial-card__review-title">{{ block.settings.review_title }}</h5>{%- endif -%}
            <p class="testimonial-card__text">{{ block.settings.text }}</p>
          </div>
        {%- endfor -%}
      </div>
    </div>

    <button class="testimonials__nav testimonials__nav--next" aria-label="Next review">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
    </button>

    <div class="testimonials__indicators">
      {%- for block in section.blocks -%}
        <div class="testimonials__dot" data-index="{{ forloop.index0 }}"></div>
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
(function() {
  const section   = document.getElementById('testimonials-section-{{ section.id }}');
  if (!section) return;

  const carousel  = section.querySelector('.testimonials__carousel');
  const cards     = Array.from(section.querySelectorAll('.testimonial-card'));
  const dots      = Array.from(section.querySelectorAll('.testimonials__dot'));
  const prevBtn   = section.querySelector('.testimonials__nav--prev');
  const nextBtn   = section.querySelector('.testimonials__nav--next');
  const total     = cards.length;
  let current     = 0;
  let autoTimer   = null;
  let paused      = false;

  function getCardWidth() {
    return cards[0] ? cards[0].offsetWidth + 20 : 300; // card + gap
  }

  function scrollTo(idx) {
    current = ((idx % total) + total) % total;
    const card = cards[current];
    if (!card) return;

    // Scroll so the target card is centred in the viewport
    const containerW = carousel.offsetWidth;
    const cardW      = card.offsetWidth;
    const target     = card.offsetLeft - (containerW / 2) + (cardW / 2);
    
    // Safety check for target
    const maxScroll = carousel.scrollWidth - containerW;
    const finalTarget = Math.max(0, Math.min(target, maxScroll));
    
    carousel.scrollTo({ left: finalTarget, behavior: 'smooth' });

    // Update active states
    cards.forEach((c, i) => c.classList.toggle('testimonial-card--active', i === current));
    dots.forEach((d, i) => d.classList.toggle('testimonials__dot--active', i === current));
  }

  // Arrow buttons
  prevBtn.addEventListener('click', () => { paused = true; scrollTo(current - 1); setTimeout(() => { paused = false; }, 4000); });
  nextBtn.addEventListener('click', () => { paused = true; scrollTo(current + 1); setTimeout(() => { paused = false; }, 4000); });

  // Dot clicks
  dots.forEach((dot, i) => dot.addEventListener('click', () => { paused = true; scrollTo(i); setTimeout(() => { paused = false; }, 4000); }));

  // Track scroll position → update active card & dots
  let scrollTimer;
  carousel.addEventListener('scroll', () => {
    clearTimeout(scrollTimer);
    scrollTimer = setTimeout(() => {
      const centre = carousel.scrollLeft + carousel.offsetWidth / 2;
      let closest = 0, minDist = Infinity;
      cards.forEach((c, i) => {
        const dist = Math.abs(c.offsetLeft + c.offsetWidth / 2 - centre);
        if (dist < minDist) { minDist = dist; closest = i; }
      });
      if (closest !== current) {
        current = closest;
        cards.forEach((c, i) => c.classList.toggle('testimonial-card--active', i === current));
        dots.forEach((d, i) => d.classList.toggle('testimonials__dot--active', i === current));
      }
    }, 80);
  });

  // Pause auto-scroll on hover / touch
  carousel.addEventListener('mouseenter', () => { paused = true; });
  carousel.addEventListener('mouseleave', () => { paused = false; });
  carousel.addEventListener('touchstart',  () => { paused = true; }, { passive: true });
  carousel.addEventListener('touchend',    () => { setTimeout(() => { paused = false; }, 3000); }, { passive: true });

  // Auto-scroll every 3.5 s
  function startAuto() {
    autoTimer = setInterval(() => { if (!paused) scrollTo(current + 1); }, 3500);
  }

  // Initialise
  function init() {
    const startIdx = window.innerWidth <= 768 ? 0 : Math.floor(total / 2);
    scrollTo(startIdx);
    startAuto();
  }

  // Handle Resize
  let resizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      scrollTo(current);
    }, 200);
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    setTimeout(init, 100);
  }
})();
</script>

<style>
  .testimonials__header {
    background-color: #2d4a3e;
    text-align: center;
    padding: var(--space-xl) 0;
  }

  .testimonials__title {
    color: #fff;
    margin: 0;
    font-size: var(--font-size-xl);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-family: var(--font-heading);
  }

  .testimonials__body {
    position: relative;
    padding-top: var(--space-3xl);
    padding-bottom: var(--space-4xl);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0;
  }

  /* Prev / Next nav buttons */
  .testimonials__nav {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid #ddd;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 5;
    transition: all 0.2s;
    position: relative;
  }
  .testimonials__nav:hover { background: var(--color-gold); border-color: var(--color-gold); color: #fff; }
  .testimonials__nav svg { width: 18px; height: 18px; stroke: currentColor; }

  /* Track wrapper – takes remaining width */
  .testimonials__track-wrap {
    flex: 1;
    overflow: hidden;
    min-width: 0;
  }

  .testimonials__carousel {
    display: flex;
    gap: 20px;
    align-items: center;
    overflow-x: auto;
    padding: 20px 10px 30px;
    -webkit-overflow-scrolling: touch;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .testimonials__carousel::-webkit-scrollbar { display: none; }

  /* Indicators — full width below */
  .testimonials__indicators {
    width: 100%;
    display: flex;
    justify-content: center;
    gap: 6px;
    margin-top: 4px;
  }

  .testimonial-card {
    background: #fdfaf5;
    border-radius: 8px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    padding: 24px 20px;
    width: 340px;
    max-width: 85vw;
    flex-shrink: 0;
    scroll-snap-align: center;
    text-align: left;
    opacity: 0.6;
    transform: scale(0.95);
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    cursor: pointer;
    border: 1px solid transparent;
  }

  .testimonial-card--active {
    opacity: 1;
    transform: scale(1.02);
    background: #fff;
    border: 1px solid #ddd;
    box-shadow: 0 8px 30px rgba(0,0,0,0.08);
    z-index: 2;
  }

  .testimonial-card:hover {
    opacity: 0.85;
  }

  .testimonial-card--active:hover {
    opacity: 1;
  }

  .testimonial-card__top {
    margin-bottom: 12px;
  }

  .testimonial-card__avatar-wrap {
    position: relative;
    width: 56px;
    height: 56px;
    margin: 0 0 10px;
  }

  .testimonial-card__avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #ddd;
    overflow: hidden;
  }
  .testimonial-card__avatar img,
  .testimonial-card__avatar svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .testimonial-card__source-badge {
    position: absolute;
    top: 0;
    right: -2px;
    width: 20px;
    height: 20px;
    background: #fff;
    border-radius: 50%;
    border: 1px solid #e0e0e0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .testimonial-card__name {
    font-size: 12px;
    font-weight: 600;
    margin: 0 0 2px;
  }

  .testimonial-card__date {
    font-size: 10px;
    color: #888;
    margin-bottom: 8px;
  }

  .testimonial-card__rating {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 5px;
    font-size: 10px;
    margin-bottom: 4px;
  }

  .testimonial-card__rating-text {
    color: #555;
  }

  .testimonial-card__rating-sep {
    color: #aaa;
  }

  .testimonial-card__stars {
    color: #f1c40f;
    letter-spacing: 1px;
  }

  .testimonial-card__images {
    display: flex;
    justify-content: flex-start;
    gap: 6px;
    margin-bottom: 14px;
  }

  .testimonial-card__img-thumb {
    width: 55px;
    height: 55px;
    background: #e8e8e8;
    border-radius: 4px;
    overflow: hidden;
  }
  .testimonial-card__img-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .testimonial-card__review-title {
    font-size: 11px;
    font-weight: 600;
    margin: 0 0 6px;
    text-align: left;
    line-height: 1.4;
  }

  .testimonial-card__text {
    font-size: 10px;
    color: #555;
    text-align: left;
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .testimonials__dot {
    width: 20px;
    height: 3px;
    background: #ddd;
    border-radius: 2px;
    transition: all var(--transition-base);
  }

  .testimonials__dot {
    cursor: pointer;
  }

  .testimonials__dot--active {
    width: 40px;
    background: var(--color-gold);
  }

  @media (max-width: 768px) {
    .testimonials__nav { display: none; }
    .testimonials__body {
      display: block;
      padding-top: var(--space-lg);
      padding-bottom: var(--space-xl);
    }
    .testimonials__track-wrap {
      width: 100%;
      overflow: hidden;
    }
    .testimonials__carousel {
      display: flex;
      padding-left: 16px;
      padding-right: 16px;
      gap: 12px;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scroll-snap-type: x mandatory;
    }
    .testimonial-card {
      width: 280px;
      min-width: 280px;
      opacity: 1;
      transform: none;
      border: 1px solid #eee;
      background: #fff;
    }
    .testimonial-card--active {
      opacity: 1;
      transform: none;
      box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    }
    .testimonials__indicators {
      display: flex;
      justify-content: center;
      margin-top: 12px;
    }
  }
</style>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "OUR CUSTOMERS LOVE US"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
          "id": "author_name",
          "label": "Author Name",
          "default": "Neha Sharma"
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Author Avatar"
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date",
          "default": "on 2nd sept, 2025"
        },
        {
          "type": "text",
          "id": "rating",
          "label": "Rating",
          "default": "4.5"
        },
        {
          "type": "text",
          "id": "review_title",
          "label": "Review Title",
          "default": "Heading of the review, with lot of... and abbreviations to make it feel like written by human"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review Text",
          "default": "The blue sapphire stone is one of the few charmers that have held the attention of jewelry lovers for centuries. Though sapphire occurs in..."
        },
        {
          "type": "image_picker",
          "id": "product_image_1",
          "label": "Product Image 1"
        },
        {
          "type": "image_picker",
          "id": "product_image_2",
          "label": "Product Image 2"
        },
        {
          "type": "image_picker",
          "id": "product_image_3",
          "label": "Product Image 3"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "review" },
        { "type": "review" },
        { "type": "review" },
        { "type": "review" },
        { "type": "review" }
      ]
    }
  ]
}
{% endschema %}
