{%- comment -%}
  Trust Badges Section
  Horizontal strip showing trust/value propositions
{%- endcomment -%}

<section class="trust-badges" id="trust-badges">
  <div class="page-width">
    <div class="trust-badges__wrapper">
      {%- for block in section.blocks -%}
        <div class="trust-badge" {{ block.shopify_attributes }}>
          <div class="trust-badge__icon">
            {% render 'icon', name: block.settings.icon %}
          </div>
          <span class="trust-badge__text">{{ block.settings.text }}</span>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust Badges",
  "settings": [],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "certificate",
          "options": [
            { "value": "certificate", "label": "Certificate" },
            { "value": "returns", "label": "Returns" },
            { "value": "transparent", "label": "Transparent" },
            { "value": "custom", "label": "Custom Jewellery" },
            { "value": "shipping", "label": "Shipping" },
            { "value": "heart", "label": "Heart" },
            { "value": "gem", "label": "Gem" }
          ]
        },
        {
          "type": "text",
          "id": "text",
          "label": "Badge text",
          "default": "Trust Badge"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Badges",
      "blocks": [
        { "type": "badge", "settings": { "icon": "certificate", "text": "Verifiable Certificates" } },
        { "type": "badge", "settings": { "icon": "returns", "text": "Easy Returns" } },
        { "type": "badge", "settings": { "icon": "transparent", "text": "Transparent Operations" } },
        { "type": "badge", "settings": { "icon": "custom", "text": "Customised Jewellery" } },
        { "type": "badge", "settings": { "icon": "shipping", "text": "Worldwide Shipping" } }
      ]
    }
  ]
}
{% endschema %}
