{%- comment -%}
  Facets/Filtering Snippet — fully dynamic via Shopify Search & Discovery metafield filters
  Usage: {% render 'facets', results: collection, enable_filtering: true %}

  SETUP REQUIRED IN SHOPIFY ADMIN:
  Online Store → Search & Discovery → Filters → Add filters:
    • Gem Type        (product.metafields.custom.gem_type)
    • Origin          (product.metafields.custom.origin)
    • Treatment Status(product.metafields.custom.treatment_status)
    • Planetary Alignment (product.metafields.custom.planetary_alignment)
    • Shape Cut       (product.metafields.custom.shape_cut)
    • Cutting Style   (product.metafields.custom.cutting_style)
    • Transparency    (product.metafields.custom.transparency)
    • Certification Lab (product.metafields.custom.certification_lab)
    • Weight Carats   (product.metafields.custom.weight_carats) — as number range
    • Price           (built-in)
{%- endcomment -%}

{%- comment -%} Map collection handle → Gem Type value for auto-pre-selection {%- endcomment -%}
{%- assign _col = collection.handle | downcase -%}
{%- assign _auto_gem = '' -%}
{%- case _col -%}
  {%- when 'ruby' -%}             {%- assign _auto_gem = 'Ruby' -%}
  {%- when 'pearl' -%}            {%- assign _auto_gem = 'Pearl' -%}
  {%- when 'emerald' -%}          {%- assign _auto_gem = 'Emerald' -%}
  {%- when 'cateye' -%}           {%- assign _auto_gem = 'Cats Eye' -%}
  {%- when 'red-coral' -%}        {%- assign _auto_gem = 'Coral' -%}
  {%- when 'blue-sapphire' -%}    {%- assign _auto_gem = 'Blue Sapphire' -%}
  {%- when 'yellow-sapphire' -%}  {%- assign _auto_gem = 'Yellow Sapphire' -%}
  {%- when 'hessonite' -%}        {%- assign _auto_gem = 'Hessonite' -%}
  {%- when 'white-sapphire' -%}   {%- assign _auto_gem = 'White Sapphire' -%}
  {%- when 'red-garnet', 'garnet' -%} {%- assign _auto_gem = 'Garnet' -%}
  {%- when 'amethyst' -%}         {%- assign _auto_gem = 'Amethyst' -%}
  {%- when 'citrine' -%}          {%- assign _auto_gem = 'Citrine' -%}
  {%- when 'iolite' -%}           {%- assign _auto_gem = 'Iolite' -%}
  {%- when 'turquoise' -%}        {%- assign _auto_gem = 'Turquoise' -%}
  {%- when 'peridot' -%}          {%- assign _auto_gem = 'Peridot' -%}
  {%- when 'tourmaline' -%}       {%- assign _auto_gem = 'Tourmaline' -%}
  {%- when 'moonstone' -%}        {%- assign _auto_gem = 'Moonstone' -%}
  {%- when 'lapis-lazuli' -%}     {%- assign _auto_gem = 'Lapis Lazuli' -%}
  {%- when 'malachite' -%}        {%- assign _auto_gem = 'Malachite' -%}
  {%- when 'natural-zircon' -%}   {%- assign _auto_gem = 'Natural Zircon' -%}
  {%- when 'blue-topaz' -%}       {%- assign _auto_gem = 'Blue Topaz' -%}
  {%- when 'tiger-eye' -%}        {%- assign _auto_gem = 'Tiger Eye' -%}
  {%- when 'aquamarine' -%}       {%- assign _auto_gem = 'Aquamarine' -%}
  {%- when 'pitambari' -%}        {%- assign _auto_gem = 'Bi-colour Sapphire' -%}

  {%- when 'white-coral' -%}      {%- assign _auto_gem = 'White Coral' -%}

  {%- when 'sphatik' -%}          {%- assign _auto_gem = 'Sphatik' -%}

{%- endcase -%}

{%- comment -%} Count total active filters {%- endcomment -%}
{%- assign _active_count = 0 -%}
{%- for filter in results.filters -%}
  {%- if filter.type == 'price_range' -%}
    {%- if filter.min_value.value or filter.max_value.value -%}
      {%- assign _active_count = _active_count | plus: 1 -%}
    {%- endif -%}
  {%- else -%}
    {%- assign _active_count = _active_count | plus: filter.active_values.size -%}
  {%- endif -%}
{%- endfor -%}

<div class="facets-container" id="FacetsContainer">

  {%- comment -%} Active filter chips row (shown above sidebar) {%- endcomment -%}
  {%- if _active_count > 0 -%}
    <div class="active-facets" id="ActiveFacets">
      {%- for filter in results.filters -%}
        {%- for value in filter.active_values -%}
          <a class="active-facets__button" href="{{ value.url_to_remove }}">
            <span class="active-facets__button-inner">
              {{ value.label | escape }}
              <svg viewBox="0 0 14 14" width="10" height="10"><path d="M13 13L1 1M13 1L1 13" stroke="currentColor" stroke-width="2" fill="none"/></svg>
            </span>
          </a>
        {%- endfor -%}
        {%- if filter.type == 'price_range' and filter.min_value.value or filter.max_value.value -%}
          <a class="active-facets__button" href="{{ filter.url_to_remove }}">
            <span class="active-facets__button-inner">
              {%- if filter.min_value.value -%}{{ filter.min_value.value | money }}{%- else -%}{{ 0 | money }}{%- endif -%}
              –
              {%- if filter.max_value.value -%}{{ filter.max_value.value | money }}{%- else -%}{{ filter.range_max | money }}{%- endif -%}
              <svg viewBox="0 0 14 14" width="10" height="10"><path d="M13 13L1 1M13 1L1 13" stroke="currentColor" stroke-width="2" fill="none"/></svg>
            </span>
          </a>
        {%- endif -%}
      {%- endfor -%}
      <a href="{{ results.url }}" class="active-facets__clear">Clear all ({{ _active_count }})</a>
    </div>
  {%- endif -%}

  <form id="FacetFiltersForm" class="facets__form">
    {%- if results.terms -%}
      <input type="hidden" name="q" value="{{ results.terms | escape }}">
      <input name="options[prefix]" type="hidden" value="last">
    {%- endif -%}

    <div class="facets__wrapper">

      <!-- Mobile toggle -->
      <div class="facets__mobile-toggle show-on-mobile">
        <button type="button" class="facets__mobile-btn" id="MobileFilterToggle">
          <svg viewBox="0 0 24 24" width="16" height="16"><path d="M3 6h18M6 12h12M10 18h4" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/></svg>
          Filters &amp; Sort
          {%- if _active_count > 0 -%}
            <span class="facets__active-badge">{{ _active_count }}</span>
          {%- endif -%}
        </button>
      </div>

      <div class="facets__list" id="FacetsItems">

        {%- if results.filters.size == 0 -%}
          {%- comment -%}
            No filters returned — metafield filters haven't been configured in
            Search & Discovery yet. Show a helpful message in development.
          {%- endcomment -%}
          <div class="facets__empty-notice">
            <p>To enable filters, go to <strong>Shopify Admin → Search &amp; Discovery → Filters</strong>
            and add your product metafields (Gem Type, Origin, Treatment Status, etc.).</p>
          </div>
        {%- endif -%}

        {%- for filter in results.filters -%}
          {%- comment -%} Skip filters with no values - and skip price_range as it is now in the top toolbar {%- endcomment -%}
          {%- if filter.type == 'price_range' -%}
            {%- continue -%}
          {%- endif -%}
          {%- if filter.type != 'price_range' and filter.values.size == 0 -%}
            {%- continue -%}
          {%- endif -%}

          <details
            class="facets__disclosure"
            id="Details-{{ filter.label | handleize }}-{{ section.id }}"
            {%- if filter.active_values.size > 0
                or filter.type == 'price_range' and filter.min_value.value or filter.max_value.value
                or forloop.index <= 3 -%}
              open
            {%- endif -%}
          >
            <summary class="facets__summary">
              <span class="facets__summary-label">
                {{ filter.label | escape }}
                {%- if filter.active_values.size > 0 -%}
                  <span class="facets__selected-count">{{ filter.active_values.size }}</span>
                {%- endif -%}
              </span>
              <svg viewBox="0 0 24 24" width="14" height="14" class="icon-caret" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
            </summary>

            <div class="facets__display">
              {%- if filter.active_values.size > 0 -%}
                <div class="facets__filter-header">
                  <a href="{{ filter.url_to_remove }}" class="facets__reset">✕ Reset</a>
                </div>
              {%- endif -%}

              {%- case filter.type -%}

                {%- when 'list' or 'boolean' -%}
                  {%- comment -%} Search box for long filter lists {%- endcomment -%}
                  {%- if filter.values.size > 8 -%}
                    <div class="facets__search-wrap">
                      <input
                        type="text"
                        class="facets__search-input"
                        placeholder="Search {{ filter.label | downcase }}…"
                        data-filter-search="{{ filter.label | handleize }}"
                        aria-label="Search {{ filter.label }} options"
                      >
                    </div>
                  {%- endif -%}

                  <ul
                    class="facets__list-unstyled{% if filter.values.size > 8 %} facets__list-scrollable{% endif %}"
                    role="list"
                    data-filter-list="{{ filter.label | handleize }}"
                  >
                    {%- for value in filter.values -%}
                      {%- comment -%}
                        Auto-pre-select: if this is the Gem Type filter and the value matches
                        the collection handle mapping, treat it as active visually.
                        The JS will handle actually applying it on first load.
                      {%- endcomment -%}
                      {%- assign _is_auto = false -%}
                      {%- if _auto_gem != '' and filter.label == 'Gem Type' and value.label == _auto_gem -%}
                        {%- assign _is_auto = true -%}
                      {%- endif -%}

                      <li
                        class="facets__item"
                        data-filter-option="{{ value.label | downcase }}"
                        {%- if value.count == 0 and value.active == false -%} style="opacity:.4;pointer-events:none;"{%- endif -%}
                      >
                        <label
                          for="Filter-{{ filter.label | handleize }}-{{ forloop.index }}"
                          class="facet-checkbox{% if value.active or _is_auto %} facet-checkbox--active{% endif %}"
                        >
                          <input
                            type="checkbox"
                            name="{{ value.param_name }}"
                            value="{{ value.value }}"
                            id="Filter-{{ filter.label | handleize }}-{{ forloop.index }}"
                            {% if value.active %}checked{% endif %}
                            {% if value.count == 0 and value.active == false %}disabled{% endif %}
                            data-auto-select="{% if _is_auto %}true{% else %}false{% endif %}"
                            data-filter-label="{{ filter.label | escape }}"
                          >
                          <span class="facet-checkbox__box">
                            <svg viewBox="0 0 12 10" width="12" height="10" fill="none">
                              <path d="M1 5l3.5 3.5L11 1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                          </span>
                          <span class="facet-checkbox__label">{{ value.label | escape }}</span>
                          <span class="facet-checkbox__count">{{ value.count }}</span>
                        </label>
                      </li>
                    {%- endfor -%}
                  </ul>

                {%- when 'price_range' -%}
                  <div class="facets__price-presets">
                    <button type="button" 
                      class="facets__price-preset{% if filter.min_value.value == nil and filter.max_value.value == 5000000 %} is-active{% endif %}"
                      data-min="0" data-max="50000"
                    >
                      Below ₹50K
                    </button>
                    
                    <button type="button" 
                      class="facets__price-preset{% if filter.min_value.value == 5000000 and filter.max_value.value == 100000000 %} is-active{% endif %}"
                      data-min="50000" data-max="1000000"
                    >
                      ₹50K - ₹10 Lakh
                    </button>
                    
                    <button type="button" 
                      class="facets__price-preset{% if filter.min_value.value == 100000000 %} is-active{% endif %}"
                      data-min="1000000" data-max=""
                    >
                      Above ₹10 Lakh
                    </button>
                  </div>

                  {%- comment -%} Hidden inputs to maintain Shopify's parameter structure {%- endcomment -%}
                  <input type="hidden" name="{{ filter.min_value.param_name }}" id="Filter-{{ filter.label | handleize }}-GTE" value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}">
                  <input type="hidden" name="{{ filter.max_value.param_name }}" id="Filter-{{ filter.label | handleize }}-LTE" value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}">
              {%- endcase -%}
            </div>
          </details>
        {%- endfor -%}

        <!-- Mobile sort -->
        <div class="facets__mobile-sort show-on-mobile">
          <label class="facets__sort-label">Sort by</label>
          <select name="sort_by" class="facets__sort-select" id="Mobile-SortBy">
            <option value="manual" {% if results.sort_by == 'manual' or results.sort_by == '' %}selected{% endif %}>Featured</option>
            <option value="price-ascending" {% if results.sort_by == 'price-ascending' %}selected{% endif %}>Price: Low to High</option>
            <option value="price-descending" {% if results.sort_by == 'price-descending' %}selected{% endif %}>Price: High to Low</option>
            <option value="title-ascending" {% if results.sort_by == 'title-ascending' %}selected{% endif %}>Weight: Low to High</option>
            <option value="title-descending" {% if results.sort_by == 'title-descending' %}selected{% endif %}>Weight: High to Low</option>
          </select>
        </div>

      </div><!-- /FacetsItems -->
    </div><!-- /facets__wrapper -->
  </form>
</div>

<style>
  /* ── Container ── */
  .facets-container { padding-right: var(--space-xl); }

  /* ── Active chips row ── */
  .active-facets {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: var(--space-lg);
  }
  .active-facets__button {
    display: inline-flex;
    align-items: center;
    background: var(--color-cream);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    padding: 4px 10px;
    font-size: 11px;
    cursor: pointer;
    transition: all 0.2s;
  }
  .active-facets__button:hover { background: #fde8e8; border-color: #e74c3c; color: #e74c3c; }
  .active-facets__button-inner { display: flex; align-items: center; gap: 5px; }
  .active-facets__clear {
    font-size: 11px;
    color: var(--color-gold);
    text-decoration: underline;
    display: flex;
    align-items: center;
    padding: 0 4px;
  }

  /* ── Heading ── */
  .facets__heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-md);
    border-bottom: 2px solid var(--color-border-light);
  }
  .facets__heading-title {
    font-size: var(--font-size-base);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .facets__active-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    background: var(--color-gold);
    color: #fff;
    border-radius: 50%;
    font-size: 10px;
    font-weight: 700;
  }
  .facets__clear-all { font-size: 11px; color: var(--color-gold); text-decoration: underline; }

  /* ── Mobile button ── */
  .facets__mobile-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    padding: 12px 16px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-white);
    font-family: var(--font-accent);
    font-size: var(--font-size-sm);
    font-weight: 600;
    letter-spacing: 0.05em;
    cursor: pointer;
    text-transform: uppercase;
  }

  /* ── Disclosure groups ── */
  .facets__disclosure {
    border-bottom: 1px solid var(--color-border-light);
    margin-bottom: 2px;
  }
  .facets__summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    list-style: none;
    padding: 12px 0;
    user-select: none;
  }
  .facets__summary::-webkit-details-marker { display: none; }
  .facets__summary-label {
    font-size: var(--font-size-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .facets__selected-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 18px;
    height: 18px;
    padding: 0 5px;
    background: var(--color-gold);
    color: #fff;
    border-radius: 10px;
    font-size: 9px;
    font-weight: 700;
  }
  .icon-caret { transition: transform 0.2s; flex-shrink: 0; }
  details[open] > .facets__summary .icon-caret { transform: rotate(180deg); }

  .facets__display { padding: 4px 0 14px; }
  .facets__filter-header { margin-bottom: 8px; }
  .facets__reset {
    font-size: 10px;
    color: #e74c3c;
    text-decoration: none;
  }
  .facets__reset:hover { text-decoration: underline; }

  /* ── Search within filter ── */
  .facets__search-wrap { margin-bottom: 8px; }
  .facets__search-input {
    width: 100%;
    padding: 6px 10px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-xs);
    font-family: var(--font-body);
    outline: none;
  }
  .facets__search-input:focus { border-color: var(--color-gold); }

  /* ── Filter list ── */
  .facets__list-unstyled { margin: 0; padding: 0; list-style: none; }
  .facets__list-scrollable {
    max-height: 240px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
    padding-right: 4px;
  }
  .facets__list-scrollable::-webkit-scrollbar { width: 3px; }
  .facets__list-scrollable::-webkit-scrollbar-thumb { background: var(--color-border); border-radius: 2px; }
  .facets__item { margin-bottom: 2px; }

  /* ── Checkbox ── */
  .facet-checkbox {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 5px 4px;
    border-radius: 4px;
    cursor: pointer;
    font-size: var(--font-size-xs);
    transition: background 0.15s;
  }
  .facet-checkbox:hover { background: var(--color-cream); }
  .facet-checkbox input[type='checkbox'] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .facet-checkbox__box {
    width: 16px;
    height: 16px;
    border: 1.5px solid var(--color-border);
    border-radius: 3px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
    background: var(--color-white);
  }
  .facet-checkbox__box svg { opacity: 0; transition: opacity 0.15s; color: #fff; }

  .facet-checkbox input:checked ~ .facet-checkbox__box,
  .facet-checkbox--active .facet-checkbox__box {
    background: var(--color-gold);
    border-color: var(--color-gold);
  }
  .facet-checkbox input:checked ~ .facet-checkbox__box svg,
  .facet-checkbox--active .facet-checkbox__box svg { opacity: 1; }

  .facet-checkbox__label { flex: 1; line-height: 1.3; }
  .facet-checkbox__count {
    font-size: 10px;
    color: var(--color-text-muted);
    background: var(--color-cream);
    padding: 1px 5px;
    border-radius: 10px;
    flex-shrink: 0;
  }

  /* ── Price range presets ── */
  .facets__price-presets {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 20px;
    align-items: flex-start;
  }
  .facets__price-preset {
    flex: 1 1 100%;
    background: #f9ebcf;
    border: 1px solid #dcd1ba;
    border-radius: 0;
    padding: 10px 8px;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    color: #282c3f;
    cursor: pointer;
    transition: all 0.25s ease;
    white-space: nowrap;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
  }
  .facets__price-preset:hover {
    background: #fdf5e6;
    border-color: var(--color-gold);
    color: #282c3f;
  }
  .facets__price-preset.is-active {
    background: var(--color-gold) !important;
    border-color: var(--color-gold);
    color: #fff !important;
  }

  /* ── Empty notice ── */
  .facets__empty-notice {
    padding: var(--space-lg);
    background: #fff8e7;
    border: 1px solid #f1c40f;
    border-radius: var(--radius-sm);
    font-size: var(--font-size-xs);
    color: #7d6608;
    line-height: 1.5;
  }

  /* ── Mobile sort ── */
  .facets__mobile-sort { margin-top: var(--space-lg); }
  .facets__sort-label { display: block; font-size: var(--font-size-xs); font-weight: 600; text-transform: uppercase; margin-bottom: 6px; }
  .facets__sort-select {
    width: 100%;
    padding: 9px 12px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-white);
    font-family: var(--font-body);
    font-size: var(--font-size-sm);
  }

  /* ── Responsive ── */
  .show-on-mobile { display: none; }
  @media screen and (max-width: 992px) {
    .facets-container { padding-right: 0; margin-bottom: var(--space-xl); }
    .hide-on-mobile { display: none !important; }
    .show-on-mobile { display: block; }
    #FacetsItems { display: none; padding-top: var(--space-md); }
    #FacetsItems.is-visible { display: block; }
    .active-facets { margin-top: var(--space-md); }
  }
</style>

<script>
(function() {
  'use strict';

  document.addEventListener('DOMContentLoaded', function() {
    var form     = document.getElementById('FacetFiltersForm');
    var facetsEl = document.getElementById('FacetsItems');
    if (!form) return;

    /* ── Auto-select based on collection ──────────────────────── */
    var autoGem = {{ _auto_gem | json }};
    if (autoGem) {
      var alreadyFiltered = window.location.search.indexOf('filter.') > -1;
      if (!alreadyFiltered) {
        // Find and click the checkbox for this gem type on page load
        var gemInputs = form.querySelectorAll('input[type="checkbox"][data-auto-select="true"]');
        if (gemInputs.length > 0) {
          // Trigger form submit with this value pre-checked
          gemInputs[0].checked = true;
          submitForm();
          return; // page will reload with filter applied
        }
      }
    }

    /* ── Auto-submit on checkbox change ──────────────────────── */
    form.addEventListener('change', function(e) {
      if (e.target.type === 'checkbox') {
        submitForm();
      }
    });

    /* ── Price range presets: handle click ────────────────────── */
    var pricePresets = form.querySelectorAll('.facets__price-preset');
    pricePresets.forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        var min = btn.getAttribute('data-min');
        var max = btn.getAttribute('data-max');
        
        var minInp = document.getElementById('Filter-price-GTE');
        var maxInp = document.getElementById('Filter-price-LTE');
        
        if (minInp) minInp.value = min;
        if (maxInp) maxInp.value = max;
        
        submitForm();
      });
    });

    /* ── Submit helper ────────────────────────────────────────── */
    function submitForm() {
      var params = new URLSearchParams(new FormData(form));
      // Carry over the sort if already set
      var existingSort = new URLSearchParams(window.location.search).get('sort_by');
      if (existingSort && !params.has('sort_by')) {
        params.set('sort_by', existingSort);
      }
      window.location.href = window.location.pathname + '?' + params.toString();
    }

    /* ── In-filter search (live option filter) ────────────────── */
    document.querySelectorAll('.facets__search-input').forEach(function(inp) {
      var listKey = inp.getAttribute('data-filter-search');
      var list    = document.querySelector('[data-filter-list="' + listKey + '"]');
      if (!list) return;
      inp.addEventListener('input', function() {
        var q = inp.value.trim().toLowerCase();
        list.querySelectorAll('.facets__item').forEach(function(li) {
          var text = li.getAttribute('data-filter-option') || '';
          li.style.display = text.indexOf(q) > -1 ? '' : 'none';
        });
      });
    });

    /* ── Mobile toggle ────────────────────────────────────────── */
    var toggleBtn = document.getElementById('MobileFilterToggle');
    if (toggleBtn && facetsEl) {
      toggleBtn.addEventListener('click', function() {
        facetsEl.classList.toggle('is-visible');
        toggleBtn.setAttribute('aria-expanded', facetsEl.classList.contains('is-visible'));
      });
    }

    /* ── Mobile sort auto-submit ──────────────────────────────── */
    var mobileSort = document.getElementById('Mobile-SortBy');
    if (mobileSort) {
      mobileSort.addEventListener('change', function() {
        var params = new URLSearchParams(window.location.search);
        params.set('sort_by', mobileSort.value);
        window.location.search = params.toString();
      });
    }
  });
})();
</script>
