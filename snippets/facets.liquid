{%- comment -%}
  Facets/Filtering Snippet
  Usage: {% render 'facets', results: collection, enable_filtering: true %}
{%- endcomment -%}

<div class="facets-container">
  <form id="FacetFiltersForm" class="facets__form">
    {%- if results.terms -%}
      <input type="hidden" name="q" value="{{ results.terms | escape }}">
      <input name="options[prefix]" type="hidden" value="last">
    {%- endif -%}

    {%- if results.current_vendor or results.current_type -%}
      <input type="hidden" name="q" value="{{ results.current_vendor }}{{ results.current_type }}">
    {%- endif -%}

    <div class="facets__wrapper">
      <div class="facets__heading hide-on-mobile">
        <h2 class="facets__heading-title">Filter By</h2>
      </div>

      <div class="facets__mobile-toggle show-on-mobile">
        <button type="button" class="btn btn--secondary btn--full" id="MobileFilterToggle">
          Filter & Sort
          <svg viewBox="0 0 24 24" width="16" height="16" style="margin-left:8px;"><path d="M3 6h18M6 12h12M10 18h4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </button>
      </div>

      <div class="facets__list" id="FacetsItems">
        {%- for filter in results.filters -%}
          <details class="facets__disclosure" id="Details-{{ forloop.index }}-{{ section.id }}" open>
            <summary class="facets__summary">
              <span class="facets__summary-label">
                {{ filter.label | escape }}
                {%- if filter.active_values.size > 0 -%}
                  <span class="facets__selected no-js-hidden">({{ filter.active_values.size }})</span>
                {%- endif -%}
              </span>
              <svg viewBox="0 0 24 24" width="16" height="16" class="icon-caret"><path d="M6 9l6 6 6-6" fill="none" stroke="currentColor" stroke-width="2"/></svg>
            </summary>
            
            <div class="facets__display">
              <div class="facets__header">
                <span class="facets__selected no-js-hidden">{{ filter.active_values.size }} selected</span>
                <a href="{{ filter.url_to_remove }}" class="facets__reset link underlined-link">
                  Reset
                </a>
              </div>

              {%- case filter.type -%}
                {%- when 'boolean' or 'list' -%}
                  <ul class="facets__list-unstyled" role="list">
                    {%- for value in filter.values -%}
                      <li class="list-menu__item facets__item">
                        <label for="Filter-{{ filter.label | escape }}-{{ forloop.index }}" class="facet-checkbox{% if value.count == 0 and value.active == false %} facet-checkbox--disabled{% endif %}">
                          <input type="checkbox"
                            name="{{ value.param_name }}"
                            value="{{ value.value }}"
                            id="Filter-{{ filter.label | escape }}-{{ forloop.index }}"
                            {% if value.active %}checked{% endif %}
                            {% if value.count == 0 and value.active == false %}disabled{% endif %}
                          >
                          <svg width="1.6rem" height="1.6rem" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                            <rect width="16" height="16" stroke="currentColor" fill="none" stroke-width="1"></rect>
                            <path class="icon-checkmark" d="M11.4 4.3L6.5 9.7l-2.6-2.5" fill="none" stroke="currentColor" stroke-width="2"></path>
                          </svg>
                          <span class="facet-checkbox__label">{{ value.label | escape }}</span>
                          <span class="facet-checkbox__count">({{ value.count }})</span>
                        </label>
                      </li>
                    {%- endfor -%}
                  </ul>

                {%- when 'price_range' -%}
                  <div class="facets__price">
                    <div class="field">
                      <span class="field__currency">{{ cart.currency.symbol }}</span>
                      <input class="field__input"
                        name="{{ filter.min_value.param_name }}"
                        id="Filter-{{ filter.label | escape }}-GTE"
                        {%- if filter.min_value.value -%}
                          value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"
                        {%- endif -%}
                        type="number"
                        placeholder="0"
                        min="0"
                        max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                      >
                    </div>
                    <span class="facets__price-separator">to</span>
                    <div class="field">
                      <span class="field__currency">{{ cart.currency.symbol }}</span>
                      <input class="field__input"
                        name="{{ filter.max_value.param_name }}"
                        id="Filter-{{ filter.label | escape }}-LTE"
                        {%- if filter.max_value.value -%}
                          value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"
                        {%- endif -%}
                        type="number"
                        min="0"
                        placeholder="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                        max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                      >
                    </div>
                  </div>
              {%- endcase -%}
            </div>
          </details>
        {%- endfor -%}

        <!-- Mobile sort dropdown incorporated in filters -->
        <div class="facets__disclosure show-on-mobile" style="margin-top:20px;">
           <label for="Mobile-SortBy" class="facets__summary-label" style="display:block;margin-bottom:10px;">Sort by</label>
           <select name="sort_by" class="facets__sort-select" id="Mobile-SortBy">
            {%- for option in results.sort_options -%}
              <option value="{{ option.value }}" {% if option.value == results.sort_by %}selected{% endif %}>
                {{ option.name | escape }}
              </option>
            {%- endfor -%}
           </select>
        </div>
      </div>

    </div>

    <!-- Active filters -->
    <div class="active-facets active-facets-desktop">
      {%- for filter in results.filters -%}
        {%- for value in filter.active_values -%}
          <a class="active-facets__button" href="{{ value.url_to_remove }}">
            <span class="active-facets__button-inner">
              {{ filter.label }}: {{ value.label | escape }}
              <svg aria-hidden="true" focusable="false" viewBox="0 0 14 14" width="12" height="12">
                <path d="M13 13L1 1M13 1L1 13" stroke="currentColor" stroke-width="2" fill="none"/>
              </svg>
            </span>
          </a>
        {%- endfor -%}
        {% if filter.type == "price_range" %}
          {%- if filter.min_value.value != nil or filter.max_value.value != nil -%}
            <a class="active-facets__button" href="{{ filter.url_to_remove }}">
              <span class="active-facets__button-inner">
                {%- if filter.min_value.value -%}{{ filter.min_value.value | money }}{%- else -%}{{ 0 | money }}{%- endif -%} - 
                {%- if filter.max_value.value -%}{{ filter.max_value.value | money }}{%- else -%}{{ filter.range_max | money }}{%- endif -%}
                <svg aria-hidden="true" focusable="false" viewBox="0 0 14 14" width="12" height="12">
                  <path d="M13 13L1 1M13 1L1 13" stroke="currentColor" stroke-width="2" fill="none"/>
                </svg>
              </span>
            </a>
          {%- endif -%}
        {% endif %}
      {%- endfor -%}
      <a href="{{ results.url }}?sort_by={{ results.sort_by }}" class="active-facets__button-remove link underlined-link">
        Clear all
      </a>
    </div>
  </form>
</div>

<style>
  .facets-container {
    padding-right: var(--space-xl);
  }
  .facets__heading-title {
    font-size: var(--font-size-lg);
    margin-bottom: var(--space-xl);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .facets__disclosure {
    border-bottom: 1px solid var(--color-border-light);
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-md);
  }
  .facets__summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    list-style: none;
    padding: var(--space-sm) 0;
  }
  .facets__summary::-webkit-details-marker {
    display: none;
  }
  .facets__summary-label {
    font-size: var(--font-size-sm);
    font-weight: 600;
    text-transform: uppercase;
  }
  .icon-caret {
    transition: transform var(--transition-fast);
  }
  details[open] > .facets__summary .icon-caret {
    transform: rotate(180deg);
  }
  .facets__header {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    margin-bottom: var(--space-md);
    color: var(--color-text-light);
  }
  .link.underlined-link {
    text-decoration: underline;
    color: var(--color-gold);
  }
  .facets__list-unstyled {
    margin: 0;
    padding: 0;
  }
  .list-menu__item {
    margin-bottom: var(--space-sm);
  }
  .facet-checkbox {
    display: flex;
    align-items: center;
    cursor: pointer;
    font-size: var(--font-size-sm);
  }
  .facet-checkbox input[type='checkbox'] {
    position: absolute;
    opacity: 0;
    width: 1px;
    height: 1px;
  }
  .facet-checkbox svg {
    margin-right: var(--space-sm);
    flex-shrink: 0;
    color: var(--color-border);
  }
  .facet-checkbox > svg > .icon-checkmark {
    visibility: hidden;
  }
  .facet-checkbox input[type='checkbox']:checked + svg > .icon-checkmark {
    visibility: visible;
  }
  .facet-checkbox input[type='checkbox']:checked + svg {
    color: var(--color-gold);
  }
  .facet-checkbox__label {
    flex-grow: 1;
  }
  .facet-checkbox__count {
    color: var(--color-text-light);
    font-size: 11px;
    margin-left: var(--space-xs);
  }
  .facet-checkbox--disabled {
    opacity: 0.5;
    pointer-events: none;
  }
  
  /* Price Range */
  .facets__price {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }
  .field {
    display: flex;
    align-items: center;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-white);
    padding: 4px 8px;
    flex: 1;
  }
  .field__currency {
    color: var(--color-text-light);
    margin-right: 4px;
    font-size: var(--font-size-sm);
  }
  .field__input {
    width: 100%;
    border: none;
    outline: none;
    background: transparent;
    font-size: var(--font-size-sm);
    font-family: inherit;
  }
  .facets__price-separator {
    font-size: var(--font-size-xs);
    color: var(--color-text-light);
  }

  /* Active filters */
  .active-facets {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: var(--space-lg);
  }
  .active-facets__button {
    background: var(--color-cream);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 4px 10px;
    font-size: 11px;
    display: inline-flex;
    align-items: center;
    border-radius: 20px;
  }
  .active-facets__button-inner {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .active-facets__button:hover {
    background: var(--color-gold-light);
    border-color: var(--color-gold);
    color: var(--color-primary);
  }
  .active-facets__button-remove {
    font-size: 11px;
    display: flex;
    align-items: center;
    padding: 4px 10px;
  }

  .show-on-mobile {
    display: none;
  }

  /* Filter form submit handling */
  .facets__sort-select {
    width: 100%;
    padding: 8px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-white);
    font-family: var(--font-body);
  }

  @media screen and (max-width: 992px) {
    .facets-container {
      padding-right: 0;
      margin-bottom: var(--space-xl);
    }
    .hide-on-mobile {
      display: none;
    }
    .show-on-mobile {
      display: block;
    }
    #FacetsItems {
      display: none;
      padding-top: var(--space-md);
      margin-top: var(--space-sm);
      border-top: 1px solid var(--color-border-light);
    }
    #FacetsItems.is-visible {
      display: block;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('FacetFiltersForm');
    if (!form) return;

    // Filter Form Auto-submit on change
    form.addEventListener('input', debounce((event) => {
      const formData = new FormData(form);
      const searchParams = new URLSearchParams(formData);
      
      const queryString = searchParams.toString();
      window.location.href = `${window.location.pathname}?${queryString}`;
    }, 500));

    // Mobile Toggle
    const toggleBtn = document.getElementById('MobileFilterToggle');
    const facetsItems = document.getElementById('FacetsItems');
    if (toggleBtn && facetsItems) {
      toggleBtn.addEventListener('click', () => {
        facetsItems.classList.toggle('is-visible');
      });
    }

    function debounce(func, timeout = 300) {
      let timer;
      return (...args) => {
        clearTimeout(timer);
        timer = setTimeout(() => { func.apply(this, args); }, timeout);
      };
    }
  });
</script>
